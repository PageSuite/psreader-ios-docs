{"sections":[],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"inlineContent":[{"text":"The PSReaderUI SDK provides a modular text-to-speech (TTS) architecture built","type":"text"},{"text":" ","type":"text"},{"text":"around the ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AudioDelegate","isActive":true,"type":"reference"},{"text":" protocol. The system is designed so that each","type":"text"},{"text":" ","type":"text"},{"text":"layer can be swapped independently — you can replace just the voice synthesis,","type":"text"},{"text":" ","type":"text"},{"text":"just the article formatting, or just the UI without touching the rest:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Article Formatter","type":"text"}],"type":"strong"},{"text":" (","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/TextToSpeechArticleFormatter","isActive":true,"type":"reference"},{"text":") — extracts and","type":"text"},{"text":" ","type":"text"},{"text":"formats article text for synthesis.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Speech Synthesizer"}],"type":"strong"},{"type":"text","text":" ("},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/TextToSpeechSynthesizer","isActive":true,"type":"reference"},{"type":"text","text":") — converts formatted"},{"text":" ","type":"text"},{"text":"text into an audio file.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Audio Session Provider"}]},{"type":"text","text":" ("},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AudioSessionProvider"},{"type":"text","text":") — manages the"},{"type":"text","text":" "},{"type":"codeVoice","code":"AVAudioSession"},{"type":"text","text":" lifecycle."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Audio Interface","type":"text"}]},{"type":"text","text":" — presents playback controls to the user as either a"},{"type":"text","text":" "},{"type":"text","text":"transient overlay or a persistent banner."}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The SDK ships default implementations of each component. For most apps, the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultTextToSpeechProvider","type":"reference"},{"text":" class wires everything together in a single","type":"text"},{"text":" ","type":"text"},{"text":"line.","type":"text"}]},{"level":2,"text":"Quick Start","type":"heading","anchor":"Quick-Start"},{"type":"paragraph","inlineContent":[{"text":"Assign a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultTextToSpeechProvider"},{"text":" as the audio delegate on your","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["globalConfig.audioDelegate = PSReaderUI.DefaultTextToSpeechProvider(","    configuration: .init(globalConfig: globalConfig)",")"]},{"type":"paragraph","inlineContent":[{"text":"That’s it. This enables a listen button in the reader navigation bar. When","type":"text"},{"text":" ","type":"text"},{"text":"tapped, the SDK formats the current article, synthesizes speech using the","type":"text"},{"text":" ","type":"text"},{"text":"device’s text-to-speech engine, and presents an audio overlay with playback","type":"text"},{"text":" ","type":"text"},{"text":"controls.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"All of the defaults — article formatting, speech synthesis, audio session","type":"text"},{"text":" ","type":"text"},{"text":"management, and overlay appearance — are handled automatically. The sections","type":"text"},{"text":" ","type":"text"},{"text":"below cover how to customize individual layers if you need more control.","type":"text"}]},{"content":[{"inlineContent":[{"type":"text","text":"TTS is available for "},{"type":"strong","inlineContent":[{"type":"text","text":"article pages only"}]},{"type":"text","text":". Pure PDF pages (non-article"},{"type":"text","text":" "},{"type":"text","text":"page spreads) do not contain structured text and cannot be synthesized. The"},{"type":"text","text":" "},{"type":"text","text":"listen button will not appear for these pages."}],"type":"paragraph"}],"name":"Note","type":"aside","style":"note"},{"level":2,"text":"Custom Synthesizer","type":"heading","anchor":"Custom-Synthesizer"},{"type":"paragraph","inlineContent":[{"text":"The default synthesizer (","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultTextToSpeechSynthesizer","type":"reference","isActive":true},{"text":") uses","type":"text"},{"text":" ","type":"text"},{"code":"AVSpeechSynthesizer","type":"codeVoice"},{"text":" with the device’s default voice. If the user has","type":"text"},{"text":" ","type":"text"},{"text":"downloaded a premium or enhanced voice through ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Settings > Accessibility >"},{"type":"text","text":" "},{"type":"text","text":"Spoken Content > Voices"}]},{"text":", iOS will prefer it automatically. However, most","type":"text"},{"text":" ","type":"text"},{"text":"users will not have done this, and the default system voice can sound","type":"text"},{"text":" ","type":"text"},{"text":"noticeably robotic.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To provide a higher quality experience, implement ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/TextToSpeechSynthesizer","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"and plug in your own synthesis layer — whether that’s a third-party TTS","type":"text"},{"text":" ","type":"text"},{"text":"package bundled with the app or a cloud-based service. Everything else the SDK","type":"text"},{"text":" ","type":"text"},{"text":"provides (article formatting, the overlay UI, audio session management,","type":"text"},{"text":" ","type":"text"},{"text":"playback controls) continues to work unchanged:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct PremiumSynthesizer: PSReaderUI.TextToSpeechSynthesizer {","    func synthesize(string: String, completion: @escaping (Result<URL, Error>) -> Void) {","        \/\/ Call your TTS API, write the audio to a temporary file,","        \/\/ and return the file URL.","        MyTTSService.synthesize(string) { result in","            completion(result)","        }","    }","}","","\/\/ Swap in your synthesizer — the rest of the stack stays the same","globalConfig.audioDelegate = PSReaderUI.DefaultTextToSpeechProvider(","    configuration: .init(globalConfig: globalConfig),","    speechSynthesizer: PremiumSynthesizer()",")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"language"},{"type":"text","text":" parameter on "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultTextToSpeechSynthesizer"},{"type":"text","text":" controls the"},{"type":"text","text":" "},{"type":"text","text":"voice locale when using the built-in engine (defaults to "},{"type":"codeVoice","code":"\"en\""},{"type":"text","text":")."}]},{"level":2,"text":"Custom Article Formatter","type":"heading","anchor":"Custom-Article-Formatter"},{"type":"paragraph","inlineContent":[{"text":"Implement ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/TextToSpeechArticleFormatter","type":"reference","isActive":true},{"text":" to control how article content is","type":"text"},{"text":" ","type":"text"},{"text":"prepared before it reaches the synthesizer. This is useful for stripping","type":"text"},{"text":" ","type":"text"},{"text":"boilerplate, reordering sections, adding pronunciation hints, or inserting","type":"text"},{"text":" ","type":"text"},{"text":"pauses between paragraphs.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Like the synthesizer, the formatter plugs directly into","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultTextToSpeechProvider","type":"reference","isActive":true},{"text":" — you get to customize what text is spoken","type":"text"},{"text":" ","type":"text"},{"text":"without rebuilding the rest of the stack:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct MyArticleFormatter: PSReaderUI.TextToSpeechArticleFormatter {","    func format(article: PSEArticle) throws -> String {","        let title = article.title ?? \"\"","        let body = article.body ?? \"\"","        return \"\\(title). \\(body)\"","    }","","    func format(article: PSArticle) throws -> String {","        return article.title ?? \"\"","    }","}","","globalConfig.audioDelegate = PSReaderUI.DefaultTextToSpeechProvider(","    configuration: .init(globalConfig: globalConfig),","    articleFormatter: MyArticleFormatter()",")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The built-in "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultTextToSpeechArticleFormatter"},{"type":"text","text":" extracts the headline,"},{"type":"text","text":" "},{"type":"text","text":"byline, and body text, strips HTML markup, and joins them into a clean string"},{"type":"text","text":" "},{"type":"text","text":"ready for synthesis."}]},{"type":"paragraph","inlineContent":[{"text":"You can combine a custom formatter and a custom synthesizer together:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["globalConfig.audioDelegate = PSReaderUI.DefaultTextToSpeechProvider(","    configuration: .init(globalConfig: globalConfig),","    articleFormatter: MyArticleFormatter(),","    speechSynthesizer: PremiumSynthesizer()",")"]},{"level":2,"text":"Audio Interface Patterns","type":"heading","anchor":"Audio-Interface-Patterns"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK supports two UI patterns for audio playback. You can use either one or"},{"type":"text","text":" "},{"type":"text","text":"both, depending on your "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AudioDelegate"},{"type":"text","text":" implementation."}]},{"level":3,"text":"Transient Overlay","type":"heading","anchor":"Transient-Overlay"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default pattern used by "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultTextToSpeechProvider"},{"type":"text","text":". When the user taps"},{"type":"text","text":" "},{"type":"text","text":"the listen button, a popover-style overlay appears over the reader content. The"},{"type":"text","text":" "},{"type":"text","text":"overlay includes:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Play \/ Pause"}],"type":"strong"},{"text":" button with a loading indicator during synthesis","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Skip backward \/ forward","type":"text"}],"type":"strong"},{"text":" buttons (15-second increments)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Progress bar","type":"text"}]},{"type":"text","text":" with scrub support for seeking through the audio"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Elapsed","type":"text"}],"type":"strong"},{"type":"text","text":" and "},{"inlineContent":[{"text":"remaining","type":"text"}],"type":"strong"},{"type":"text","text":" time labels"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Title","type":"text"}]},{"type":"text","text":" and "},{"type":"strong","inlineContent":[{"type":"text","text":"subtitle"}]},{"type":"text","text":" labels showing the article name"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK manages the overlay’s presentation and dismissal. The overlay is"},{"type":"text","text":" "},{"type":"text","text":"dismissed when the user taps outside it. On iOS 26+, the overlay adopts the"},{"type":"text","text":" "},{"type":"text","text":"Liquid Glass design language by default."}]},{"type":"paragraph","inlineContent":[{"text":"To provide a fully custom overlay UI while keeping the SDK’s lifecycle","type":"text"},{"text":" ","type":"text"},{"text":"management, subclass ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AudioOverlay"},{"text":":","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a subclass of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AudioOverlay"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Design your audio interface in the subclass."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Return an instance from your ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AudioDelegate","type":"reference"},{"text":" ","type":"text"},{"code":"playAudio","type":"codeVoice"},{"text":" method.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both feed and replica editions support overlays via separate delegate methods:"},{"type":"text","text":" "},{"code":"playAudio(for:inEdition:)","type":"codeVoice"},{"type":"text","text":" for feed editions and"},{"type":"text","text":" "},{"code":"playAudio(forSpread:inReplicaEdition:)","type":"codeVoice"},{"type":"text","text":" for replica editions."}]},{"level":3,"text":"Persistent Banner","type":"heading","anchor":"Persistent-Banner"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An alternative pattern where a compact audio control banner remains visible at"},{"type":"text","text":" "},{"type":"text","text":"the bottom of the reader as the user navigates between pages. This is useful"},{"type":"text","text":" "},{"type":"text","text":"when you want playback controls to persist across page navigation rather than"},{"type":"text","text":" "},{"type":"text","text":"appearing as a modal."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AudioBannerViewController"},{"type":"text","text":" and return it from"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AudioDelegate\/audioBannerViewController()"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["class MyAudioBanner: UIViewController, PSReaderUI.AudioBannerViewController {","","    var isFloating: Bool { true }","","    override func viewDidLoad() {","        super.viewDidLoad()","        \/\/ Build your compact audio control UI (play\/pause, progress, etc.)","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"isFloating","type":"codeVoice"},{"text":" property controls how the banner is positioned:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":"true","type":"codeVoice"}]},{"text":" — the banner floats above the reader content, pinned to the","type":"text"},{"text":" ","type":"text"},{"text":"bottom of the screen. The SDK automatically applies a bottom safe-area inset","type":"text"},{"text":" ","type":"text"},{"text":"equal to the banner’s height so content is not obscured.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"false"}],"type":"strong"},{"text":" — the banner is stacked below the reader. The reader’s available","type":"text"},{"text":" ","type":"text"},{"text":"height is reduced accordingly.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Banner visibility is driven by the view’s own layout. Set an intrinsic content","type":"text"},{"text":" ","type":"text"},{"text":"height (via Auto Layout constraints) to show the banner. Collapse the height to","type":"text"},{"text":" ","type":"text"},{"text":"zero to hide it. The SDK does not call show\/hide methods — it reads the","type":"text"},{"text":" ","type":"text"},{"text":"banner’s layout directly.","type":"text"}]},{"level":3,"text":"Choosing a Pattern","type":"heading","anchor":"Choosing-a-Pattern"},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Pattern"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Best for","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Default provider"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Transient overlay","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Most integrations — simple, no custom UI needed"}],"type":"paragraph"}],[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultTextToSpeechProvider","type":"reference"},{"text":" provides this out of the box","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Persistent banner"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Apps with their own audio system or “now playing” UI","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Requires a custom ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AudioDelegate"},{"text":" implementation","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Both","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Overlay for on-demand playback, banner for persistent controls"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Requires a custom ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AudioDelegate","type":"reference","isActive":true},{"text":" returning both","type":"text"}],"type":"paragraph"}]]],"type":"table"},{"level":2,"text":"Customizing the Overlay","type":"heading","anchor":"Customizing-the-Overlay"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AudioOverlayConfiguration"},{"type":"text","text":" struct controls the appearance of the"},{"type":"text","text":" "},{"type":"text","text":"default audio overlay. It inherits defaults from "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"text","text":"can be customized before passing to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultTextToSpeechProvider"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["var ttsConfig = PSReaderUI.AudioOverlayConfiguration(globalConfig: globalConfig)","","\/\/ Accent color for the play button and progress bar","ttsConfig.brandColor = .systemBlue","","\/\/ Overlay background","ttsConfig.backgroundColor = .secondarySystemBackground","","\/\/ Article title (defaults: primaryFont bold, 18pt)","ttsConfig.titleLabel = LabelConfiguration(","    font: .systemFont(ofSize: 18, weight: .bold),","    pointSize: 18,","    color: .label",")","","\/\/ Secondary info line (defaults: primaryFont, 14pt)","ttsConfig.subtitleLabel = LabelConfiguration(","    font: .systemFont(ofSize: 14),","    pointSize: 14,","    color: .secondaryLabel",")","","\/\/ Elapsed time display (defaults: primaryFont, 12pt)","ttsConfig.elapsedLabel = LabelConfiguration(","    font: .monospacedDigitSystemFont(ofSize: 12, weight: .regular),","    pointSize: 12,","    color: .tertiaryLabel",")","","\/\/ Remaining time display (defaults: primaryFont, 12pt)","ttsConfig.remainingLabel = LabelConfiguration(","    font: .monospacedDigitSystemFont(ofSize: 12, weight: .regular),","    pointSize: 12,","    color: .tertiaryLabel",")","","\/\/ Custom playback icons","ttsConfig.assetDelegate = MyAssetDelegate()","","\/\/ iOS 26+ Liquid Glass effect (defaults to global value)","ttsConfig.liquidGlassPolicy = .automatic","","let ttsProvider = PSReaderUI.DefaultTextToSpeechProvider(configuration: ttsConfig)","globalConfig.audioDelegate = ttsProvider"]},{"level":2,"text":"Handling Page Navigation","type":"heading","anchor":"Handling-Page-Navigation"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AudioDelegate","type":"reference"},{"text":" protocol includes methods that the SDK calls when the","type":"text"},{"text":" ","type":"text"},{"text":"user navigates to a different page or spread:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"didChangeTo(page:inEdition:inPublished:)","type":"codeVoice"},{"type":"text","text":" — called for feed edition"},{"type":"text","text":" "},{"type":"text","text":"navigation."}]}]},{"content":[{"inlineContent":[{"code":"didChangeTo(spread:inReplicaEdition:)","type":"codeVoice"},{"text":" — called for replica edition","type":"text"},{"text":" ","type":"text"},{"text":"navigation.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultTextToSpeechProvider"},{"text":" uses these methods to automatically stop","type":"text"},{"text":" ","type":"text"},{"text":"playback when the user navigates away from the article that is currently","type":"text"},{"text":" ","type":"text"},{"text":"playing. If the user navigates back to the same article, playback resumes from","type":"text"},{"text":" ","type":"text"},{"text":"where it left off.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If you implement a custom ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AudioDelegate"},{"text":", use these methods to pause or stop","type":"text"},{"text":" ","type":"text"},{"text":"your audio player, update banner state, or perform any cleanup needed when the","type":"text"},{"text":" ","type":"text"},{"text":"user moves between pages.","type":"text"}]},{"level":2,"text":"Audio Session Management","type":"heading","anchor":"Audio-Session-Management"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AudioSessionProvider","isActive":true,"type":"reference"},{"text":" protocol manages ","type":"text"},{"code":"AVAudioSession","type":"codeVoice"},{"text":" activation and","type":"text"},{"text":" ","type":"text"},{"text":"deactivation around playback. The default implementation","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultAudioSessionProvider","isActive":true,"type":"reference"},{"text":") configures the session for ","type":"text"},{"code":".playback","type":"codeVoice"},{"text":" ","type":"text"},{"text":"category, enabling background audio.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Override it if your app has specific audio session requirements — for example,","type":"text"},{"text":" ","type":"text"},{"text":"mixing with other audio sources or handling interruptions differently:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct MyAudioSessionProvider: PSReaderUI.AudioSessionProvider {","    func setupAudioSession(for article: PSEArticle, inEdition source: PSEEditionSource) throws {","        let session = AVAudioSession.sharedInstance()","        try session.setCategory(.playback, options: .mixWithOthers)","        try session.setActive(true)","    }","","    func deactivateAudioSession(for article: PSEArticle, inEdition source: PSEEditionSource) throws {","        try AVAudioSession.sharedInstance().setActive(false, options: .notifyOthersOnDeactivation)","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"The protocol also defines matching methods for replica editions","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"code":"setupAudioSession(for:inReplicaEdition:)","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"deactivateAudioSession(for:inReplicaEdition:)","type":"codeVoice"},{"text":") with default implementations","type":"text"},{"text":" ","type":"text"},{"text":"that delegate to the feed edition methods.","type":"text"}]},{"level":2,"text":"Custom AudioDelegate","type":"heading","anchor":"Custom-AudioDelegate"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For full control over the audio experience, implement "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AudioDelegate","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"directly. This is an advanced pattern for apps that manage their own audio"},{"type":"text","text":" "},{"type":"text","text":"system entirely — for example, using a persistent “now playing” banner with an"},{"type":"text","text":" "},{"type":"text","text":"external audio manager instead of the SDK’s built-in overlay."}]},{"type":"codeListing","syntax":"swift","code":["class MyAudioDelegate: PSReaderUI.AudioDelegate {","","    let audioManager: MyAudioManager","","    \/\/ MARK: Feed Edition Methods","","    func isListenable(page: PSEPage, inEdition source: PSEEditionSource) -> Bool {","        return page.articles?.count == 1","    }","","    func audioBannerViewController() -> AudioBannerViewController? {","        \/\/ Return a persistent banner, or nil for overlay-only","        return MyAudioBanner(audioManager: audioManager)","    }","","    func playAudio(for page: PSEPage, inEdition source: PSEEditionSource) -> AudioOverlay? {","        guard let article = page.articles?.first else { return nil }","","        \/\/ Start playback through your own audio manager","        audioManager.play(article: article)","","        \/\/ Return nil — the banner handles the UI","        return nil","    }","","    func didChangeTo(page: PSEPage?,","                     inEdition edition: PSEEdition,","                     inPublished published: PSEPublished) {","        audioManager.pause()","    }","","    \/\/ MARK: Replica Edition Methods","","    func isListenable(spread: PSReplicaPageSpread,","                      inReplicaEdition replicaEdition: PSReplicaEdition) -> Bool {","        return spread.isArticle","    }","","    func playAudio(forSpread spread: PSReplicaPageSpread,","                   inReplicaEdition replicaEdition: PSReplicaEdition) -> AudioOverlay? {","        guard case .article(let article) = spread else { return nil }","        audioManager.play(replicaArticle: article)","        return nil","    }","","    func didChangeTo(spread: PSReplicaPageSpread?,","                     inReplicaEdition replicaEdition: PSReplicaEdition) {","        audioManager.pause()","    }","}","","globalConfig.audioDelegate = MyAudioDelegate(audioManager: myAudioManager)"]},{"content":[{"type":"paragraph","inlineContent":[{"text":"If you return ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" from both ","type":"text"},{"code":"playAudio","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"audioBannerViewController()","type":"codeVoice"},{"text":", the SDK will not present any audio UI. Use this","type":"text"},{"text":" ","type":"text"},{"text":"when your app manages the entire audio experience externally.","type":"text"}]}],"name":"Tip","type":"aside","style":"tip"}]}],"abstract":[{"text":"Add audio playback of article content using the SDK’s text-to-speech system.","type":"text"}],"variants":[{"paths":["\/documentation\/psreaderui\/text-to-speech"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/psreaderui\/text-to-speech"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"article","metadata":{"modules":[{"name":"PSReaderUI"}],"title":"Text-to-Speech","roleHeading":"Article","role":"article"},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech"},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","do