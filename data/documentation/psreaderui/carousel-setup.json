{"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"PSReaderUI"}],"roleHeading":"Article","role":"article","title":"Carousel Setup"},"abstract":[{"text":"Configure the carousel’s sections, content sources, and layout.","type":"text"}],"variants":[{"paths":["\/documentation\/psreaderui\/carousel-setup"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/psreaderui\/carousel-setup"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"sections":[],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","isActive":true,"type":"reference"},{"text":" is the primary entry point for the PSReaderUI SDK.","type":"text"},{"text":" ","type":"text"},{"text":"It presents a tabbed interface with horizontal section ribbons at the top and","type":"text"},{"text":" ","type":"text"},{"text":"content grids below. Each section can display edition archives, bookmarks,","type":"text"},{"text":" ","type":"text"},{"text":"downloads, or kiosk grids.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sections are defined as an array of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController\/SectionItem"},{"type":"text","text":" "},{"type":"text","text":"values passed to the initializer. The SDK supports three kinds of section"},{"type":"text","text":" "},{"type":"text","text":"items: dynamic archives, single sections, and subsection groups."}]},{"level":2,"text":"Dynamic Archives (Recommended)","type":"heading","anchor":"Dynamic-Archives-Recommended"},{"type":"paragraph","inlineContent":[{"text":"The simplest way to populate the carousel is with a ","type":"text"},{"inlineContent":[{"type":"text","text":"shortcode"}],"type":"strong"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":".dynamicArchive","type":"codeVoice"},{"text":". The SDK fetches publication configuration from the","type":"text"},{"text":" ","type":"text"},{"text":"PageSuite backend and automatically creates the appropriate content sections:","type":"text"}]},{"syntax":"swift","code":["let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    sections: [","        .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\"),","        .subsections(\"My Content\", [","            .init(name: \"Bookmarks\", type: .bookmarks(type: .all)),","            .init(name: \"Downloads\", type: .downloads(type: .all))","        ])","    ]",")"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController\/refreshDynamicArchives(completion:)","isActive":true},{"type":"text","text":" at any"},{"type":"text","text":" "},{"type":"text","text":"time to re-fetch the remote configuration and update the carousel content."}]},{"level":2,"text":"Manual Sections","type":"heading","anchor":"Manual-Sections"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For full control, define sections explicitly using "},{"code":".section","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":".subsections","type":"codeVoice"},{"type":"text","text":":"}]},{"syntax":"swift","code":["let sections: [PSReaderUI.CarouselViewController.SectionItem] = [","    .section(.init(name: \"Latest\", type: .feedArchive(guid: \"APP_GUID\"))),","    .subsections(\"More\", [","        .init(name: \"Archive\", type: .replicaArchive(guid: \"PUB_GUID\")),","        .init(name: \"Bookmarks\", type: .bookmarks(type: .all)),","        .init(name: \"Downloads\", type: .downloads(type: .all))","    ])","]"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":".section"},{"text":" creates a top-level tab with a single content view. A","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":".subsections"},{"text":" creates a top-level tab with a secondary ribbon that lets","type":"text"},{"text":" ","type":"text"},{"text":"users switch between multiple content views.","type":"text"}]},{"anchor":"Content-Types","type":"heading","text":"Content Types","level":2},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController\/ContentType","isActive":true},{"type":"text","text":" enum defines all available content"},{"type":"text","text":" "},{"type":"text","text":"sources:"}],"type":"paragraph"},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Content Type"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".feedArchive(guid:)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Feed edition archive identified by an application GUID."}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".replicaArchive(guid:, supplements:)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Replica edition archive identified by a publication GUID. Pass an optional "},{"type":"codeVoice","code":"supplements"},{"type":"text","text":" array of publication GUIDs to include supplemental editions alongside the main archive."}]}]],[[{"type":"paragraph","inlineContent":[{"code":".feedPublicationKiosk(publications:)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Grid of multiple feed publications (kiosk layout). Each cell represents a different publication and tapping one opens its archive.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".replicaPublicationKiosk(publications:)"}]}],[{"type":"paragraph","inlineContent":[{"text":"Grid of multiple replica publications (kiosk layout). Same multi-publication grid for replica editions.","type":"text"}]}]],[[{"inlineContent":[{"code":".bookmarks(type:)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"User’s bookmarked pages and articles. Filter by type."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".downloads(type:)"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"User’s downloaded editions. Filter by type.","type":"text"}]}]]],"header":"row"},{"inlineContent":[{"type":"text","text":"See "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions","isActive":true,"type":"reference"},{"type":"text","text":" to determine whether your publications use"},{"type":"text","text":" "},{"type":"text","text":"feed or replica content types."}],"type":"paragraph"},{"anchor":"Per-Section-Configuration-Overrides","type":"heading","text":"Per-Section Configuration Overrides","level":2},{"inlineContent":[{"text":"Each content type accepts an optional configuration parameter. Use this to","type":"text"},{"text":" ","type":"text"},{"text":"override the global defaults for a specific section — for example, to use a","type":"text"},{"text":" ","type":"text"},{"text":"different date formatter or thumbnail aspect ratio:","type":"text"}],"type":"paragraph"},{"code":["var specialArchiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","specialArchiveConfig.aspectRatio = 0.75","specialArchiveConfig.thumbnailContentMode = .flexibleHeight(estimatedAspectRatio: 0.75)","",".section(.init(","    name: \"Special Edition\",","    type: .feedArchive(guid: \"GUID\", config: specialArchiveConfig)","))"],"syntax":"swift","type":"codeListing"},{"anchor":"Dismiss-Button-and-Safe-Area","type":"heading","text":"Dismiss Button and Safe Area","level":2},{"inlineContent":[{"type":"text","text":"When presenting the carousel modally, add a dismiss button:"}],"type":"paragraph"},{"code":["var carouselConfig = PSReaderUI.CarouselConfiguration(globalConfig: globalConfig)","carouselConfig.dismissButton = .dismissButton(position: .leading())"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Control which safe area edges the carousel ignores. This is useful when","type":"text"},{"text":" ","type":"text"},{"text":"embedding the carousel in a container that already provides its own safe","type":"text"},{"text":" ","type":"text"},{"text":"area handling:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["carouselConfig.ignoreSafeArea = .bottom"]},{"text":"Complete Example","anchor":"Complete-Example","level":2,"type":"heading"},{"inlineContent":[{"text":"A carousel combining a dynamic archive, a manual section with a per-section","type":"text"},{"text":" ","type":"text"},{"text":"configuration override, and a subsection group:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: apiKey,","    accountGUID: accountGUID",")","","\/\/ Per-section override for the premium archive","var premiumConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","premiumConfig.aspectRatio = 0.75","","let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    sections: [","        \/\/ Dynamic archive populated from a shortcode","        .dynamicArchive(\"Latest\", shortcode: \"SHORTCODE\"),","","        \/\/ Manual section with a per-section configuration","        .section(.init(","            name: \"Premium\",","            type: .replicaArchive(","                guid: \"PUB_GUID\",","                supplements: [\"SUPPLEMENT_PUB_GUID\"],","                config: premiumConfig","            )","        )),","","        \/\/ Subsection group for user content","        .subsections(\"My Content\", [","            .init(name: \"Bookmarks\", type: .bookmarks(type: .all)),","            .init(name: \"Downloads\", type: .downloads(type: .all))","        ])","    ]",")"]},{"text":"SwiftUI Integration","anchor":"SwiftUI-Integration","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Wrap "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","isActive":true},{"type":"text","text":" in a "},{"type":"codeVoice","code":"UIViewControllerRepresentable"},{"type":"text","text":" for use"},{"type":"text","text":" "},{"type":"text","text":"in SwiftUI:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import SwiftUI","import PSReaderUI","","struct ReaderView: UIViewControllerRepresentable {","    func makeUIViewController(context: Context) -> PSReaderUI.CarouselViewController {","        let globalConfig = PSReaderUI.GlobalConfiguration(","            apiKey: \"API_KEY\",","            accountGUID: \"ACCOUNT_GUID\"","        )","        return PSReaderUI.CarouselViewController(","            globalConfig: globalConfig,","            sections: [","                .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\")","            ]","        )","    }","","    func updateUIViewController(_ uiViewController: PSReaderUI.CarouselViewController, context: Context) {}","}"]}]}],"seeAlsoSections":[{"title":"Customization","anchor":"Customization","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Theming-and-Customization","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Standalone-View-Controllers","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Localization"],"generated":true}