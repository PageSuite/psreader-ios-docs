{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/carousel-setup"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/psreaderui\/carousel-setup"]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup"},"metadata":{"roleHeading":"Article","title":"Carousel Setup","role":"article","modules":[{"name":"PSReaderUI"}]},"abstract":[{"text":"Configure the carousel’s sections, content sources, and layout.","type":"text"}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Theming-and-Customization","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Standalone-View-Controllers","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Localization"],"title":"Customization","anchor":"Customization"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"kind":"article","primaryContentSections":[{"content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","isActive":true},{"type":"text","text":" is the primary entry point for the PSReaderUI SDK."},{"type":"text","text":" "},{"type":"text","text":"It presents a tabbed interface with horizontal section ribbons at the top and"},{"type":"text","text":" "},{"type":"text","text":"content grids below. Each section can display edition archives, bookmarks,"},{"type":"text","text":" "},{"type":"text","text":"downloads, or kiosk grids."}]},{"type":"paragraph","inlineContent":[{"text":"Sections are defined as an array of ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController\/SectionItem","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"values passed to the initializer. The SDK supports three kinds of section","type":"text"},{"text":" ","type":"text"},{"text":"items: dynamic archives, single sections, and subsection groups.","type":"text"}]},{"text":"Dynamic Archives (Recommended)","type":"heading","anchor":"Dynamic-Archives-Recommended","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The simplest way to populate the carousel is with a "},{"inlineContent":[{"text":"shortcode","type":"text"}],"type":"strong"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":".dynamicArchive","type":"codeVoice"},{"type":"text","text":". The SDK fetches publication configuration from the"},{"type":"text","text":" "},{"type":"text","text":"PageSuite backend and automatically creates the appropriate content sections:"}]},{"code":["let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    sections: [","        .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\"),","        .subsections(\"My Content\", [","            .init(name: \"Bookmarks\", type: .bookmarks(type: .all)),","            .init(name: \"Downloads\", type: .downloads(type: .all))","        ])","    ]",")"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController\/refreshDynamicArchives(completion:)"},{"type":"text","text":" at any"},{"type":"text","text":" "},{"type":"text","text":"time to re-fetch the remote configuration and update the carousel content."}]},{"text":"Manual Sections","type":"heading","anchor":"Manual-Sections","level":2},{"type":"paragraph","inlineContent":[{"text":"For full control, define sections explicitly using ","type":"text"},{"type":"codeVoice","code":".section"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":".subsections"},{"text":":","type":"text"}]},{"code":["let sections: [PSReaderUI.CarouselViewController.SectionItem] = [","    .section(.init(name: \"Latest\", type: .feedArchive(guid: \"APP_GUID\"))),","    .subsections(\"More\", [","        .init(name: \"Archive\", type: .replicaArchive(guid: \"PUB_GUID\")),","        .init(name: \"Bookmarks\", type: .bookmarks(type: .all)),","        .init(name: \"Downloads\", type: .downloads(type: .all))","    ])","]"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":".section"},{"type":"text","text":" creates a top-level tab with a single content view. A"},{"type":"text","text":" "},{"type":"codeVoice","code":".subsections"},{"type":"text","text":" creates a top-level tab with a secondary ribbon that lets"},{"type":"text","text":" "},{"type":"text","text":"users switch between multiple content views."}]},{"text":"Content Types","anchor":"Content-Types","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController\/ContentType","type":"reference","isActive":true},{"type":"text","text":" enum defines all available content"},{"type":"text","text":" "},{"type":"text","text":"sources:"}]},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Content Type","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".feedArchive(guid:)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Feed edition archive identified by an application GUID."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".replicaArchive(guid:, supplements:)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Replica edition archive identified by a publication GUID. Pass an optional ","type":"text"},{"code":"supplements","type":"codeVoice"},{"text":" array of publication GUIDs to include supplemental editions alongside the main archive.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".feedPublicationKiosk(publications:)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Grid of multiple feed publications (kiosk layout). Each cell represents a different publication and tapping one opens its archive."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".replicaPublicationKiosk(publications:)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Grid of multiple replica publications (kiosk layout). Same multi-publication grid for replica editions."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".bookmarks(type:)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"User’s bookmarked pages and articles. Filter by type.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".downloads(type:)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"User’s downloaded editions. Filter by type."}],"type":"paragraph"}]]]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions"},{"type":"text","text":" to determine whether your publications use"},{"type":"text","text":" "},{"type":"text","text":"feed or replica content types."}]},{"text":"Per-Section Configuration Overrides","anchor":"Per-Section-Configuration-Overrides","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Each content type accepts an optional configuration parameter. Use this to","type":"text"},{"text":" ","type":"text"},{"text":"override the global defaults for a specific section — for example, to use a","type":"text"},{"text":" ","type":"text"},{"text":"different date formatter or thumbnail aspect ratio:","type":"text"}]},{"code":["var specialArchiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","specialArchiveConfig.aspectRatio = 0.75","specialArchiveConfig.thumbnailContentMode = .flexibleHeight(estimatedAspectRatio: 0.75)","",".section(.init(","    name: \"Special Edition\",","    type: .feedArchive(guid: \"GUID\", config: specialArchiveConfig)","))"],"type":"codeListing","syntax":"swift"},{"text":"Dismiss Button and Safe Area","anchor":"Dismiss-Button-and-Safe-Area","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"When presenting the carousel modally, add a dismiss button:"}]},{"code":["var carouselConfig = PSReaderUI.CarouselConfiguration(globalConfig: globalConfig)","carouselConfig.dismissButton = .dismissButton(position: .leading())"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Control which safe area edges the carousel ignores. This is useful when","type":"text"},{"text":" ","type":"text"},{"text":"embedding the carousel in a container that already provides its own safe","type":"text"},{"text":" ","type":"text"},{"text":"area handling:","type":"text"}]},{"code":["carouselConfig.ignoreSafeArea = .bottom"],"type":"codeListing","syntax":"swift"},{"text":"Complete Example","anchor":"Complete-Example","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"A carousel combining a dynamic archive, a manual section with a per-section","type":"text"},{"text":" ","type":"text"},{"text":"configuration override, and a subsection group:","type":"text"}]},{"code":["let globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: apiKey,","    accountGUID: accountGUID",")","","\/\/ Per-section override for the premium archive","var premiumConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","premiumConfig.aspectRatio = 0.75","","let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    sections: [","        \/\/ Dynamic archive populated from a shortcode","        .dynamicArchive(\"Latest\", shortcode: \"SHORTCODE\"),","","        \/\/ Manual section with a per-section configuration","        .section(.init(","            name: \"Premium\",","            type: .replicaArchive(","                guid: \"PUB_GUID\",","                supplements: [\"SUPPLEMENT_PUB_GUID\"],","                config: premiumConfig","            )","        )),","","        \/\/ Subsection group for user content","        .subsections(\"My Content\", [","            .init(name: \"Bookmarks\", type: .bookmarks(type: .all)),","            .init(name: \"Downloads\", type: .downloads(type: .all))","        ])","    ]",")"],"type":"codeListing","syntax":"swift"},{"text":"SwiftUI Integration","anchor":"SwiftUI-Integration","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Wrap "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","isActive":true},{"type":"text","text":" in a "},{"type":"codeVoice","code":"UIViewControllerRepresentable"},{"type":"text","text":" for use"},{"type":"text","text":" "},{"type":"text","text":"in SwiftUI:"}]},{"code":["import SwiftUI","import PSReaderUI","","struct ReaderView: UIViewControllerRepresentable {","    func makeUIViewController(context: Context) -> PSReaderUI.CarouselViewController {","        let globalConfig = PSReaderUI.GlobalConfiguration(","            apiKey: \"API_KEY\",","            accountGUID: \"ACCOUNT_GUID\"","        )","        return PSReaderUI.CarouselViewController(","            globalConfig: globalConfig,","            sections: [","                .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\")","            ]","        )","    }","","    func updateUIViewController(_ uiViewController: PSReaderUI.CarouselViewController, context: Context) {}","}"],"type":"codeListing","syntax":"swift"}],