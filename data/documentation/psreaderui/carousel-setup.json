{"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"modules":[{"name":"PSReaderUI"}],"roleHeading":"Article","title":"Carousel Setup","role":"article"},"abstract":[{"type":"text","text":"Configure the carousel’s sections, content sources, and layout."}],"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"kind":"article","primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","isActive":true},{"type":"text","text":" is the primary entry point for the PSReaderUI SDK."},{"type":"text","text":" "},{"type":"text","text":"It presents a tabbed interface with horizontal section ribbons at the top and"},{"type":"text","text":" "},{"type":"text","text":"content grids below. Each section can display edition archives, bookmarks,"},{"type":"text","text":" "},{"type":"text","text":"downloads, or kiosk grids."}]},{"type":"paragraph","inlineContent":[{"text":"Sections are defined as an array of ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController\/SectionItem","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"values passed to the initializer. The SDK supports three kinds of section","type":"text"},{"text":" ","type":"text"},{"text":"items: dynamic archives, single sections, and subsection groups.","type":"text"}]},{"type":"heading","level":2,"anchor":"Dynamic-Archives-Recommended","text":"Dynamic Archives (Recommended)"},{"type":"paragraph","inlineContent":[{"text":"The simplest way to populate the carousel is with a ","type":"text"},{"inlineContent":[{"type":"text","text":"shortcode"}],"type":"strong"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":".dynamicArchive","type":"codeVoice"},{"text":". The SDK fetches publication configuration from the","type":"text"},{"text":" ","type":"text"},{"text":"PageSuite backend and automatically creates the appropriate content sections:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    sections: [","        .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\"),","        .subsections(\"My Content\", [","            .init(name: \"Bookmarks\", type: .bookmarks(type: .all)),","            .init(name: \"Downloads\", type: .downloads(type: .all))","        ])","    ]",")"]},{"type":"paragraph","inlineContent":[{"text":"Call ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController\/refreshDynamicArchives(completion:)"},{"text":" at any","type":"text"},{"text":" ","type":"text"},{"text":"time to re-fetch the remote configuration and update the carousel content.","type":"text"}]},{"type":"heading","level":2,"anchor":"Manual-Sections","text":"Manual Sections"},{"type":"paragraph","inlineContent":[{"text":"For full control, define sections explicitly using ","type":"text"},{"type":"codeVoice","code":".section"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":".subsections"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let sections: [PSReaderUI.CarouselViewController.SectionItem] = [","    .section(.init(name: \"Latest\", type: .feedArchive(guid: \"APP_GUID\"))),","    .subsections(\"More\", [","        .init(name: \"Archive\", type: .replicaArchive(guid: \"PUB_GUID\")),","        .init(name: \"Bookmarks\", type: .bookmarks(type: .all)),","        .init(name: \"Downloads\", type: .downloads(type: .all))","    ])","]"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":".section"},{"type":"text","text":" creates a top-level tab with a single content view. A"},{"type":"text","text":" "},{"type":"codeVoice","code":".subsections"},{"type":"text","text":" creates a top-level tab with a secondary ribbon that lets"},{"type":"text","text":" "},{"type":"text","text":"users switch between multiple content views."}]},{"type":"heading","level":2,"anchor":"Content-Types","text":"Content Types"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController\/ContentType"},{"type":"text","text":" enum defines all available content"},{"type":"text","text":" "},{"type":"text","text":"sources:"}]},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Content Type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".feedArchive(guid:)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Feed edition archive identified by an application GUID."}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".replicaArchive(guid:, supplements:)"}]}],[{"type":"paragraph","inlineContent":[{"text":"Replica edition archive identified by a publication GUID. Pass an optional ","type":"text"},{"type":"codeVoice","code":"supplements"},{"text":" array of publication GUIDs to include supplemental editions alongside the main archive.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".feedPublicationKiosk(publications:)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Grid of multiple feed publications (kiosk layout). Each cell represents a different publication and tapping one opens its archive."}]}]],[[{"type":"paragraph","inlineContent":[{"code":".replicaPublicationKiosk(publications:)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Grid of multiple replica publications (kiosk layout). Same multi-publication grid for replica editions.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".bookmarks(type:)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"User’s bookmarked pages and articles. Filter by type."}]}]],[[{"type":"paragraph","inlineContent":[{"code":".downloads(type:)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"User’s downloaded editions. Filter by type.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".search(config:)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Full-text search across feed edition articles and pages. Requires a "},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchConfiguration","type":"reference"},{"type":"text","text":". See "},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Search","type":"reference"},{"type":"text","text":"."}]}]]]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions","type":"reference","isActive":true},{"type":"text","text":" to determine whether your publications use"},{"type":"text","text":" "},{"type":"text","text":"feed or replica content types."}]},{"type":"heading","level":2,"anchor":"Per-Section-Configuration-Overrides","text":"Per-Section Configuration Overrides"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each content type accepts an optional configuration parameter. Use this to"},{"type":"text","text":" "},{"type":"text","text":"override the global defaults for a specific section — for example, to use a"},{"type":"text","text":" "},{"type":"text","text":"different date formatter or thumbnail aspect ratio:"}]},{"type":"codeListing","syntax":"swift","code":["var specialArchiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","specialArchiveConfig.aspectRatio = 0.75","specialArchiveConfig.thumbnailContentMode = .flexibleHeight(estimatedAspectRatio: 0.75)","",".section(.init(","    name: \"Special Edition\",","    type: .feedArchive(guid: \"GUID\", config: specialArchiveConfig)","))"]},{"type":"heading","level":2,"anchor":"Dismiss-Button-and-Safe-Area","text":"Dismiss Button and Safe Area"},{"type":"paragraph","inlineContent":[{"text":"When presenting the carousel modally, add a dismiss button:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["var carouselConfig = PSReaderUI.CarouselConfiguration(globalConfig: globalConfig)","carouselConfig.dismissButton = .dismissButton(position: .leading())"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Control which safe area edges the carousel ignores. This is useful when"},{"type":"text","text":" "},{"type":"text","text":"embedding the carousel in a container that already provides its own safe"},{"type":"text","text":" "},{"type":"text","text":"area handling:"}]},{"type":"codeListing","syntax":"swift","code":["carouselConfig.ignoreSafeArea = .bottom"]},{"type":"heading","level":2,"anchor":"Complete-Example","text":"Complete Example"},{"type":"paragraph","inlineContent":[{"text":"A carousel combining a dynamic archive, a manual section with a per-section","type":"text"},{"text":" ","type":"text"},{"text":"configuration override, and a subsection group:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: apiKey,","    accountGUID: accountGUID",")","","\/\/ Per-section override for the premium archive","var premiumConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","premiumConfig.aspectRatio = 0.75","","let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    sections: [","        \/\/ Dynamic archive populated from a shortcode","        .dynamicArchive(\"Latest\", shortcode: \"SHORTCODE\"),","","        \/\/ Manual section with a per-section configuration","        .section(.init(","            name: \"Premium\",","            type: .replicaArchive(","                guid: \"PUB_GUID\",","                supplements: [\"SUPPLEMENT_PUB_GUID\"],","                config: premiumConfig","            )","        )),","","        \/\/ Subsection group for user content","        .subsections(\"My Content\", [","            .init(name: \"Bookmarks\", type: .bookmarks(type: .all)),","            .init(name: \"Downloads\", type: .downloads(type: .all))","        ])","    ]",")"]},{"type":"heading","level":2,"anchor":"SwiftUI-Integration","text":"SwiftUI Integration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Wrap "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","isActive":true},{"type":"text","text":" in a "},{"type":"codeVoice","code":"UIViewControllerRepresentable"},{"type":"text","text":" for use"},{"type":"text","text":" "},{"type":"text","text":"in SwiftUI:"}]},{"type":"codeListing","syntax":"swift","code":["import SwiftUI","import PSReaderUI","","struct ReaderView: UIViewControllerRepresentable {","    func makeUIViewController(context: Context) -> PSReaderUI.CarouselViewController {","        let globalConfig = PSReaderUI.GlobalConfiguration(","            apiKey: \"API_KEY\",","            accountGUID: \"ACCOUNT_GUID\"","        )","        return PSReaderUI.CarouselViewController(","            globalConfig: globalConfig,","            sections: [","                .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\")","            ]","        )","    }","","    func updateUIViewController(_ uiViewController: PSReaderUI.CarouselViewController, context: Context) {}","}"]}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/carousel-setup"]},{"traits":[{"interfaceLanguag