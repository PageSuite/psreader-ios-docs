{"variants":[{"paths":["\/documentation\/psreaderui\/carousel-setup"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/psreaderui\/carousel-setup"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"text":"Configure the carousel’s sections, content sources, and layout.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"metadata":{"roleHeading":"Article","title":"Carousel Setup","modules":[{"name":"PSReaderUI"}],"role":"article"},"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup"},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Theming-and-Customization","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Standalone-View-Controllers","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Localization"],"anchor":"Customization","title":"Customization"}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","isActive":true,"type":"reference"},{"text":" is the primary entry point for the PSReaderUI SDK.","type":"text"},{"text":" ","type":"text"},{"text":"It presents a tabbed interface with horizontal section ribbons at the top and","type":"text"},{"text":" ","type":"text"},{"text":"content grids below. Each section can display edition archives, bookmarks,","type":"text"},{"text":" ","type":"text"},{"text":"downloads, or kiosk grids.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Sections are defined as an array of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController\/SectionItem"},{"text":" ","type":"text"},{"text":"values passed to the initializer. The SDK supports three kinds of section","type":"text"},{"text":" ","type":"text"},{"text":"items: dynamic archives, single sections, and subsection groups.","type":"text"}]},{"level":2,"text":"Dynamic Archives (Recommended)","anchor":"Dynamic-Archives-Recommended","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The simplest way to populate the carousel is with a ","type":"text"},{"inlineContent":[{"type":"text","text":"shortcode"}],"type":"strong"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":".dynamicArchive"},{"text":". The SDK fetches publication configuration from the","type":"text"},{"text":" ","type":"text"},{"text":"PageSuite backend and automatically creates the appropriate content sections:","type":"text"}]},{"syntax":"swift","code":["let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    sections: [","        .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\"),","        .subsections(\"My Content\", [","            .init(name: \"Bookmarks\", type: .bookmarks(type: .all)),","            .init(name: \"Downloads\", type: .downloads(type: .all))","        ])","    ]",")"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Call ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController\/refreshDynamicArchives(completion:)","type":"reference","isActive":true},{"text":" at any","type":"text"},{"text":" ","type":"text"},{"text":"time to re-fetch the remote configuration and update the carousel content.","type":"text"}]},{"level":2,"text":"Manual Sections","anchor":"Manual-Sections","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For full control, define sections explicitly using "},{"type":"codeVoice","code":".section"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":".subsections"},{"type":"text","text":":"}]},{"syntax":"swift","code":["let sections: [PSReaderUI.CarouselViewController.SectionItem] = [","    .section(.init(name: \"Latest\", type: .feedArchive(guid: \"APP_GUID\"))),","    .subsections(\"More\", [","        .init(name: \"Archive\", type: .replicaArchive(guid: \"PUB_GUID\")),","        .init(name: \"Bookmarks\", type: .bookmarks(type: .all)),","        .init(name: \"Downloads\", type: .downloads(type: .all))","    ])","]"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"code":".section","type":"codeVoice"},{"type":"text","text":" creates a top-level tab with a single content view. A"},{"type":"text","text":" "},{"code":".subsections","type":"codeVoice"},{"type":"text","text":" creates a top-level tab with a secondary ribbon that lets"},{"type":"text","text":" "},{"type":"text","text":"users switch between multiple content views."}]},{"level":2,"type":"heading","text":"Content Types","anchor":"Content-Types"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController\/ContentType","isActive":true},{"text":" enum defines all available content","type":"text"},{"text":" ","type":"text"},{"text":"sources:","type":"text"}]},{"rows":[[[{"inlineContent":[{"text":"Content Type","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".feedArchive(guid:)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Feed edition archive identified by an application GUID."}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".replicaArchive(guid:, supplements:)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Replica edition archive identified by a publication GUID. Pass an optional ","type":