{"seeAlsoSections":[{"identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Deep-Linking","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Commenting","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Search"],"generated":true,"anchor":"Features","title":"Features"}],"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","interfaceLanguage":"swift"},"sections":[],"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"inlineContent":[{"text":"All analytics events are reported through the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel","type":"reference"},{"text":" singleton. To","type":"text"},{"text":" ","type":"text"},{"text":"begin receiving events, create a class that conforms to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventSubscriber","type":"reference"},{"text":" ","type":"text"},{"text":"and subscribe it to the shared channel:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import PSReaderUI","","class AnalyticsHandler: PSReaderUI.EventSubscriber {","    func analytics(event: PSReaderUI.EventChannel.AnalyticsEvent) {","        switch event {","        \/\/ handle events","        }","    }","}","","let subscriber = AnalyticsHandler()","PSReaderUI.EventChannel.shared.subscribe(subscriber)"]},{"style":"important","type":"aside","name":"Important","content":[{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel","isActive":true,"type":"reference"},{"text":" holds a ","type":"text"},{"inlineContent":[{"type":"text","text":"weak"}],"type":"strong"},{"text":" reference to each","type":"text"},{"text":" ","type":"text"},{"text":"subscriber. Maintain a strong reference to your subscriber (for example, as a","type":"text"},{"text":" ","type":"text"},{"text":"property on your app delegate or coordinator) to prevent it from being","type":"text"},{"text":" ","type":"text"},{"text":"deallocated. You do not need to explicitly unsubscribe.","type":"text"}],"type":"paragraph"}]},{"inlineContent":[{"type":"text","text":"Events are always delivered on the "},{"type":"strong","inlineContent":[{"type":"text","text":"main thread"}]},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Replica vs Feed Events","anchor":"Replica-vs-Feed-Events","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Which events the SDK fires depends on the backend system your publication uses."},{"type":"text","text":" "},{"type":"text","text":"Replica editions produce "},{"type":"codeVoice","code":"replica*"},{"type":"text","text":" events while feed editions produce"},{"type":"text","text":" "},{"type":"codeVoice","code":"feedEdition*"},{"type":"text","text":" events. Some events (such as carousel views and bookmark"},{"type":"text","text":" "},{"type":"text","text":"operations) apply to both systems."}],"type":"paragraph"},{"inlineContent":[{"text":"Consult the PageSuite portal or your account manager to determine which system","type":"text"},{"text":" ","type":"text"},{"text":"applies to your publications. See ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions","type":"reference","isActive":true},{"text":" for","type":"text"},{"text":" ","type":"text"},{"text":"background.","type":"text"}],"type":"paragraph"},{"text":"Event Categories","anchor":"Event-Categories","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/AnalyticsEvent"},{"type":"text","text":" enumeration defines every event the SDK"},{"type":"text","text":" "},{"type":"text","text":"reports. Below is a summary of the main categories. See the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/AnalyticsEvent"},{"type":"text","text":" symbol page for the complete list."}],"type":"paragraph"},{"text":"Carousel Events","anchor":"Carousel-Events","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Fired when a carousel section becomes visible, providing the section index,"},{"type":"text","text":" "},{"type":"text","text":"name, and content type through "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/CarouselEventContext"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Edition Lifecycle","anchor":"Edition-Lifecycle","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Events for edition launches, downloads, and deletions. For example,"},{"type":"text","text":" "},{"type":"codeVoice","code":"replicaLaunch"},{"type":"text","text":" fires when a user opens a replica edition, and"},{"type":"text","text":" "},{"type":"codeVoice","code":"feedEditionDownloaded"},{"type":"text","text":" fires when a feed edition finishes downloading."}],"type":"paragraph"},{"text":"Page View and Navigation","anchor":"Page-View-and-Navigation","type":"heading","level":3},{"inlineContent":[{"text":"Page view events fire as the user navigates through an edition. Replica","type":"text"},{"text":" ","type":"text"},{"text":"editions report ","type":"text"},{"type":"codeVoice","code":"replicaPageView"},{"text":" with page numbers; feed editions report","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"feedEditionArticleView"},{"text":", ","type":"text"},{"type":"codeVoice","code":"feedEditionSectionView"},{"text":", or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"feedEditionOtherPageView"},{"text":" depending on the page type.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The content browser also emits events when the user opens it or taps","type":"text"},{"text":" ","type":"text"},{"text":"navigation controls within it.","type":"text"}],"type":"paragraph"},{"text":"Bookmark Events","anchor":"Bookmark-Events","type":"heading","level":3},{"inlineContent":[{"text":"Bookmark and unbookmark events fire for both pages and articles. Each event","type":"text"},{"text":" ","type":"text"},{"text":"includes the bookmark object with edition and page metadata.","type":"text"}],"type":"paragraph"},{"text":"Share and Print Events","anchor":"Share-and-Print-Events","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Share and print actions are tracked separately for replica pages, replica"},{"type":"text","text":" "},{"type":"text","text":"articles, and feed edition pages. These fire when the user initiates the"},{"type":"text","text":" "},{"type":"text","text":"action from the navigation bar."}],"type":"paragraph"},{"text":"Search Events","anchor":"Search-Events","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Search events track user queries and result interactions. "},{"type":"codeVoice","code":"searchCompleted"},{"type":"text","text":" "},{"type":"text","text":"fires when a search query returns results (not on pagination), and"},{"type":"text","text":" "},{"type":"codeVoice","code":"searchResultTapped"},{"type":"text","text":" fires when a user taps a result. Both carry a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/SearchEventContext","isActive":true},{"type":"text","text":" with the query, search type filter, result"},{"type":"text","text":" "},{"type":"text","text":"count, and the publications that were searched."}],"type":"paragraph"},{"text":"Article-Specific Events","anchor":"Article-Specific-Events","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"In replica editions, additional events track article taps, article link taps,"},{"type":"text","text":" "},{"type":"text","text":"and text size changes. Each carries a "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/ReplicaArticleEventContext","isActive":true},{"type":"text","text":" "},{"type":"text","text":"with the edition and article details."}],"type":"paragraph"},{"text":"Context Objects","anchor":"Context-Objects","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Each event carries an associated context object that provides the relevant"},{"type":"text","text":" "},{"type":"text","text":"metadata. The five context types are:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/CarouselEventContext","type":"reference"},{"text":" — section index, name, and content","type":"text"},{"text":" ","type":"text"},{"text":"type. Use ","type":"text"},{"code":"sectionName","type":"codeVoice"},{"text":" to identify which tab the user is viewing and","type":"text"},{"text":" ","type":"text"},{"code":"contentType","type":"codeVoice"},{"text":" to distinguish between archive, bookmarks, and downloads.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/ReplicaEventContext","isActive":true},{"type":"text","text":" — edition, page number, and spread page"},{"type":"text","text":" "},{"type":"text","text":"numbers for double-page mode. The "},{"type":"codeVoice","code":"edition"},{"type":"text","text":" property gives you access to"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"PSEdition"},{"type":"text","text":" model, and "},{"type":"codeVoice","code":"pageNumber"},{"type":"text","text":" identifies the current page."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/ReplicaArticleEventContext","isActive":true},{"type":"text","text":" — edition and article. The"},{"type":"text","text":" "},{"type":"codeVoice","code":"article"},{"type":"text","text":" property contains the article headline, ID, and share link."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/FeedEditionEventContext","type":"reference","isActive":true},{"type":"text","text":" — published object, edition, and"},{"type":"text","text":" "},{"type":"text","text":"current page spread. The "},{"code":"published","type":"codeVoice"},{"type":"text","text":" property provides the "},{"code":"PSEPublished","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"model with edition metadata, and "},{"code":"edition","type":"codeVoice"},{"type":"text","text":" contains page-level details."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/SearchEventContext"},{"type":"text","text":" — query string, search type filter,"},{"type":"text","text":" "},{"type":"text","text":"total result count, and the publications that were searched. The"},{"type":"text","text":" "},{"code":"searchResultTapped","type":"codeVoice"},{"type":"text","text":" event also includes the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchResult"},{"type":"text","text":" that was"},{"type":"text","text":" "},{"type":"text","text":"tapped."}]}]}]},{"inlineContent":[{"type":"text","text":"See the symbol pages for each context type for the full list of properties."}],"type":"paragraph"},{"style":"tip","type":"aside","name":"Tip","content":[{"inlineContent":[{"type":"text","text":"Map SDK event names to your analytics provider’s conventions in one"},{"type":"text","text":" "},{"type":"text","text":"central place. A "},{"type":"codeVoice","code":"switch"},{"type":"text","text":" over "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/AnalyticsEvent"},{"type":"text","text":" with a"},{"type":"text","text":" "},{"type":"codeVoice","code":"default"},{"type":"text","text":" case ensures you gracefully handle new events added in future SDK"},{"type":"text","text":" "},{"type":"text","text":"versions without a compile error."}],"type":"paragraph"}]},{"text":"Example","anchor":"Example","type":"heading","level":2},{"inlineContent":[{"text":"A practical example mapping common events to an analytics provider:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class MyAnalyticsSubscriber: PSReaderUI.EventSubscriber {","    func analytics(event: PSReaderUI.EventChannel.AnalyticsEvent) {","        switch event {","        case .carouselView(let context):","            trackScreen(\"carousel_\\(context.sectionName)\")","","        case .replicaLaunch(let context):","            trackEvent(\"edition_open\", properties: [","                \"page\": context.pageNumber ?? 0","            ])","","        case .feedEditionLaunch(let published):","            trackEvent(\"edition_open\", properties: [","                \"edition\": published.guid","            ])","","        case .replicaPageView(let context):","            trackEvent(\"page_view\", properties: [","                \"page\": context.pageNumber ?? 0","            ])","","        case .feedEditionArticleView(let context):","            trackEvent(\"article_view\", properties: [","                \"edition\": context.edition?.guid ?? \"\"","            ])","","        case .replicaPageBookmark, .feedEditionPageBookmark,","             .feedEditionArticleBookmark, .replicaArticleBookmark:","            trackEvent(\"bookmark_added\")","","        case .replicaPageShare, .feedEditionShare:","            trackEvent(\"share\")","","        case .searchCompleted(let context):","            trackEvent(\"search\", properties: [","                \"query\": context.query,","                \"results\": context.totalCount","            ])","","        case .searchResultTapped(let result, _):","            trackEvent(\"search_result_tapped\", properties: [","                \"type\": result.type ?? \"\",","                \"headline\": result.headline ?? \"\"","            ])","","        default:","            break","        }","    }","","    private func trackEvent(_ name: String, properties: [String: Any] = [:]) {","        \/\/ Forward to your analytics provider","    }","","    private func trackScreen(_ name: String) {","        \/\/ Forward to your analytics provider","    }","}"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/analytics"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/psreaderui\/analytics"]}],"abstract":[{"text":"Track user interactions and content engagement across the PSReaderUI SDK.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"title":"Analytics","role":"article","modules":[{"name":"PSReaderUI"}],"roleHeading":"Article"},"kind":