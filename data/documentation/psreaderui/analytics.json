{"seeAlsoSections":[{"identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Deep-Linking","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Commenting","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Search"],"title":"Features","generated":true,"anchor":"Features"}],"abstract":[{"text":"Track user interactions and content engagement across the PSReaderUI SDK.","type":"text"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"type":"text","text":"All analytics events are reported through the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel"},{"type":"text","text":" singleton. To"},{"type":"text","text":" "},{"type":"text","text":"begin receiving events, create a class that conforms to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventSubscriber"},{"type":"text","text":" "},{"type":"text","text":"and subscribe it to the shared channel:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import PSReaderUI","","class AnalyticsHandler: PSReaderUI.EventSubscriber {","    func analytics(event: PSReaderUI.EventChannel.AnalyticsEvent) {","        switch event {","        \/\/ handle events","        }","    }","}","","let subscriber = AnalyticsHandler()","PSReaderUI.EventChannel.shared.subscribe(subscriber)"]},{"name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel"},{"type":"text","text":" holds a "},{"type":"strong","inlineContent":[{"text":"weak","type":"text"}]},{"type":"text","text":" reference to each"},{"type":"text","text":" "},{"type":"text","text":"subscriber. Maintain a strong reference to your subscriber (for example, as a"},{"type":"text","text":" "},{"type":"text","text":"property on your app delegate or coordinator) to prevent it from being"},{"type":"text","text":" "},{"type":"text","text":"deallocated. You do not need to explicitly unsubscribe."}]}],"type":"aside","style":"important"},{"inlineContent":[{"text":"Events are always delivered on the ","type":"text"},{"inlineContent":[{"text":"main thread","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Replica-vs-Feed-Events","type":"heading","level":2,"text":"Replica vs Feed Events"},{"inlineContent":[{"type":"text","text":"Which events the SDK fires depends on the backend system your publication uses."},{"type":"text","text":" "},{"type":"text","text":"Replica editions produce "},{"type":"codeVoice","code":"replica*"},{"type":"text","text":" events while feed editions produce"},{"type":"text","text":" "},{"type":"codeVoice","code":"feedEdition*"},{"type":"text","text":" events. Some events (such as carousel views and bookmark"},{"type":"text","text":" "},{"type":"text","text":"operations) apply to both systems."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Consult the PageSuite portal or your account manager to determine which system"},{"type":"text","text":" "},{"type":"text","text":"applies to your publications. See "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions"},{"type":"text","text":" for"},{"type":"text","text":" "},{"type":"text","text":"background."}],"type":"paragraph"},{"anchor":"Event-Categories","type":"heading","level":2,"text":"Event Categories"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/AnalyticsEvent","isActive":true},{"type":"text","text":" enumeration defines every event the SDK"},{"type":"text","text":" "},{"type":"text","text":"reports. Below is a summary of the main categories. See the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/AnalyticsEvent","isActive":true},{"type":"text","text":" symbol page for the complete list."}],"type":"paragraph"},{"anchor":"Carousel-Events","type":"heading","level":3,"text":"Carousel Events"},{"inlineContent":[{"type":"text","text":"Fired when a carousel section becomes visible, providing the section index,"},{"type":"text","text":" "},{"type":"text","text":"name, and content type through "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/CarouselEventContext","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Edition-Lifecycle","type":"heading","level":3,"text":"Edition Lifecycle"},{"inlineContent":[{"type":"text","text":"Events for edition launches, downloads, and deletions. For example,"},{"type":"text","text":" "},{"type":"codeVoice","code":"replicaLaunch"},{"type":"text","text":" fires when a user opens a replica edition, and"},{"type":"text","text":" "},{"type":"codeVoice","code":"feedEditionDownloaded"},{"type":"text","text":" fires when a feed edition finishes downloading."}],"type":"paragraph"},{"anchor":"Page-View-and-Navigation","type":"heading","level":3,"text":"Page View and Navigation"},{"inlineContent":[{"type":"text","text":"Page view events fire as the user navigates through an edition. Replica"},{"type":"text","text":" "},{"type":"text","text":"editions report "},{"type":"codeVoice","code":"replicaPageView"},{"type":"text","text":" with page numbers; feed editions report"},{"type":"text","text":" "},{"type":"codeVoice","code":"feedEditionArticleView"},{"type":"text","text":", "},{"type":"codeVoice","code":"feedEditionSectionView"},{"type":"text","text":", or"},{"type":"text","text":" "},{"type":"codeVoice","code":"feedEditionOtherPageView"},{"type":"text","text":" depending on the page type."}],"type":"paragraph"},{"inlineContent":[{"text":"The content browser also emits events when the user opens it or taps","type":"text"},{"text":" ","type":"text"},{"text":"navigation controls within it.","type":"text"}],"type":"paragraph"},{"anchor":"Bookmark-Events","type":"heading","level":3,"text":"Bookmark Events"},{"inlineContent":[{"text":"Bookmark and unbookmark events fire for both pages and articles. Each event","type":"text"},{"text":" ","type":"text"},{"text":"includes the bookmark object with edition and page metadata.","type":"text"}],"type":"paragraph"},{"anchor":"Share-and-Print-Events","type":"heading","level":3,"text":"Share and Print Events"},{"inlineContent":[{"type":"text","text":"Share and print actions are tracked separately for replica pages, replica"},{"type":"text","text":" "},{"type":"text","text":"articles, and feed edition pages. These fire when the user initiates the"},{"type":"text","text":" "},{"type":"text","text":"action from the navigation bar."}],"type":"paragraph"},{"anchor":"Search-Events","type":"heading","level":3,"text":"Search Events"},{"inlineContent":[{"text":"Search events track user queries and result interactions. ","type":"text"},{"type":"codeVoice","code":"searchCompleted"},{"text":" ","type":"text"},{"text":"fires when a search query returns results (not on pagination), and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"searchResultTapped"},{"text":" fires when a user taps a result. Both carry a","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/SearchEventContext","isActive":true},{"text":" with the query, search type filter, result","type":"text"},{"text":" ","type":"text"},{"text":"count, and the publications that were searched.","type":"text"}],"type":"paragraph"},{"anchor":"Article-Specific-Events","type":"heading","level":3,"text":"Article-Specific Events"},{"inlineContent":[{"text":"In replica editions, additional events track article taps, article link taps,","type":"text"},{"text":" ","type":"text"},{"text":"and text size changes. Each carries a ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/ReplicaArticleEventContext","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"with the edition and article details.","type":"text"}],"type":"paragraph"},{"anchor":"Context-Objects","type":"heading","level":2,"text":"Context Objects"},{"inlineContent":[{"type":"text","text":"Each event carries an associated context object that provides the relevant"},{"type":"text","text":" "},{"type":"text","text":"metadata. The five context types are:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/CarouselEventContext"},{"text":" — section index, name, and content","type":"text"},{"text":" ","type":"text"},{"text":"type. Use ","type":"text"},{"type":"codeVoice","code":"sectionName"},{"text":" to identify which tab the user is viewing and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"contentType"},{"text":" to distinguish between archive, bookmarks, and downloads.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/ReplicaEventContext"},{"text":" — edition, page number, and spread page","type":"text"},{"text":" ","type":"text"},{"text":"numbers for double-page mode. The ","type":"text"},{"code":"edition","type":"codeVoice"},{"text":" property gives you access to","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"PSEdition","type":"codeVoice"},{"text":" model, and ","type":"text"},{"code":"pageNumber","type":"codeVoice"},{"text":" identifies the current page.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/ReplicaArticleEventContext","isActive":true},{"type":"text","text":" — edition and article. The"},{"type":"text","text":" "},{"type":"codeVoice","code":"article"},{"type":"text","text":" property contains the article headline, ID, and share link."}]}]},{"content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/FeedEditionEventContext"},{"type":"text","text":" — published object, edition, and"},{"type":"text","text":" "},{"type":"text","text":"current page spread. The "},{"code":"published","type":"codeVoice"},{"type":"text","text":" property provides the "},{"code":"PSEPublished","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"model with edition metadata, and "},{"code":"edition","type":"codeVoice"},{"type":"text","text":" contains page-level details."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/SearchEventContext"},{"type":"text","text":" — query string, search type filter,"},{"type":"text","text":" "},{"type":"text","text":"total result count, and the publications that were searched. The"},{"type":"text","text":" "},{"type":"codeVoice","code":"searchResultTapped"},{"type":"text","text":" event also includes the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchResult"},{"type":"text","text":" that was"},{"type":"text","text":" "},{"type":"text","text":"tapped."}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"See the symbol pages for each context type for the full list of properties.","type":"text"}],"type":"paragraph"},{"name":"Tip","content":[{"inlineContent":[{"type":"text","text":"Map SDK event names to your analytics provider’s conventions in one"},{"type":"text","text":" "},{"type":"text","text":"central place. A "},{"type":"codeVoice","code":"switch"},{"type":"text","text":" over "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/AnalyticsEvent","type":"reference","isActive":true},{"type":"text","text":" with a"},{"type":"text","text":" "},{"type":"codeVoice","code":"default"},{"type":"text","text":" case ensures you gracefully handle new events added in future SDK"},{"type":"text","text":" "},{"type":"text","text":"versions without a compile error."}],"type":"paragraph"}],"type":"aside","style":"tip"},{"anchor":"Example","type":"heading","level":2,"text":"Example"},{"inlineContent":[{"type":"text","text":"A practical example mapping common events to an analytics provider:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class MyAnalyticsSubscriber: PSReaderUI.EventSubscriber {","    func analytics(event: PSReaderUI.EventChannel.AnalyticsEvent) {","        switch event {","        case .carouselView(let context):","            trackScreen(\"carousel_\\(context.sectionName)\")","","        case .replicaLaunch(let context):","            trackEvent(\"edition_open\", properties: [","                \"page\": context.pageNumber ?? 0","            ])","","        case .feedEditionLaunch(let published):","            trackEvent(\"edition_open\", properties: [","                \"edition\": published.guid","            ])","","        case .replicaPageView(let context):","            trackEvent(\"page_view\", properties: [","                \"page\": context.pageNumber ?? 0","            ])","","        case .feedEditionArticleView(let context):","            trackEvent(\"article_view\", properties: [","                \"edition\": context.edition?.guid ?? \"\"","            ])","","        case .replicaPageBookmark, .feedEditionPageBookmark,","             .feedEditionArticleBookmark, .replicaArticleBookmark:","            trackEvent(\"bookmark_added\")","","        case .replicaPageShare, .feedEditionShare:","            trackEvent(\"share\")","","        case .searchCompleted(let context):","            trackEvent(\"search\", properties: [","                \"query\": context.query,","                \"results\": context.totalCount","            ])","","        case .searchResultTapped(let result, _):","            trackEvent(\"search_result_tapped\", properties: [","                \"type\": result.type ?? \"\",","                \"headline\": result.headline ?? \"\"","            ])","","        default:","            break","        }","    }","","    private func trackEvent(_ name: String, properties: [String: Any] = [:]) {","        \/\/ Forward to your analytics provider","    }","","    private func trackScreen(_ name: String) {","        \/\/ Forward to your analytics provider","    }","}"]}]}],"variants":[{"paths":["\/documentation\/psreaderui\/analytics"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/psreaderui\/analytics"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"article","metadata":{"roleHeading":"Article","title":"Analytics","role":"article","modules":[{"name":"PSRea