{"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","interfaceLanguage":"swift"},"seeAlsoSections":[{"identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Deep-Linking","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Commenting","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Search"],"generated":true,"anchor":"Features","title":"Features"}],"abstract":[{"text":"Track user interactions and content engagement across the PSReaderUI SDK.","type":"text"}],"metadata":{"modules":[{"name":"PSReaderUI"}],"roleHeading":"Article","role":"article","title":"Analytics"},"sections":[],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"All analytics events are reported through the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel"},{"type":"text","text":" singleton. To"},{"type":"text","text":" "},{"type":"text","text":"begin receiving events, create a class that conforms to "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventSubscriber"},{"type":"text","text":" "},{"type":"text","text":"and subscribe it to the shared channel:"}],"type":"paragraph"},{"syntax":"swift","code":["import PSReaderUI","","class AnalyticsHandler: PSReaderUI.EventSubscriber {","    func analytics(event: PSReaderUI.EventChannel.AnalyticsEvent) {","        switch event {","        \/\/ handle events","        }","    }","}","","let subscriber = AnalyticsHandler()","PSReaderUI.EventChannel.shared.subscribe(subscriber)"],"type":"codeListing"},{"type":"aside","name":"Important","style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel","type":"reference"},{"type":"text","text":" holds a "},{"type":"strong","inlineContent":[{"text":"weak","type":"text"}]},{"type":"text","text":" reference to each"},{"type":"text","text":" "},{"type":"text","text":"subscriber. Maintain a strong reference to your subscriber (for example, as a"},{"type":"text","text":" "},{"type":"text","text":"property on your app delegate or coordinator) to prevent it from being"},{"type":"text","text":" "},{"type":"text","text":"deallocated. You do not need to explicitly unsubscribe."}]}]},{"inlineContent":[{"type":"text","text":"Events are always delivered on the "},{"type":"strong","inlineContent":[{"type":"text","text":"main thread"}]},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Replica vs Feed Events","level":2,"type":"heading","anchor":"Replica-vs-Feed-Events"},{"inlineContent":[{"text":"Which events the SDK fires depends on the backend system your publication uses.","type":"text"},{"text":" ","type":"text"},{"text":"Replica editions produce ","type":"text"},{"code":"replica*","type":"codeVoice"},{"text":" events while feed editions produce","type":"text"},{"text":" ","type":"text"},{"code":"feedEdition*","type":"codeVoice"},{"text":" events. Some events (such as carousel views and bookmark","type":"text"},{"text":" ","type":"text"},{"text":"operations) apply to both systems.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Consult the PageSuite portal or your account manager to determine which system","type":"text"},{"text":" ","type":"text"},{"text":"applies to your publications. See ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions","type":"reference"},{"text":" for","type":"text"},{"text":" ","type":"text"},{"text":"background.","type":"text"}],"type":"paragraph"},{"text":"Event Categories","level":2,"type":"heading","anchor":"Event-Categories"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/AnalyticsEvent","type":"reference","isActive":true},{"type":"text","text":" enumeration defines every event the SDK"},{"type":"text","text":" "},{"type":"text","text":"reports. Below is a summary of the main categories. See the"},{"type":"text","text":" "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/AnalyticsEvent","type":"reference","isActive":true},{"type":"text","text":" symbol page for the complete list."}],"type":"paragraph"},{"text":"Carousel Events","level":3,"type":"heading","anchor":"Carousel-Events"},{"inlineContent":[{"text":"Fired when a carousel section becomes visible, providing the section index,","type":"text"},{"text":" ","type":"text"},{"text":"name, and content type through ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/CarouselEventContext","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Edition Lifecycle","level":3,"type":"heading","anchor":"Edition-Lifecycle"},{"inlineContent":[{"type":"text","text":"Events for edition launches, downloads, and deletions. For example,"},{"type":"text","text":" "},{"code":"replicaLaunch","type":"codeVoice"},{"type":"text","text":" fires when a user opens a replica edition, and"},{"type":"text","text":" "},{"code":"feedEditionDownloaded","type":"codeVoice"},{"type":"text","text":" fires when a feed edition finishes downloading."}],"type":"paragraph"},{"text":"Page View and Navigation","level":3,"type":"heading","anchor":"Page-View-and-Navigation"},{"inlineContent":[{"text":"Page view events fire as the user navigates through an edition. Replica","type":"text"},{"text":" ","type":"text"},{"text":"editions report ","type":"text"},{"code":"replicaPageView","type":"codeVoice"},{"text":" with page numbers; feed editions report","type":"text"},{"text":" ","type":"text"},{"code":"feedEditionArticleView","type":"codeVoice"},{"text":", ","type":"text"},{"code":"feedEditionSectionView","type":"codeVoice"},{"text":", or","type":"text"},{"text":" ","type":"text"},{"code":"feedEditionOtherPageView","type":"codeVoice"},{"text":" depending on the page type.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The content browser also emits events when the user opens it or taps","type":"text"},{"text":" ","type":"text"},{"text":"navigation controls within it.","type":"text"}],"type":"paragraph"},{"text":"Bookmark Events","level":3,"type":"heading","anchor":"Bookmark-Events"},{"inlineContent":[{"type":"text","text":"Bookmark and unbookmark events fire for both pages and articles. Each event"},{"type":"text","text":" "},{"type":"text","text":"includes the bookmark object with edition and page metadata."}],"type":"paragraph"},{"text":"Share and Print Events","level":3,"type":"heading","anchor":"Share-and-Print-Events"},{"inlineContent":[{"text":"Share and print actions are tracked separately for replica pages, replica","type":"text"},{"text":" ","type":"text"},{"text":"articles, and feed edition pages. These fire when the user initiates the","type":"text"},{"text":" ","type":"text"},{"text":"action from the navigation bar.","type":"text"}],"type":"paragraph"},{"text":"Search Events","level":3,"type":"heading","anchor":"Search-Events"},{"inlineContent":[{"text":"Search events track user queries and result interactions. ","type":"text"},{"code":"searchCompleted","type":"codeVoice"},{"text":" ","type":"text"},{"text":"fires when a search query returns results (not on pagination), and","type":"text"},{"text":" ","type":"text"},{"code":"searchResultTapped","type":"codeVoice"},{"text":" fires when a user taps a result. Both carry a","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/SearchEventContext","isActive":true,"type":"reference"},{"text":" with the query, search type filter, result","type":"text"},{"text":" ","type":"text"},{"text":"count, and the publications that were searched.","type":"text"}],"type":"paragraph"},{"text":"Article-Specific Events","level":3,"type":"heading","anchor":"Article-Specific-Events"},{"inlineContent":[{"type":"text","text":"In replica editions, additional events track article taps, article link taps,"},{"type":"text","text":" "},{"type":"text","text":"and text size changes. Each carries a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/ReplicaArticleEventContext"},{"type":"text","text":" "},{"type":"text","text":"with the edition and article details."}],"type":"paragraph"},{"text":"Context Objects","level":2,"type":"heading","anchor":"Context-Objects"},{"inlineContent":[{"text":"Each event carries an associated context object that provides the relevant","type":"text"},{"text":" ","type":"text"},{"text":"metadata. The five context types are:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/CarouselEventContext","isActive":true},{"type":"text","text":" — section index, name, and content"},{"type":"text","text":" "},{"type":"text","text":"type. Use "},{"type":"codeVoice","code":"sectionName"},{"type":"text","text":" to identify which tab the user is viewing and"},{"type":"text","text":" "},{"type":"codeVoice","code":"contentType"},{"type":"text","text":" to distinguish between archive, bookmarks, and downloads."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/ReplicaEventContext"},{"text":" — edition, page number, and spread page","type":"text"},{"text":" ","type":"text"},{"text":"numbers for double-page mode. The ","type":"text"},{"code":"edition","type":"codeVoice"},{"text":" property gives you access to","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"PSEdition","type":"codeVoice"},{"text":" model, and ","type":"text"},{"code":"pageNumber","type":"codeVoice"},{"text":" identifies the current page.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/ReplicaArticleEventContext","isActive":true},{"type":"text","text":" — edition and article. The"},{"type":"text","text":" "},{"type":"codeVoice","code":"article"},{"type":"text","text":" property contains the article headline, ID, and share link."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/FeedEditionEventContext","type":"reference","isActive":true},{"type":"text","text":" — published object, edition, and"},{"type":"text","text":" "},{"type":"text","text":"current page spread. The "},{"code":"published","type":"codeVoice"},{"type":"text","text":" property provides the "},{"code":"PSEPublished","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"model with edition metadata, and "},{"code":"edition","type":"codeVoice"},{"type":"text","text":" contains page-level details."}]}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/SearchEventContext","type":"reference","isActive":true},{"type":"text","text":" — query string, search type filter,"},{"type":"text","text":" "},{"type":"text","text":"total result count, and the publications that were searched. The"},{"type":"text","text":" "},{"type":"codeVoice","code":"searchResultTapped"},{"type":"text","text":" event also includes the "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchResult","type":"reference","isActive":true},{"type":"text","text":" that was"},{"type":"text","text":" "},{"type":"text","text":"tapped."}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"See the symbol pages for each context type for the full list of properties."}],"type":"paragraph"},{"type":"aside","name":"Tip","style":"tip","content":[{"type":"paragraph","inlineContent":[{"text":"Map SDK event names to your analytics provider’s conventions in one","type":"text"},{"text":" ","type":"text"},{"text":"central place. A ","type":"text"},{"code":"switch","type":"codeVoice"},{"text":" over ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/AnalyticsEvent","type":"reference"},{"text":" with a","type":"text"},{"text":" ","type":"text"},{"code":"default","type":"codeVoice"},{"text":" case ensures you gracefully handle new events added in future SDK","type":"text"},{"text":" ","type":"text"},{"text":"versions without a compile error.","type":"text"}]}]},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"inlineContent":[{"type":"text","text":"A practical example mapping common events to an analytics provider:"}],"type":"paragraph"},{"syntax":"swift","code":["class MyAnalyticsSubscriber: PSReaderUI.EventSubscriber {","    func analytics(event: PSReaderUI.EventChannel.AnalyticsEvent) {","        switch event {","        case .carouselView(let context):","            trackScreen(\"carousel_\\(context.sectionName)\")","","        case .replicaLaunch(let context):","            trackEvent(\"edition_open\", properties: [","                \"page\": context.pageNumber ?? 0","            ])","","        case .feedEditionLaunch(let published):","            trackEvent(\"edition_open\", properties: [","                \"edition\": published.guid","            ])","","        case .replicaPageView(let context):","            trackEvent(\"page_view\", properties: [","                \"page\": context.pageNumber ?? 0","            ])","","        case .feedEditionArticleView(let context):","            trackEvent(\"article_view\", properties: [","                \"edition\": context.edition?.guid ?? \"\"","            ])","","        case .replicaPageBookmark, .feedEditionPageBookmark,","             .feedEditionArticleBookmark, .replicaArticleBookmark:","            trackEvent(\"bookmark_added\")","","        case .replicaPageShare, .feedEditionShare:","            trackEvent(\"share\")","","        case .searchCompleted(let context):","            trackEvent(\"search\", properties: [","                \"query\": context.query,","                \"results\": context.totalCount","            ])","","        case .searchResultTapped(let result, _):","            trackEvent(\"search_result_tapped\", properties: [","                \"type\": result.type ?? \"\",","                \"headline\": result.headline ?? \"\"","            ])","","        default:","            break","        }","    }","","    private func trackEvent(_ name: String, properties: [String: Any] = [:]) {","        \/\/ Forward to your analytics provider","    }","","    private func trackScreen(_ name: String) {","        \/\/ Forward to your analytics provider","    }","}"],"type":"codeListing"}]}],"kind":"article","hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/analytics"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/psreaderui\/anal