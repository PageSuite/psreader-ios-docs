{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"PSReaderUI"}],"title":"Analytics"},"seeAlsoSections":[{"identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback"],"generated":true,"title":"Features","anchor":"Features"}],"kind":"article","abstract":[{"text":"Track user interactions and content engagement across the PSReaderUI SDK.","type":"text"}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All analytics events are reported through the "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel","isActive":true},{"type":"text","text":" singleton. To"},{"type":"text","text":" "},{"type":"text","text":"begin receiving events, create a class that conforms to "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventSubscriber","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and subscribe it to the shared channel:"}]},{"type":"codeListing","syntax":"swift","code":["import PSReaderUI","","class AnalyticsHandler: PSReaderUI.EventSubscriber {","    func analytics(event: PSReaderUI.EventChannel.AnalyticsEvent) {","        switch event {","        \/\/ handle events","        }","    }","}","","let subscriber = AnalyticsHandler()","PSReaderUI.EventChannel.shared.subscribe(subscriber)"]},{"type":"aside","style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel","isActive":true},{"type":"text","text":" holds a "},{"type":"strong","inlineContent":[{"type":"text","text":"weak"}]},{"type":"text","text":" reference to each"},{"type":"text","text":" "},{"type":"text","text":"subscriber. Maintain a strong reference to your subscriber (for example, as a"},{"type":"text","text":" "},{"type":"text","text":"property on your app delegate or coordinator) to prevent it from being"},{"type":"text","text":" "},{"type":"text","text":"deallocated. You do not need to explicitly unsubscribe."}]}],"name":"Important"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Events are always delivered on the "},{"inlineContent":[{"type":"text","text":"main thread"}],"type":"strong"},{"type":"text","text":"."}]},{"type":"heading","level":2,"anchor":"Replica-vs-Feed-Events","text":"Replica vs Feed Events"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Which events the SDK fires depends on the backend system your publication uses."},{"type":"text","text":" "},{"type":"text","text":"Replica editions produce "},{"code":"replica*","type":"codeVoice"},{"type":"text","text":" events while feed editions produce"},{"type":"text","text":" "},{"code":"feedEdition*","type":"codeVoice"},{"type":"text","text":" events. Some events (such as carousel views and bookmark"},{"type":"text","text":" "},{"type":"text","text":"operations) apply to both systems."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Consult the PageSuite portal or your account manager to determine which system"},{"type":"text","text":" "},{"type":"text","text":"applies to your publications. See "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions","type":"reference","isActive":true},{"type":"text","text":" for"},{"type":"text","text":" "},{"type":"text","text":"background."}]},{"type":"heading","level":2,"anchor":"Event-Categories","text":"Event Categories"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/AnalyticsEvent"},{"text":" enumeration defines every event the SDK","type":"text"},{"text":" ","type":"text"},{"text":"reports. Below is a summary of the main categories. See the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/AnalyticsEvent"},{"text":" symbol page for the complete list.","type":"text"}]},{"type":"heading","level":3,"anchor":"Carousel-Events","text":"Carousel Events"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Fired when a carousel section becomes visible, providing the section index,"},{"type":"text","text":" "},{"type":"text","text":"name, and content type through "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/CarouselEventContext","isActive":true},{"type":"text","text":"."}]},{"type":"heading","level":3,"anchor":"Edition-Lifecycle","text":"Edition Lifecycle"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Events for edition launches, downloads, and deletions. For example,"},{"type":"text","text":" "},{"code":"replicaLaunch","type":"codeVoice"},{"type":"text","text":" fires when a user opens a replica edition, and"},{"type":"text","text":" "},{"code":"feedEditionDownloaded","type":"codeVoice"},{"type":"text","text":" fires when a feed edition finishes downloading."}]},{"type":"heading","level":3,"anchor":"Page-View-and-Navigation","text":"Page View and Navigation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Page view events fire as the user navigates through an edition. Replica"},{"type":"text","text":" "},{"type":"text","text":"editions report "},{"type":"codeVoice","code":"replicaPageView"},{"type":"text","text":" with page numbers; feed editions report"},{"type":"text","text":" "},{"type":"codeVoice","code":"feedEditionArticleView"},{"type":"text","text":", "},{"type":"codeVoice","code":"feedEditionSectionView"},{"type":"text","text":", or"},{"type":"text","text":" "},{"type":"codeVoice","code":"feedEditionOtherPageView"},{"type":"text","text":" depending on the page type."}]},{"type":"paragraph","inlineContent":[{"text":"The content browser also emits events when the user opens it or taps","type":"text"},{"text":" ","type":"text"},{"text":"navigation controls within it.","type":"text"}]},{"type":"heading","level":3,"anchor":"Bookmark-Events","text":"Bookmark Events"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Bookmark and unbookmark events fire for both pages and articles. Each event"},{"type":"text","text":" "},{"type":"text","text":"includes the bookmark object with edition and page metadata."}]},{"type":"heading","level":3,"anchor":"Share-and-Print-Events","text":"Share and Print Events"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Share and print actions are tracked separately for replica pages, replica"},{"type":"text","text":" "},{"type":"text","text":"articles, and feed edition pages. These fire when the user initiates the"},{"type":"text","text":" "},{"type":"text","text":"action from the navigation bar."}]},{"type":"heading","level":3,"anchor":"Article-Specific-Events","text":"Article-Specific Events"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In replica editions, additional events track article taps, article link taps,"},{"type":"text","text":" "},{"type":"text","text":"and text size changes. Each carries a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/ReplicaArticleEventContext"},{"type":"text","text":" "},{"type":"text","text":"with the edition and article details."}]},{"type":"heading","level":2,"anchor":"Context-Objects","text":"Context Objects"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each event carries an associated context object that provides the relevant"},{"type":"text","text":" "},{"type":"text","text":"metadata. The four context types are:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/CarouselEventContext"},{"type":"text","text":" — section index, name, and content"},{"type":"text","text":" "},{"type":"text","text":"type. Use "},{"type":"codeVoice","code":"sectionName"},{"type":"text","text":" to identify which tab the user is viewing and"},{"type":"text","text":" "},{"type":"codeVoice","code":"contentType"},{"type":"text","text":" to distinguish between archive, bookmarks, and downloads."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/ReplicaEventContext","isActive":true},{"type":"text","text":" — edition, page number, and spread page"},{"type":"text","text":" "},{"type":"text","text":"numbers for double-page mode. The "},{"code":"edition","type":"codeVoice"},{"type":"text","text":" property gives you access to"},{"type":"text","text":" "},{"type":"text","text":"the "},{"code":"PSEdition","type":"codeVoice"},{"type":"text","text":" model, and "},{"code":"pageNumber","type":"codeVoice"},{"type":"text","text":" identifies the current page."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/ReplicaArticleEventContext","isActive":true},{"type":"text","text":" — edition and article. The"},{"type":"text","text":" "},{"type":"codeVoice","code":"article"},{"type":"text","text":" property contains the article headline, ID, and share link."}]}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/FeedEditionEventContext","type":"reference","isActive":true},{"type":"text","text":" — published object, edition, and"},{"type":"text","text":" "},{"type":"text","text":"current page spread. The "},{"code":"published","type":"codeVoice"},{"type":"text","text":" property provides the "},{"code":"PSEPublished","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"model with edition metadata, and "},{"code":"edition","type":"codeVoice"},{"type":"text","text":" contains page-level details."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"See the symbol pages for each context type for the full list of properties.","type":"text"}]},{"type":"aside","style":"tip","content":[{"inlineContent":[{"type":"text","text":"Map SDK event names to your analytics provider’s conventions in one"},{"type":"text","text":" "},{"type":"text","text":"central place. A "},{"type":"codeVoice","code":"switch"},{"type":"text","text":" over "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EventChannel\/AnalyticsEvent"},{"type":"text","text":" with a"},{"type":"text","text":" "},{"type":"codeVoice","code":"default"},{"type":"text","text":" case ensures you gracefully handle new events added in future SDK"},{"type":"text","text":" "},{"type":"text","text":"versions without a compile error."}],"type":"paragraph"}],"name":"Tip"},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A practical example mapping common events to an analytics provider:"}]},{"type":"codeListing","syntax":"swift","code":["class MyAnalyticsSubscriber: PSReaderUI.EventSubscriber {","    func analytics(event: PSReaderUI.EventChannel.AnalyticsEvent) {","        switch event {","        case .carouselView(let context):","            trackScreen(\"carousel_\\(context.sectionName)\")","","        case .replicaLaunch(let context):","            trackEvent(\"edition_open\", properties: [","                \"page\": context.pageNumber ?? 0","            ])","","        case .feedEditionLaunch(let published):","            trackEvent(\"edition_open\", properties: [","                \"edition\": published.guid","            ])","","        case .replicaPageView(let context):","            trackEvent(\"page_view\", properties: [","                \"page\": context.pageNumber ?? 0","            ])","","        case .feedEditionArticleView(let context):","            trackEvent(\"article_view\", properties: [","                \"edition\": context.edition?.guid ?? \"\"","            ])","","        case .replicaPageBookmark, .feedEditionPageBookmark,","             .feedEditionArticleBookmark, .replicaArticleBookmark:","            trackEvent(\"bookmark_added\")","","        case .replicaPageShare, .feedEditionShare:","            trackEvent(\"share\")","","        default:","            break","        }","    }","","    private func trackEvent(_ name: String, properties: [String: Any] = [:]) {","        \/\/ Forward to your analytics provider","    }","","    private func trackScreen(_ name: String) {","        \/\/ Forward to your analytics provider","    }","}"]}],"kind":"content"}],"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/analytics"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/psreaderui\/analytics"]}],"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/EventChannel/CarouselEventContext":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CarouselEventContext","kind":"identifier"}],"identif