ntroller","type":"reference","isActive":true},{"type":"text","text":" in a "},{"type":"codeVoice","code":"UIViewControllerRepresentable"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"use it in a SwiftUI view hierarchy:"}],"type":"paragraph"},{"syntax":"swift","code":["import SwiftUI","import PSReaderUI","","struct ReaderView: UIViewControllerRepresentable {","    func makeUIViewController(context: Context) -> PSReaderUI.CarouselViewController {","        let globalConfig = PSReaderUI.GlobalConfiguration(","            apiKey: \"API_KEY\",","            accountGUID: \"ACCOUNT_GUID\"","        )","        return PSReaderUI.CarouselViewController(","            globalConfig: globalConfig,","            sections: [","                .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\")","            ]","        )","    }","","    func updateUIViewController(_ uiViewController: PSReaderUI.CarouselViewController, context: Context) {}","}"],"type":"codeListing"},{"text":"Using a Coordinator as a Delegate","anchor":"Using-a-Coordinator-as-a-Delegate","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"The SDK makes wide use of delegate protocols (see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"When embedding in SwiftUI, you can implement delegates on a "},{"type":"codeVoice","code":"Coordinator"},{"type":"text","text":" so their"},{"type":"text","text":" "},{"type":"text","text":"lifecycle is tied to the representable:"}],"type":"paragraph"},{"syntax":"swift","code":["struct ReaderView: UIViewControllerRepresentable {","    func makeCoordinator() -> Coordinator {","        Coordinator()","    }","","    func makeUIViewController(context: Context) -> PSReaderUI.CarouselViewController {","        let globalConfig = PSReaderUI.GlobalConfiguration(","        