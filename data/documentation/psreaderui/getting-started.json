n close it:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var carouselConfig = PSReaderUI.CarouselConfiguration(globalConfig: globalConfig)","carouselConfig.dismissButton = .dismissButton(position: .leading())","","let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    carouselConfig: carouselConfig,","    sections: [ \/* ... *\/ ]",")"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"If you are embedding the carousel inside your own "},{"type":"codeVoice","code":"UINavigationController"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"set "},{"type":"codeVoice","code":"embedInNavigationController"},{"type":"text","text":" to "},{"type":"codeVoice","code":"false"},{"type":"text","text":" on the carousel configuration"},{"type":"text","text":" "},{"type":"text","text":"to prevent the SDK from creating a second navigation controller, which would"},{"type":"text","text":" "},{"type":"text","text":"result in double navigation bars:"}],"type":"paragraph"},{"syntax":"swift","code":["carouselConfig.embedInNavigationController = false"],"type":"codeListing"},{"text":"App Store Compliance","anchor":"App-Store-Compliance","level":2,"type":"heading"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Export Compliance"}]}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The SDK does ","type":"text"},{"inlineContent":[{"text":"not","type":"text"}],"type":"strong"},{"text":" use any non-standard encryption and will not affect export controls.","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Privacy Compliance"}],"type":"strong"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"The SDK does "},{"type":"strong","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" collect any private information and will not affect