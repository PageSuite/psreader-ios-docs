{"seeAlsoSections":[{"title":"Essentials","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Demo-Project"],"generated":true,"anchor":"Essentials"}],"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"inlineContent":[{"text":"This guide walks you through installation, credentials, SDK initialization, and","type":"text"},{"text":" ","type":"text"},{"text":"launching your first reader experience. By the end you will have a working","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","isActive":true},{"text":" displaying your publication editions.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Installation","level":2,"text":"Installation"},{"inlineContent":[{"type":"text","text":"We support three installation methods for integrating the SDK into your iOS app:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Manual installation","type":"text"}],"type":"strong"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"CocoaPods"}],"type":"strong"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Swift Package Manager (SPM)"}],"type":"strong"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Access to our CocoaPods Specs repository and Swift Package repository is "},{"inlineContent":[{"type":"text","text":"private"}],"type":"strong"},{"type":"text","text":" and granted via SSH."},{"type":"text","text":" "},{"type":"text","text":"To request access, please generate an SSH key pair and send the public key to our team. We’ll provision access to the appropriate repositories."}],"type":"paragraph"},{"type":"thematicBreak"},{"type":"heading","anchor":"1-Manual-Installation","level":3,"text":"1. Manual Installation"},{"inlineContent":[{"text":"Manually install the provided ","type":"text"},{"code":"PSReaderUI.xcframework","type":"codeVoice"},{"text":" and its dependencies by dragging and dropping them into your Xcode project.","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"PSReaderUI.xcframework","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"PSReader.xcframework","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"PDFNet.xcframework","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Tools.xcframework"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Ensure the frameworks are set to "},{"inlineContent":[{"type":"text","text":"Embed and Sign"}],"type":"strong"},{"type":"text","text":" in your Xcode project settings."}],"type":"paragraph"},{"type":"thematicBreak"},{"type":"heading","anchor":"2-CocoaPods","level":3,"text":"2. CocoaPods"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Specs repository:"}]}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["git@bitbucket.org:pagesuite\/psreader-specs.git"]},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Note"}],"type":"strong"},{"type":"text","text":": The Apryse SDK integration is slightly non-standard. We recommend pinning it to version "},{"code":"11.6.0.85755","type":"codeVoice"},{"type":"text","text":", as this is the version we have tested internally."}]}],"name":"Note"},{"inlineContent":[{"text":"Example ","type":"text"},{"code":"Podfile","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"ruby","code":["source 'git@bitbucket.org:pagesuite\/psreader-specs.git'","","target 'YourAppTarget' do","  use_frameworks!","","  pod 'PDFTron', podspec: 'https:\/\/www.pdftron.com\/downloads\/ios\/cocoapods\/xcframeworks\/pdftron\/11.3.0.85075.podspec'","  pod 'PDFTronTools', podspec: 'https:\/\/www.pdftron.com\/downloads\/ios\/cocoapods\/xcframeworks\/pdftron-tools\/11.3.0.85075.podspec'","  pod 'PSReaderUI2'","end"]},{"type":"thematicBreak"},{"type":"heading","anchor":"3-Swift-Package-Manager","level":3,"text":"3. Swift Package Manager"},{"inlineContent":[{"inlineContent":[{"text":"Package URL:","type":"text"}],"type":"strong"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["git@bitbucket.org:pagesuite\/psreader-swift-package.git"]},{"inlineContent":[{"type":"text","text":"To integrate:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In Xcode, go to "},{"inlineContent":[{"type":"text","text":"File > Add Packages…"}],"type":"strong"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Enter the repository URL above.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Authenticate via SSH (make sure you have been granted access)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Select the desired version\/range and add the package to your target.","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Versioning","level":2,"text":"Versioning"},{"inlineContent":[{"type":"text","text":"Starting in 2026, the SDK uses a calendar-based versioning scheme to align"},{"type":"text","text":" "},{"type":"text","text":"with the rest of the PageSuite product line. Versions follow the format"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"year.month.patch","type":"text"}]},{"type":"text","text":" — for example, "},{"type":"codeVoice","code":"26.1.0"},{"type":"text","text":" is the first January 2026"},{"type":"text","text":" "},{"type":"text","text":"release."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This scheme does "},{"inlineContent":[{"text":"not","type":"text"}],"type":"strong"},{"type":"text","text":" follow semantic versioning. While we strive to"},{"type":"text","text":" "},{"type":"text","text":"maintain API stability, breaking changes may occur in any release without a"},{"type":"text","text":" "},{"type":"text","text":"major version bump. We recommend pinning to a specific version and reviewing"},{"type":"text","text":" "},{"type":"text","text":"the "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Change-Log","isActive":true,"type":"reference"},{"type":"text","text":" before upgrading."}],"type":"paragraph"},{"level":2,"text":"Credentials","anchor":"Credentials","type":"heading"},{"inlineContent":[{"text":"To use the PSReaderUI SDK you need the following credentials. Contact your","type":"text"},{"text":" ","type":"text"},{"text":"PageSuite account manager or check the PageSuite portal to obtain them.","type":"text"}],"type":"paragraph"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"text":"Credential","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"inlineContent":[{"type":"text","text":"API Key"}],"type":"strong"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Authenticates your app with the PageSuite backend."}]}]],[[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Account GUID","type":"text"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"text":"Identifies your account.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Shortcode"}]},{"type":"text","text":" (recommended)"}]}],[{"type":"paragraph","inlineContent":[{"text":"A short identifier that maps to your publication configuration. Use with ","type":"text"},{"type":"codeVoice","code":".dynamicArchive"},{"text":" to load content automatically.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Application GUID"}]}]}],[{"type":"paragraph","inlineContent":[{"text":"Identifies a specific feed edition publication.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Publication GUID","type":"text"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Identifies a specific replica publication."}]}]]]},{"style":"tip","name":"Tip","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"strong","inlineContent":[{"type":"text","text":"Shortcode is the recommended approach."}]},{"type":"text","text":" It lets the SDK fetch your"},{"type":"text","text":" "},{"type":"text","text":"publication configuration dynamically, so you don’t need to manage GUIDs"},{"type":"text","text":" "},{"type":"text","text":"yourself."}]}]},{"level":2,"text":"Initialize the SDK","anchor":"Initialize-the-SDK","type":"heading"},{"inlineContent":[{"type":"text","text":"The PSReader SDK must be globally initialized before it can be used. Call this"},{"type":"text","text":" "},{"type":"text","text":"method early in your app lifecycle to optimize reader launch speed. You only"},{"type":"text","text":" "},{"type":"text","text":"need to call this method once."}],"type":"paragraph"},{"inlineContent":[{"text":"The completion handler is only used to return a status flag. It is not required","type":"text"},{"text":" ","type":"text"},{"text":"and it is not necessary to wait for the completion handler before continuing.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This method will only fail if the API key is invalid."}],"type":"paragraph"},{"syntax":"swift","code":["import PSReaderUI","","PSReader.initialize(apiKey: apiKey, completion: { success in","    \/\/ Note: The completion handler may be called on any thread.","})"],"type":"codeListing"},{"level":2,"text":"Quick Start","anchor":"Quick-Start","type":"heading"},{"inlineContent":[{"text":"Create a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration"},{"text":" with your credentials and basic theming:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import PSReaderUI","","let globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: apiKey,","    accountGUID: accountGUID,","    primaryFont: .systemFont(ofSize: 12),","    secondaryFont: .systemFont(ofSize: 12),","    brandColor: UIColor(dynamicProvider: {","        $0.userInterfaceStyle == .dark ? .white : .black","    })",")"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The primary font is used for titles, headlines, and publication names. The"},{"type":"text","text":" "},{"type":"text","text":"secondary font covers the remaining UI. The brand color is used as an accent"},{"type":"text","text":" "},{"type":"text","text":"throughout the SDK."}],"type":"paragraph"},{"inlineContent":[{"text":"Then create a ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","isActive":true,"type":"reference"},{"text":" using a ","type":"text"},{"type":"strong","inlineContent":[{"text":"shortcode","type":"text"}]},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":".dynamicArchive"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    sections: [","        .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\"),","        .subsections(\"My Content\", [","            .init(name: \"Bookmarks\", type: .bookmarks(type: .all)),","            .init(name: \"Downloads\", type: .downloads(type: .all))","        ])","    ]",")"],"type":"codeListing"},{"inlineContent":[{"text":"You can now push, present, or embed the ","type":"text"},{"type":"codeVoice","code":"CarouselViewController"},{"text":" as needed.","type":"text"},{"text":" ","type":"text"},{"text":"See ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup","type":"reference"},{"text":" for more detail on sections, content types, and layout","type":"text"},{"text":" ","type":"text"},{"text":"options.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Manual Configuration","anchor":"Manual-Configuration","type":"heading"},{"inlineContent":[{"type":"text","text":"If you need to use explicit GUIDs instead of a shortcode, replace"},{"type":"text","text":" "},{"type":"codeVoice","code":".dynamicArchive"},{"type":"text","text":" with a "},{"type":"codeVoice","code":".section"},{"type":"text","text":" or "},{"type":"codeVoice","code":".subsections"},{"type":"text","text":" entry using the"},{"type":"text","text":" "},{"type":"text","text":"appropriate content type:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Feed edition archive with an application GUID",".section(.init(name: \"Editions\", type: .feedArchive(guid: \"APP_GUID\")))","","\/\/ Replica archive with a publication GUID",".section(.init(name: \"Editions\", type: .replicaArchive(guid: \"PUB_GUID\")))"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions"},{"type":"text","text":" to determine which content type matches"},{"type":"text","text":" "},{"type":"text","text":"your publication."}],"type":"paragraph"},{"level":2,"text":"Dark Mode","anchor":"Dark-Mode","type":"heading"},{"inlineContent":[{"text":"The SDK fully supports dark mode. To provide distinct light and dark brand","type":"text"},{"text":" ","type":"text"},{"text":"colors, use a dynamic ","type":"text"},{"code":"UIColor","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let brandColor = UIColor(dynamicProvider: {","    $0.userInterfaceStyle == .dark ? .white : .black","})"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Alternatively, define a color in your asset catalog so the system resolves it"},{"type":"text","text":" "},{"type":"text","text":"automatically."}],"type":"paragraph"},{"inlineContent":[{"text":"To force a specific appearance across the entire SDK, set","type":"text"},{"text":" ","type":"text"},{"code":"overrideUserInterfaceStyle","type":"codeVoice"},{"text":" on the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["carouselVC.overrideUserInterfaceStyle = .dark"],"type":"codeListing"},{"level":2,"text":"Embedding in SwiftUI","anchor":"Embedding-in-SwiftUI","type":"heading"},{"inlineContent":[{"text":"Wrap the ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","isActive":true},{"text":" in a ","type":"text"},{"type":"codeVoice","code":"UIViewControllerRepresentable"},{"text":" to","type":"text"},{"text":" ","type":"text"},{"text":"use it in a SwiftUI view hierarchy:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import SwiftUI","import PSReaderUI","","struct ReaderView: UIViewControllerRepresentable {","    func makeUIViewController(context: Context) -> PSReaderUI.CarouselViewController {","        let globalConfig = PSReaderUI.GlobalConfiguration(","            apiKey: \"API_KEY\",","            accountGUID: \"ACCOUNT_GUID\"","        )","        return PSReaderUI.CarouselViewController(","            globalConfig: globalConfig,","            sections: [","                .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\")","            ]","        )","    }","","    func updateUIViewController(_ uiViewController: PSReaderUI.CarouselViewController, context: Context) {}","}"],"type":"codeListing"},{"level":3,"text":"Using a Coordinator as a Delegate","anchor":"Using-a-Coordinator-as-a-Delegate","type":"heading"},{"inlineContent":[{"text":"The SDK makes wide use of delegate protocols (see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"When embedding in SwiftUI, you can implement delegates on a ","type":"text"},{"code":"Coordinator","type":"codeVoice"},{"text":" so their","type":"text"},{"text":" ","type":"text"},{"text":"lifecycle is tied to the representable:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct ReaderView: UIViewControllerRepresentable {","    func makeCoordinator() -> Coordinator {","        Coordinator()","    }","","    func makeUIViewController(context: Context) -> PSReaderUI.CarouselViewController {","        let globalConfig = PSReaderUI.GlobalConfiguration(","            apiKey: \"API_KEY\",","            accountGUID: \"ACCOUNT_GUID\",","            navigationDelegate: context.coordinator","        )","        return PSReaderUI.CarouselViewController(","            globalConfig: globalConfig,","            sections: [","                .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\")","            ]","        )","    }","","    func updateUIViewController(_ uiViewController: PSReaderUI.CarouselViewController, context: Context) {}","","    class Coordinator: NavigationDelegate {","        func willPresentReplicaReader() {","            \/\/ Track analytics, adjust UI state, etc.","        }","","        func willDismissReplicaReader() {","            \/\/ Restore UI state, etc.","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"The same approach works for any delegate — have ","type":"text"},{"type":"codeVoice","code":"Coordinator"},{"type":"text","text":" conform to"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallDelegate"},{"type":"text","text":", "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareDelegate"},{"type":"text","text":", or any combination you need and"},{"type":"text","text":" "},{"type":"text","text":"pass "},{"type":"codeVoice","code":"context.coordinator"},{"text":" to the corresponding ","type":"text"},{"code":"GlobalConfiguration","type":"codeVoice"},{"text":" ","type":"text"},{"text":"parameter.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Presenting Modally","anchor":"Presenting-Modally","type":"heading"},{"inlineContent":[{"text":"When presenting the ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","isActive":true,"type":"reference"},{"text":" modally, add a dismiss button","type":"text"},{"text":" ","type":"text"},{"text":"so users can close it:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var carouselConfig = PSReaderUI.CarouselConfiguration(globalConfig: globalConfig)","carouselConfig.dismissButton = .dismissButton(position: .leading())","","let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    carouselConfig: carouselConfig,","    sections: [ \/* ... *\/ ]",")"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"If you are embedding the carousel inside your own "},{"type":"codeVoice","code":"UINavigationController"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"set "},{"type":"codeVoice","code":"embedInNavigationController"},{"type":"text","text":" to "},{"type":"codeVoice","code":"false"},{"type":"text","text":" on the carousel configuration"},{"type":"text","text":" "},{"type":"text","text":"to prevent the SDK from creating a second navigation controller, which would"},{"type":"text","text":" "},{"type":"text","text":"result in double navigation bars:"}],"type":"paragraph"},{"syntax":"swift","code":["carouselConfig.embedInNavigationController = false"],"type":"codeListing"},{"level":2,"text":"App Store Compliance","anchor":"App-Store-Compliance","type":"heading"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Export Compliance"}]}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The SDK does ","type":"text"},{"inlineContent":[{"type":"text","text":"not"}],"type":"strong"},{"text":" use any non-standard encryption and will not affect export controls.","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Privacy Compliance","type":"text"}]}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"The SDK does "},{"type":"strong","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" collect any private information and will not affect privacy compliance."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Required Info.plist Keys","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"text":"The SDK uses the Apryse library to render PDFs, which is preferred over Core","type":"text"},{"text":" ","type":"text"},{"text":"Graphics for its closer adherence to PDF standards. Add the following keys to","type":"text"},{"text":" ","type":"text"},{"text":"your app’s ","type":"text"},{"inlineContent":[{"text":"Info.plist","type":"text"}],"type":"strong"},{"text":":","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For more information, see the Apryse documentation:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.apryse.com\/ios\/guides\/get-started\/integration?tab=spm"}],"type":"paragraph"},{"syntax":"xml","code":["<key>NSCameraUsageDescription<\/key>","<string>This will allow you to use the image from your camera.<\/string>","<key>NSPhotoLibraryAddUsageDescription<\/key>","<string>This will allow you to add images to your photo library.<\/string>","<key>NSPhotoLibraryUsageDescription<\/key>","<string>This will allow you to create signatures and annotations from images in your photo library.<\/string>","<key>NSBluetoothAlwaysUsageDescription<\/key>","<string>This will allow us to detect if an Apple Pencil is paired, enabling palm rejection and the ability to scroll with one finger while annotating.<\/string>","<key>NSBluetoothPeripheralUsageDescription<\/key>","<string>This will allow us detect if an Apple Pencil is paired, enabling palm rejection and the ability to scroll with one finger while annotating.<\/string>"],"type":"codeListing"}],"kind":"content"}],"kind":"article","abstract":[{"type":"text","text":"The PSReaderUI SDK provides a flexible, modern UI for integrating the PageSuite"},{"type":"text","text":" "},{"type":"text","text":"PSReader SDK into your application."}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/getting-started"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/psreaderui\/getting-started"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Getting-Started","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"PSReaderUI"}],"roleHeading":"Article","title":"Getting Started","role":"article"},"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/PaywallDelegate":{"url":"\/documentation\/psreaderui\/paywalldelegate","abstract":[{"text":"A del