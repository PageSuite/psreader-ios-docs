t":" "},{"type":"text","text":"and it is not necessary to wait for the completion handler before continuing."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method will only fail if the API key is invalid."}]},{"type":"codeListing","syntax":"swift","code":["import PSReaderUI","","PSReader.initialize(apiKey: apiKey, completion: { success in","    \/\/ Note: The completion handler may be called on any thread.","})"]},{"type":"heading","anchor":"Quick-Start","text":"Quick Start","level":2},{"type":"paragraph","inlineContent":[{"text":"Create a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration"},{"text":" with your credentials and basic theming:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import PSReaderUI","","let globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: apiKey,","    accountGUID: accountGUID,","    primaryFont: .systemFont(ofSize: 12),","    secondaryFont: .systemFont(ofSize: 12),","    brandColor: UIColor(dynamicProvider: {","        $0.userInterfaceStyle == .dark ? .white : .black","    })",")"]},{"type":"paragraph","inlineContent":[{"text":"The primary font is used for titles, headlines, and publication names. The","type":"text"},{"text":" ","type":"text"},{"text":"secondary font covers the remaining UI. The brand color is used as an accent","type":"text"},{"text":" ","type":"text"},{"text":"throughout the SDK.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then create a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController"},{"type":"text","text":" using a "},{"type":"strong","inlineContent":[{"type":"text","text":"shortcode"}]},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":".dynamicArchive"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swif