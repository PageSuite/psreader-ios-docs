on","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"inlineContent":[{"type":"text","text":"API Key"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Authenticates your app with the PageSuite backend."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Account GUID"}]}],"type":"paragraph"}],[{"inlineContent":[{"text":"Identifies your account.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Shortcode"}]},{"type":"text","text":" (recommended)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"A short identifier that maps to your publication configuration. Use with "},{"type":"codeVoice","code":".dynamicArchive"},{"type":"text","text":" to load content automatically."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Application GUID"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Identifies a specific feed edition publication."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Publication GUID"}]}],"type":"paragraph"}],[{"inlineContent":[{"text":"Identifies a specific replica publication.","type":"text"}],"type":"paragraph"}]]],"type":"table"},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"inlineContent":[{"type":"text","text":"Shortcode is the recommended approach."}],"type":"strong"},{"text":" It lets the SDK fetch your","type":"text"},{"text":" ","type":"text"},{"text":"publication configuration dynamically, so you don’t need to manage GUIDs","type":"text"},{"text":" ","type":"text"},{"text":"yourself.","type":"text"}]}],"style":"tip","name":"Tip","type":"aside"},{"text":"Initialize the SDK","anchor":"Initialize-the-SDK","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The PSReader SDK must be globally initialized before it can be used. Call this"},{"type":"text","text":" "},{"type":"text","text":"method early in your app lifecycle to optimize reader launch speed. You only"},{"type":"text","text":" "},{"type":"text","text":"need to call this method once."}],"type":"paragraph"},{"inlineContent":[{"text":"The completion handler is only used to return a status flag. It is not required","type":"text"},{"text":" ","type":"text"},{"text":"and it is not necessary to wait for the completion handler before continuing.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This method will only fail if the API key is invalid.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import PSReaderUI","","PSReader.initialize(apiKey: apiKey, completion: { success in","    \/\/ Note: The completion handler may be called on any thread.","})"],"type":"codeListing"},{"text":"Quick Start","anchor":"Quick-Start","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Create a "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","isActive":true},{"type":"text","text":" with your credentials and basic theming:"}],"type":"paragraph"},{"syntax":"swift","code":["import PSReaderUI","","let globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: apiKey,","    accountGUID: accountGUID,","    primaryFont: .systemFont(ofSize: 12),","    secondaryFont: .systemFont(ofSize: 12),","    brandColor: UIColor(dynamicProvider: {","        $0.userInterfaceStyle == .dark ? .white : .black","    })",")"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The primary font is used for titles, headlines, and publication names. The"},{"type":"text","text":" "},{"type":"text","text":"secondary font covers the remaining UI. The brand color is used as an accent"},{"type":"text","text":" "},{"type":"text","text":"throughout the SDK."}],"type":"paragraph"},{"inlineContent":[{"text":"Then create a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController"},{"text":" using a ","type":"text"},{"inlineContent":[{"text":"shortcode","type":"text"}],"type":"strong"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":".dynamicArchive","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    sections: [","        .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\"),","        .subsections(\"My Content\", [","            .init(name: \"Bookmarks\", type: .bookmarks(type: .all)),","            .init(name: \"Downloads\", type: .downloads(type: .all))","        ])","    ]",")"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"You can now push, present, or embed the "},{"type":"codeVoice","code":"CarouselViewController"},{"type":"text","text":" as needed."},{"type":"text","text":" "},{"type":"text","text":"See "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup","type":"reference","isActive":true},{"type":"text","text":" for more detail on sections, content types, and layout"},{"type":"text","text":" "},{"type":"text","text":"options."}],"type":"paragraph"},{"text":"Manual Configuration","anchor":"Manual-Configuration","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"If you need to use explicit GUIDs instead of a shortcode, replace"},{"type":"text","text":" "},{"type":"codeVoice","code":".dynamicArchive"},{"type":"text","text":" with a "},{"type":"codeVoice","code":".section"},{"type":"text","text":" or "},{"type":"codeVoice","code":".subsections"},{"type":"text","text":" entry using the"},{"type":"text","text":" "},{"type":"text","text":"appropriate content type:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Feed edition archive with an application GUID",".section(.init(name: 