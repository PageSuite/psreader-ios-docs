{"abstract":[{"type":"text","text":"Enable video and media playback within the reader."}],"sections":[],"kind":"article","primaryContentSections":[{"content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"The PSReaderUI SDK does "},{"inlineContent":[{"text":"not","type":"text"}],"type":"strong"},{"type":"text","text":" bundle a video player. To enable video"},{"type":"text","text":" "},{"type":"text","text":"playback for media embedded in editions, implement the "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/MediaDelegate","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"protocol and provide your own player view controller."}],"type":"paragraph"},{"level":2,"anchor":"Protocol-Methods","type":"heading","text":"Protocol Methods"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/MediaDelegate"},{"type":"text","text":" protocol defines two methods:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/MediaDelegate\/videoViewController(for:presentingFrom:)"},{"type":"text","text":" — returns a view"},{"type":"text","text":" "},{"type":"text","text":"controller for video playback, which the SDK embeds in its media gallery UI."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/MediaDelegate\/pdfMediaOverlay(for:in:superview:)","isActive":true},{"type":"text","text":" — returns a media"},{"type":"text","text":" "},{"type":"text","text":"overlay for embedded media objects within replica edition PDF pages."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Both methods return "},{"cod