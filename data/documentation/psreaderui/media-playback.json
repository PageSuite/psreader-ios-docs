{"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The PSReaderUI SDK does "},{"type":"strong","inlineContent":[{"type":"text","text":"not"}]},{"type":"text","text":" bundle a video player. To enable video"},{"type":"text","text":" "},{"type":"text","text":"playback for media embedded in editions, implement the "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/MediaDelegate","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"protocol and provide your own player view controller."}]},{"anchor":"Protocol-Methods","type":"heading","level":2,"text":"Protocol Methods"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/MediaDelegate","isActive":true},{"type":"text","text":" protocol defines two methods:"}]},{"items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/MediaDelegate\/videoViewController(for:presentingFrom:)"},{"type":"text","text":" — returns a view"},{"type":"text","text":" "},{"type":"text","text":"controller for video playback, which the SDK embeds in its media gallery UI."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/MediaDelegate\/pdfMediaOverlay(for:in:superview:)"},{"type":"text","text":" — returns a media"},{"type":"text","text":" "},{"type":"text","text":"overlay for embedded media objects within replica edition PDF pages."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both methods return "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" by default, meaning media is not played unless you"},{"type":"text","text":" "},{"type":"text","text":"provide an implementation."}]},{"anchor":"Example","type":"heading","level":2,"text":"Example"},{"type":"paragraph","inlineContent":[{"text":"A minimal implementation using ","type":"text"},{"code":"AVPlayerViewController","type":"codeVoice"},{"text":":","type":"text"}]},{"syntax":"swift","code":["import AVKit","import PSReaderUI","","struct MyMediaDelegate: PSReaderUI.MediaDelegate {","    func videoViewController(","        for video: PSEVideo,","        presentingFrom: UIViewController","    ) -> UIViewController? {","        guard let url = video.url else { return nil }","","        let player = AVPlayer(url: url)","        let playerVC = AVPlayerViewController()","        playerVC.player = player","        return playerVC","    }","}"],"type":"codeListing"},{"anchor":"PDF-Media-Overlay","type":"heading","level":3,"text":"PDF Media Overlay"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To handle media objects embedded directly in replica edition PDF pages (such as"},{"type":"text","text":" "},{"type":"text","text":"inline videos or interactive elements), implement "},{"type":"codeVoice","code":"pdfMediaOverlay"},{"type":"text","text":":"}]},{"syntax":"swift","code":["struct MyMediaDelegate: PSReaderUI.MediaDelegate {","    func videoViewController(","        for video: PSEVideo,","        presentingFrom: UIViewController","    ) -> UIViewController? {","        guard let url = video.url else { return nil }","","        let player = AVPlayer(url: url)","        let playerVC = AVPlayerViewController()","        playerVC.player = player","        return playerVC","    }","","    func pdfMediaOverlay(","        for mediaObject: PSEMediaObject,","        in page: PSEPage,","        superview: UIView","    ) -> PSEMediaOverlay? {","        \/\/ Return a media overlay for the embedded object, or nil to skip","        return nil","    }","}"],"type":"codeListing"},{"type":"aside","content":[{"inlineCo