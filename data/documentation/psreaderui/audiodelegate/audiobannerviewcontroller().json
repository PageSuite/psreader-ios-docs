,{"inlineContent":[{"type":"text","text":"This method should return a view controller that will be displayed as a persistent"},{"type":"text","text":" "},{"type":"text","text":"banner in the reading interface. The banner’s visibility is controlled by its"},{"type":"text","text":" "},{"type":"text","text":"intrinsic content size — return zero height to hide the banner."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Layout is determined by the returned controller’s "},{"type":"codeVoice","code":"isFloating"},{"type":"text","text":" property:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"true"},{"type":"text","text":", the banner floats above the reader content pinned to the bottom edge."},{"type":"text","text":" "},{"type":"text","text":"The SDK applies matching bottom insets to the content so it is not obscured."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"false"},{"type":"text","text":", the banner is stacked below the reader, reducing the reader’s"},{"type":"text","text":" "},{"type":"text","text":"available height."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"This approach is ideal for showing persistent audio controls that remain visible","type":"text"},{"text":" ","type":"text"},{"text":"as users navigate through content.","type":"text"}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/psreaderui\/audiodelegate\/audiobannerviewcontroller()"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AudioDelegate\/audioBannerViewController()","interfaceLanguage":"swift"},"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Text-to-Speech":{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentati