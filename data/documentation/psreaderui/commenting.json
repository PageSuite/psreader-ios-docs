{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"inlineContent":[{"text":"The PSReaderUI SDK provides a pluggable commenting architecture built around two","type":"text"},{"text":" ","type":"text"},{"text":"protocols:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CommentingService"}],"type":"strong"},{"text":" — a backend-agnostic data layer that fetches comment","type":"text"},{"text":" ","type":"text"},{"text":"counts and determines which articles support commenting.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CommentingDelegate","isActive":true,"type":"reference"}],"type":"strong"},{"text":" — extends ","type":"text"},{"code":"CommentingService","type":"codeVoice"},{"text":" with UI","type":"text"},{"text":" ","type":"text"},{"text":"responsibilities: providing a comment button, handling taps, and presenting","type":"text"},{"text":" ","type":"text"},{"text":"onboarding tooltips.","type":"text"}]}]}]},{"inlineContent":[{"text":"The SDK ships ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultCommentingProvider","type":"reference"},{"text":", an open class that wraps any","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CommentingService","type":"reference"},{"text":" and provides default UI components out of the box —","type":"text"},{"text":" ","type":"text"},{"text":"a pill-shaped comment button, comment-count caching, trending indicators in the","type":"text"},{"text":" ","type":"text"},{"text":"content browser, and one-time onboarding tooltips.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The commenting backend is pluggable. The SDK currently bundles","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CoralCommentingService"},{"text":" for ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/coralproject.net\/"},{"text":" ","type":"text"},{"text":"integration. You can connect any commenting backend by implementing","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CommentingService"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Quick-Start","level":2,"text":"Quick Start"},{"inlineContent":[{"type":"text","text":"Create a "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CommentingService","type":"reference","isActive":true},{"type":"text","text":" for your commenting backend, wrap it in a"},{"type":"text","text":" "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultCommentingProvider","type":"reference","isActive":true},{"type":"text","text":", and assign it to your "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","type":"reference","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The example below uses "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CoralCommentingService","type":"reference","isActive":true},{"type":"text","text":", but all"},{"type":"text","text":" "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CommentingService","type":"reference","isActive":true},{"type":"text","text":" implementations work the same way:"}],"type":"paragraph"},{"code":["\/\/ 1. Create a commenting service for your backend","let service = CoralCommentingService(domain: \"talk.yourpublication.com\")","","\/\/ 2. Wrap it in a provider that handles UI, caching, and tooltips","let provider = DefaultCommentingProvider(","    globalConfig: globalConfig,","    service: service,","    onCommentButtonTapped: { article, page, source, viewController in","        \/\/ Present your commenting UI — see \"The Callback\" below","    }",")","","\/\/ 3. Assign to your global configuration","globalConfig.commentingDelegate = provider"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"That’s it. The SDK will show a comment button at the bottom of eligible articles,","type":"text"},{"text":" ","type":"text"},{"text":"display comment counts in the content browser, and prefetch counts at edition","type":"text"},{"text":" ","type":"text"},{"text":"load time.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"The-Callback","level":2,"text":"The Callback"},{"inlineContent":[{"type":"text","text":"When a user taps the comment button — either the native button in the article"},{"type":"text","text":" "},{"type":"text","text":"footer or a template-based button in the article byline — the SDK invokes the"},{"type":"text","text":" "},{"type":"codeVoice","code":"onCommentButtonTapped"},{"type":"text","text":" closure with four parameters:"}],"type":"paragraph"},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Parameter"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"article"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"PSEArticle"}],"type":"paragraph"}],[{"inlineContent":[{"text":"The article the user wants to comment on.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"page"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"PSEPage"}],"type":"paragraph"}],[{"inlineContent":[{"text":"The page containing the article.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"source"}],"type":"paragraph"}],[{"inlineContent":[{"code":"PSEEditionSource","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The edition the article belongs to."}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"viewController","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"UIViewController","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The presenting view controller — use it to present your commenting UI."}],"type":"paragraph"}]]],"header":"row"},{"inlineContent":[{"text":"This is where you present your commenting interface. For Coral Talk, the article","type":"text"},{"text":" ","type":"text"},{"text":"carries metadata that you can use to identify the comment stream:","type":"text"}],"type":"paragraph"},{"code":["onCommentButtonTapped: { article, page, source, viewController in","    \/\/ Access Coral-specific metadata","    guard let coral = article.metadata?.coralCommenting else { return }","","    \/\/ coral.assetId     — the Coral asset ID for this article","    \/\/ coral.publicUrl   — the public URL associated with the comment stream","    \/\/ coral.enabled     — whether commenting is enabled","","    let commentVC = MyCoralViewController(assetId: coral.assetId)","    viewController.present(commentVC, animated: true)","}"],"type":"codeListing","syntax":"swift"},{"style":"tip","content":[{"type":"paragraph","inlineContent":[{"text":"Store the ","type":"text"},{"code":"page.pageguid","type":"codeVoice"},{"text":" and edition GUID alongside your comment data","type":"text"},{"text":" ","type":"text"},{"text":"if you need to deep link back to the article later (e.g., from a comment","type":"text"},{"text":" ","type":"text"},{"text":"history screen). See the next section.","type":"text"}]}],"type":"aside","name":"Tip"},{"type":"heading","anchor":"Deep-Linking-Back-to-Articles","level":2,"text":"Deep Linking Back to Articles"},{"inlineContent":[{"type":"text","text":"A client may need to navigate back to a specific article from outside the"},{"type":"text","text":" "},{"type":"text","text":"reader — for example, from a comment history view or a push notification about"},{"type":"text","text":" "},{"type":"text","text":"a reply. Use "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/FeedReaderViewController","isActive":true},{"type":"text","text":" with the shortcode initializer and"},{"type":"text","text":" "},{"type":"text","text":"pass the page GUID as the opening page:"}],"type":"paragraph"},{"code":["let reader = FeedReaderViewController(","    globalConfig: globalConfig,","    shortcode: \"SHORTCODE\",","    editionGUID: savedEditionGUID,","    openingPage: .page(guid: savedPageGUID)",")","","present(reader, animated: true)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"To make this work, persist the page GUID (","type":"text"},{"type":"codeVoice","code":"page.pageguid"},{"text":"), edition GUID, and","type":"text"},{"text":" ","type":"text"},{"text":"shortcode when the user opens a comment stream. These three values are","type":"text"},{"text":" ","type":"text"},{"text":"sufficient to reconstruct the deep link later.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"See "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Deep-Linking","type":"reference","isActive":true},{"type":"text","text":" for the full guide on opening editions and pages"},{"type":"text","text":" "},{"type":"text","text":"programmatically."}],"type":"paragraph"},{"type":"heading","anchor":"Custom-Commenting-Service","level":2,"text":"Custom Commenting Service"},{"inlineContent":[{"text":"To connect a non-Coral backend, implement ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CommentingService","isActive":true},{"text":". The protocol","type":"text"},{"text":" ","type":"text"},{"text":"has three required methods and one optional batch method:","type":"text"}],"type":"paragraph"},{"code":["class MyCommentingService: CommentingService {","","    func isCommentingEnabled(","        article: PSEArticle,","        inEdition source: PSEEditionSource","    ) -> Bool {","        \/\/ Return true for articles that support commenting","        return article.articleguid != nil","    }","","    func articleIdentifier(for article: PSEArticle) -> String? {","        \/\/ Return a stable ID used as the cache key and batch lookup key","        return article.articleguid","    }","","    func fetchCommentCount(","        forArticle article: PSEArticle,","        inEdition source: PSEEditionSource,","        completion: @escaping (Result<Int, Error>) -> Void","    ) {","        \/\/ Fetch the count from your backend","        MyAPI.fetchCount(for: article) { count in","            completion(.success(count))","        }","    }","","    \/\/ Optional — override for efficient batch fetching.","    \/\/ The default calls fetchCommentCount individually per article.","    func prefetchCommentCounts(","        forArticles articles: [PSEArticle],","        inEdition source: PSEEditionSource,","        completion: ((Result<[String: Int], Error>) -> Void)?","    ) {","        let ids = articles.compactMap { articleIdentifier(for: $0) }","        MyAPI.fetchCounts(for: ids) { results in","            completion?(.success(results))","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Pass your service into "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultCommentingProvider","isActive":true,"type":"reference"},{"type":"text","text":" to get all the default UI"},{"type":"text","text":" "},{"type":"text","text":"behavior — button, caching, tooltips, trending — without reimplementing any of"},{"type":"text","text":" "},{"type":"text","text":"it:"}],"type":"paragraph"},{"code":["let provider = DefaultCommentingProvider(","    globalConfig: globalConfig,","    service: MyCommentingService(),","    onCommentButtonTapped: { article, page, source, viewController in","        \/\/ Present your commenting UI","    }",")","","globalConfig.commentingDelegate = provider"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Customizing-the-Button","level":2,"text":"Customizing the Button"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultCommentingProvider"},{"text":" returns a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultCommentingButton"},{"text":" — a","type":"text"},{"text":" ","type":"text"},{"text":"pill-shaped button with a 1 px border and centered text label. To customize","type":"text"},{"text":" ","type":"text"},{"text":"its appearance, subclass ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultCommentingProvider"},{"text":" and override","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultCommentingProvider\/commentButton(forArticle:inEdition:onTap:)"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["class MyCommentingProvider: DefaultCommentingProvider {","    override func commentButton(","        forArticle article: PSEArticle,","        inEdition source: PSEEditionSource,","        onTap: @escaping () -> Void","    ) -> (any CommentingButtonView)? {","        let button = DefaultCommentingButton(","            text: \"Leave a comment\",","            foregroundColor: .systemBlue,","            font: .systemFont(ofSize: 16, weight: .semibold),","            pillTopPadding: 20,","            pillBottomPadding: 20,","            labelVerticalPadding: 14,","            labelHorizontalPadding: 40","        )","        button.onTap = onTap","        return button","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"For a completely custom button, implement ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CommentingButtonView","type":"reference","isActive":true},{"text":" on your own","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"UIView"},{"text":" subclass. Store the ","type":"text"},{"type":"codeVoice","code":"onTap"},{"text":" closure and call it when the user taps","type":"text"},{"text":" ","type":"text"},{"text":"the button. Implement ","type":"text"},{"type":"codeVoice","code":"updateText(_:)"},{"text":" so the SDK can update the label when","type":"text"},{"text":" ","type":"text"},{"text":"comment counts are fetched.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Trending-Threshold","level":2,"text":"Trending Threshold"},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultCommentingProvider\/trendingThreshold"},{"text":" controls when a trending icon","type":"text"},{"text":" ","type":"text"},{"text":"appears next to the comment count in the content browser. When an article’s","type":"text"},{"text":" ","type":"text"},{"text":"comment count meets or exceeds this value, the SDK displays a trending","type":"text"},{"text":" ","type":"text"},{"text":"indicator alongside the count.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The default threshold is "},{"code":"100","type":"codeVoice"},{"type":"text","text":". Pass a custom value to the initializer:"}],"type":"paragraph"},{"code":["let provider = DefaultCommentingProvider(","    globalConfig: globalConfig,","    service: service,","    trendingThreshold: 50,","    onCommentButtonTapped: { article, page, source, viewController in","        \/\/ ...","    }",")"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Tooltips","level":2,"text":"Tooltips"},{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultCommentingProvider","type":"reference"},{"text":" presents one-time onboarding tooltips to introduce","type":"text"},{"text":" ","type":"text"},{"text":"the commenting feature:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Article tooltip","type":"text"}]},{"text":" — a popover anchored above the comment button in the","type":"text"},{"text":" ","type":"text"},{"text":"article view.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Content browser tooltip"}]},{"text":" — a popover anchored below the first visible","type":"text"},{"text":" ","type":"text"},{"text":"commenting-enabled cell in the content browser.","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Each tooltip is shown once per app install. The provider tracks presentation"},{"type":"text","text":" "},{"type":"text","text":"state in "},{"type":"codeVoice","code":"UserDefaults"},{"type":"text","text":" and returns "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" on subsequent calls."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To customize tooltip text, use the "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LocalizationManager","type":"reference","isActive":true},{"type":"text","text":" system (see below)."},{"type":"text","text":" "},{"type":"text","text":"To customize tooltip appearance or behavior, subclass "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultCommentingProvider","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and override "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultCommentingProvider\/articleCommentTooltipViewController(inEdition:)","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"or "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultCommentingProvider\/contentBrowserCommentTooltipViewController(inEdition:)","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"type":"heading","anchor":"Localization","level":2,"text":"Localization"},{"inlineContent":[{"type":"text","text":"All commenting strings are resolved through the "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LocalizationManager","isActive":true},{"type":"text","text":" system."}],"type":"paragraph"},{"inlineContent":[{"text":"Override these using a String Catalog or by subclassing ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LocalizationManager","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"See ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Localization","isActive":true},{"text":" for the full localization guide.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Custom-Icons","level":2,"text":"Custom Icons"},{"inlineContent":[{"type":"text","text":"The content browser uses two images from the "},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AssetDelegate","type":"reference"},{"type":"text","text":" system for"},{"type":"text","text":" "},{"type":"text","text":"commenting indicators:"}],"type":"paragraph"},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Resource Name","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Usage"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".comment","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Comment count icon in content browser cells"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".trending","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Trending indicator shown when the count exceeds the threshold","type":"text"}]}]]],"header":"row"},{"inlineContent":[{"text":"Override these through a custom ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AssetDelegate"},{"text":" to match your app’s icon","type":"text"},{"text":" ","type":"text"},{"text":"style. See ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Theming-and-Customization"},{"text":" for details on asset customization.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Custom-CommentingDelegate","level":2,"text":"Custom CommentingDelegate"},{"inlineContent":[{"type":"text","text":"For full control over every aspect of the commenting experience, implement"},{"type":"text","text":" "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CommentingDelegate","type":"reference","isActive":true},{"type":"text","text":" directly. This is an advanced pattern — you take on"},{"type":"text","text":" "},{"type":"text","text":"responsibility for the data layer, button creation, tap handling, and tooltips:"}],"type":"paragraph"},{"code":["class MyCommentingDelegate: CommentingDelegate {","","    var trendingThreshold: Int { 50 }","","    \/\/ MARK: - CommentingService","","    func isCommentingEnabled(","        article: PSEArticle,","        inEdition source: PSEEditionSource","    ) -> Bool {","        return article.articleguid != nil","    }","","    func articleIdentifier(for article: PSEArticle) -> String? {","        return article.articleguid","    }","","    func fetchCommentCount(","        forArticle article: PSEArticle,","        inEdition source: PSEEditionSource,","        completion: @escaping (Result<Int, Error>) -> Void","    ) {","        \/\/ Fetch from your backend","    }","","    func prefetchCommentCounts(","        forArticles articles: [PSEArticle],","        inEdition source: PSEEditionSource,","        completion: ((Result<[String: Int], Error>) -> Void)?","    ) {","        \/\/ Batch fetch from your backend","    }","","    \/\/ MARK: - CommentingDelegate","","    func commentButton(","        forArticle article: PSEArticle,","        inEdition source: PSEEditionSource,","        onTap: @escaping () -> Void","    ) -> (any CommentingButtonView)? {","        \/\/ Return your custom button, or nil to suppress","        let button = MyCustomButton()","        button.onTap = onTap","        return button","    }","","    func commentButtonTapped(","        forArticle article: PSEArticle,","        onPage page: PSEPage,","        inEdition source: PSEEditionSource,","        from viewController: UIViewController","    ) {","        \/\/ Present your commenting UI","    }","}","","globalConfig.commentingDelegate = MyCommentingDelegate()"],"type":"codeListing","syntax":"swift"},{"style":"tip","content":[{"inlineContent":[{"type":"text","text":"In most cases, subclassing "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultCommentingProvider"},{"type":"text","text":" and overriding"},{"type":"text","text":" "},{"type":"text","text":"a single method is simpler than implementing "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CommentingDelegate"},{"type":"text","text":" from"},{"type":"text","text":" "},{"type":"text","text":"scratch. Only use the full protocol when you need to replace the caching,"},{"type":"text","text":" "},{"type":"text","text":"tooltip, or button logic entirely."}],"type":"paragraph"}],"type":"aside","name":"Tip"}]}],"variants":[{"paths":["\/documentation\/psreaderui\/commenting"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/psreaderui\/commenting"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Commenting"},"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"abstract":[{"type":"text","text":"Add comment counts, comment buttons, and commenting integration to the reader."}],"metadata":{"title":"Commenting","modules":[{"name":"PSReaderUI"}],"roleHeading":"Article","role":"article"},"seeAlsoSections":[{"generated":true,"anchor":"Features","title":"Features","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Deep-Linking","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Search"]}],"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/CommentingDelegate":{"navigatorTitle":[{"kind":"identifier","text":"CommentingDelegate"}],"kind":"symbol","url":"\/documentation\/psreaderui\/commentingdelegate","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSRe