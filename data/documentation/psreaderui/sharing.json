{"seeAlsoSections":[{"title":"Features","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics"],"generated":true,"anchor":"Features"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing"},"metadata":{"modules":[{"name":"PSReaderUI"}],"roleHeading":"Article","role":"article","title":"Sharing"},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"The PSReaderUI SDK provides built-in sharing through the "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareDelegate","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"protocol. The SDK ships three ready-to-use providers — "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareProvider","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/WebReaderShareProvider","type":"reference","isActive":true},{"type":"text","text":", and "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArticleLinkShareProvider","type":"reference","isActive":true},{"type":"text","text":" — that cover the"},{"type":"text","text":" "},{"type":"text","text":"most common scenarios. For full control, implement "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareDelegate","type":"reference","isActive":true},{"type":"text","text":" directly."}],"type":"paragraph"},{"text":"Key Concepts","level":2,"anchor":"Key-Concepts","type":"heading"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Web reader link"}],"type":"strong"},{"type":"text","text":" — a URL that opens the edition page in the PageSuite web"},{"type":"text","text":" "},{"type":"text","text":"reader (e.g., "},{"type":"codeVoice","code":"reader.pagesuite.com\/shortcode\/CODE\/edition\/GUID"},{"type":"text","text":"). This lets"},{"type":"text","text":" "},{"type":"text","text":"anyone view the page in a browser without installing the app."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Article link"}]},{"type":"text","text":" — a URL pointing to the article on the publisher’s own website"},{"type":"text","text":" "},{"type":"text","text":"(e.g., "},{"code":"example.com\/news\/article-slug","type":"codeVoice"},{"type":"text","text":"). This link is set by the publisher in"},{"type":"text","text":" "},{"type":"text","text":"the CMS and is only available for article-type pages that have a "},{"code":"shareLink","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"configured."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Both link types are surfaced through the iOS share sheet"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"UIActivityViewController"},{"type":"text","text":"). The built-in providers automatically include a"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"Copy Link"}]},{"type":"text","text":" activity alongside the standard system activities."}],"type":"paragraph"},{"text":"Choosing a Share Policy","level":2,"anchor":"Choosing-a-Share-Policy","type":"heading"},{"inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareProvider","isActive":true,"type":"reference"},{"type":"text","text":" wraps one or both of the built-in providers and applies a"},{"type":"text","text":" "},{"type":"text","text":"fallback strategy through its "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareProvider\/SharePolicy","isActive":true,"type":"reference"},{"type":"text","text":" enum:"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Policy"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"When to use"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"What’s shareable"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".disabled","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"You don’t want any sharing","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Nothing","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".onlyWebReader","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"All pages should share a web reader link"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Any page with a page GUID"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".onlyArticleLink"}]}],[{"type":"paragraph","inlineContent":[{"text":"Only article pages with a CMS link should be shareable","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Article pages with a non-empty "},{"type":"codeVoice","code":"shareLink"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".preferWebReader","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Web reader link preferred, article link as fallback"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Most pages via web reader; article pages also eligible"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".preferArticleLink","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Article link preferred, web reader as fallback"}]}],[{"type":"paragraph","inlineContent":[{"text":"Article pages via CMS link; all other pages via web reader","type":"text"}]}]]],"header":"row","type":"table"},{"name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":".onlyArticleLink()"},{"type":"text","text":" is the default policy when no share delegate is"},{"type":"text","text":" "},{"type":"text","text":"assigned. Assign a delegate explicitly only if you need a different policy."}]}],"type":"aside","style":"tip"},{"text":"Quick Setup","level":2,"anchor":"Quick-Setup","type":"heading"},{"inlineContent":[{"text":"To enable web reader sharing, create a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/WebReaderShareProvider","type":"reference"},{"text":" with your","type":"text"},{"text":" ","type":"text"},{"text":"shortcode and assign it through a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareProvider","type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let webProvider = PSReaderUI.WebReaderShareProvider(","    urlMask: nil,","    shortCode: \"SHORTCODE\"",")","","globalConfig.shareDelegate = PSReaderUI.ShareProvider(","    sharePolicy: .preferArticleLink(","        webProvider: webProvider,","        articleLinkProvider: PSReaderUI.ArticleLinkShareProvider()","    )",")"]},{"inlineContent":[{"type":"text","text":"To disable sharing entirely:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["globalConfig.shareDelegate = PSReaderUI.ShareProvider(sharePolicy: .disabled)"]},{"text":"Policy Examples","level":2,"anchor":"Policy-Examples","type":"heading"},{"text":"Web Reader Only","level":3,"anchor":"Web-Reader-Only","type":"heading"},{"inlineContent":[{"text":"Share every page as a web reader link. Useful when the publisher does not have","type":"text"},{"text":" ","type":"text"},{"text":"article pages on their website:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let webProvider = PSReaderUI.WebReaderShareProvider(","    urlMask: nil,","    shortCode: \"SHORTCODE\"",")","","globalConfig.shareDelegate = PSReaderUI.ShareProvider(","    sharePolicy: .onlyWebReader(webProvider: webProvider)",")"]},{"text":"Custom Web Reader Domain","level":3,"anchor":"Custom-Web-Reader-Domain","type":"heading"},{"inlineContent":[{"text":"If your web reader is hosted on a custom domain, pass it as the ","type":"text"},{"code":"urlMask","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let webProvider = PSReaderUI.WebReaderShareProvider(","    urlMask: \"reader.mypublication.com\",","    shortCode: \"SHORTCODE\"",")"]},{"inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"urlMask"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", the provider defaults to "},{"type":"codeVoice","code":"reader.pagesuite.com"},{"type":"text","text":" for"},{"type":"text","text":" "},{"type":"text","text":"feed editions and "},{"type":"codeVoice","code":"edition.pagesuite.com"},{"type":"text","text":" for replica editions."}],"type":"paragraph"},{"text":"Article Link Only (Default)","level":3,"anchor":"Article-Link-Only-Default","type":"heading"},{"inlineContent":[{"text":"Only pages that have a publisher-configured article link are shareable:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["globalConfig.shareDelegate = PSReaderUI.ShareProvider(","    sharePolicy: .onlyArticleLink()",")"]},{"text":"Prefer Article Link with Web Reader Fallback","level":3,"anchor":"Prefer-Article-Link-with-Web-Reader-Fallback","type":"heading"},{"inlineContent":[{"type":"text","text":"Share the article link when available, otherwise fall back to the web reader:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let webProvider = PSReaderUI.WebReaderShareProvider(","    urlMask: nil,","    shortCode: \"SHORTCODE\"",")","","globalConfig.shareDelegate = PSReaderUI.ShareProvider(","    sharePolicy: .preferArticleLink(","        webProvider: webProvider,","        articleLinkProvider: PSReaderUI.ArticleLinkShareProvider()","    )",")"]},{"text":"ShareContext","level":2,"anchor":"ShareContext","type":"heading"},{"inlineContent":[{"text":"When a share action is triggered, the delegate returns a ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareContext","isActive":true,"type":"reference"},{"text":" that","type":"text"},{"text":" ","type":"text"},{"text":"the SDK passes to ","type":"text"},{"code":"UIActivityViewController","type":"codeVoice"},{"text":". The struct has three fields:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":"activityItems","type":"codeVoice"}]},{"type":"text","text":" — the primary items to share (URLs, strings, images)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"applicationActivities"}]},{"type":"text","text":" — optional custom "},{"code":"UIActivity","type":"codeVoice"},{"type":"text","text":" instances to"},{"type":"text","text":" "},{"type":"text","text":"include in the share sheet."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"subject"}]},{"type":"text","text":" — an optional subject line used by activities like Mail."}]}]}]},{"inlineContent":[{"type":"text","text":"The built-in providers automatically add a "},{"inlineContent":[{"type":"text","text":"Copy Link"}],"type":"strong"},{"type":"text","text":" activity to"},{"type":"text","text":" "},{"code":"applicationActivities","type":"codeVoice"},{"type":"text","text":". If you implement a custom delegate, add your own"},{"type":"text","text":" "},{"type":"text","text":"activities as needed."}],"type":"paragraph"},{"text":"Replica vs Feed Sharing","level":2,"anchor":"Replica-vs-Feed-Sharing","type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareDelegate","isActive":true},{"type":"text","text":" protocol defines "},{"type":"strong","inlineContent":[{"text":"separate methods","type":"text"}]},{"type":"text","text":" for feed and"},{"type":"text","text":" "},{"type":"text","text":"replica editions."}],"type":"paragraph"},{"text":"Feed Edition Methods","level":3,"anchor":"Feed-Edition-Methods","type":"heading"},{"inlineContent":[{"text":"Feed editions use page-level sharing:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"isShareable(page:inEdition:inPublished:)","type":"codeVoice"},{"type":"text","text":" — controls whether the share"},{"type":"text","text":" "},{"type":"text","text":"button is visible for a given page."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"shareContext(forPage:inEdition:inPublished:)","type":"codeVoice"},{"text":" — provides the share content.","type":"text"}]}]}]},{"text":"Replica Edition Methods","level":3,"anchor":"Replica-Edition-Methods","type":"heading"},{"inlineContent":[{"text":"Replica editions use spread-level sharing. A ","type":"text"},{"code":"PSReplicaPageSpread","type":"codeVoice"},{"text":" represents","type":"text"},{"text":" ","type":"text"},{"text":"what the user currently sees and has three cases:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":".single(PSPage)"}]},{"text":" — a single PDF page.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":".double(left: PSPage?, right: PSPage?)","type":"codeVoice"}],"type":"strong"},{"type":"text","text":" — a double-page spread in"},{"type":"text","text":" "},{"type":"text","text":"landscape mode."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"codeVoice","code":".article(PSArticle)"}],"type":"strong"},{"text":" — an article view within the replica reader.","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"The delegate methods receive a ","type":"text"},{"type":"codeVoice","code":"PSReplicaPageSpread"},{"text":" and a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"PSReplicaEdition"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"isShareable(spread:inReplicaEdition:)"},{"text":" — controls share button visibility.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"shareContext(forSpread:inReplicaEdition:)"},{"type":"text","text":" — provides the share content."}],"type":"paragraph"}]}]},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArticleLinkShareProvider","type":"reference","isActive":true},{"text":" only shares replica article spreads","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"type":"codeVoice","code":".article"},{"text":" case) where the article has a non-empty ","type":"text"},{"type":"codeVoice","code":"shareLink"},{"text":". PDF page","type":"text"},{"text":" ","type":"text"},{"text":"spreads are not shareable through this provider.","type":"text"}]}],"type":"aside","style":"note"},{"text":"Custom ShareDelegate","level":2,"anchor":"Custom-ShareDelegate","type":"heading"},{"inlineContent":[{"text":"For full control, implement ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareDelegate"},{"type":"text","text":" directly. The protocol has"},{"type":"text","text":" "},{"type":"text","text":"methods for both feed edition pages and replica spreads:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct MyShareDelegate: PSReaderUI.ShareDelegate {","","    \/\/ MARK: Feed Edition Methods","","    func isShareable(","        page: PSEPage,","        inEdition edition: PSEEdition,","        inPublished published: PSEPublished","    ) -> Bool {","        \/\/ Only share article pages","        return page.type == \"templateArticle\"","    }","","    func shareContext(","        forPage page: PSEPage,","        inEdition edition: PSEEdition,","        inPublished published: PSEPublished","    ) -> ShareContext? {","        guard let article = page.articles?.first,","              let shareLink = article.sharelink,","              let url = URL(string: shareLink) else {","            return nil","        }","        return ShareContext(","            activityItems: [url],","            subject: article.headline","        )","    }","","    \/\/ MARK: Replica Edition Methods","","    func isShareable(","        spread: PSReplicaPageSpread,","        inReplicaEdition replicaEdition: PSReplicaEdition","    ) -> Bool {","        \/\/ Share all page spreads; only share articles that have a link","        switch spread {","        case .single, .double:","            return true","        case .article(let article):","            return !article.shareLink.isEmpty","        }","    }","","    func shareContext(","        forSpread spread: PSReplicaPageSpread,","        inReplicaEdition replicaEdition: PSReplicaEdition","    ) -> ShareContext? {","        let edition = replicaEdition.edition","","        switch spread {","        case .article(let article):","            \/\/ Share the article link","            guard let url = URL(string: article.shareLink) else { return nil }","            return ShareContext(","                activityItems: [url],","                subject: article.headline","            )","","        case .single(let page):","            \/\/ Share a text description of the page","            let text = \"\\(edition.publicationName) - \\(edition.name), page \\(page.num)\"","            return ShareContext(activityItems: [text])","","        case .double(let left, let right):","            let page = left ?? right","            guard let page else { return nil }","            let text = \"\\(edition.publicationName) - \\(edition.name), page \\(page.num)\"","            return ShareContext(activityItems: [text])","        }","    }","}"]},{"name":"Tip","content":[{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"isShareable"},{"type":"text","text":" methods have default implementations that return"},{"type":"text","text":" "},{"type":"codeVoice","code":"true"},{"type":"text","text":" when "},{"type":"codeVoice","code":"shareContext"},{"type":"text","text":" returns a non-nil value. You only need to implement"},{"type":"text","text":" "},{"type":"text","text":"them explicitly as a performance optimization to avoid building a share"},{"type":"text","text":" "},{"type":"text","text":"context just to check visibility."}],"type":"paragraph"}],"type":"aside","style":"tip"},{"text":"Print Integration","level":2,"anchor":"Print-Integration","type":"heading"},{"inlineContent":[{"text":"Since v5.3, printing is consolidated into the share actions. The dedicated","type":"text"},{"text":" ","type":"text"},{"text":"print icon has been removed from the reader navigation bar. Users access","type":"text"},{"text":" ","type":"text"},{"text":"printing through the system share sheet, where it appears as a standard","type":"text"},{"text":" ","type":"text"},{"code":"UIActivity","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Printing requires no configuration. It is available automatically whenever"},{"type":"text","text":" "},{"type":"text","text":"sharing is enabled (i.e., the share delegate is not set to "},{"type":"codeVoice","code":".disabled"},{"type":"text","text":")."}],"type":"paragraph"}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/sharing"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/psreaderui\/sharing"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"kind":"article","abstract":[{"type":"text","text":"Configure how users share edition content from the reader."}],"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Analytics":{"type":"topic","title":"Analytics","abstract":[{"text":"Track user interactions and content engagement across the PSReaderUI SDK.","type":"text"}],"url":"\/documentation\/psreaderui\/analytics","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","kind":"article","role":"article"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/ArticleLinkShareProvider":{"title":"ArticleLinkShareProvider","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArticleLinkShareProvider","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ArticleLinkShareProvider","kind":"identifier"}],"url":"\/documentation\/psreaderui\/articlelinkshareprovider","navigatorTitle":[{"text":"ArticleLinkShareProvider","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"A "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareDelegate","isActive":true},{"type":"text","text":" providing direct article links on the publication’s website."}],"type":"topic"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/ShareContext":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ShareContext"}],"role":"symbol","title":"ShareContext","type":"topic","url":"\/documentation\/psreaderui\/sharecontext","navigatorTitle":[{"kind":"identifier","text":"ShareContext"}],"abstract":[{"type":"text","text":"A structure encapsulating information used to present shareable content."}],"kind":"symbol","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareContext"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/WebReaderShareProvider":{"navigatorTitle":[{"kind":"identifier","text":"WebReaderShareProvider"}],"abstract":[{"type":"text","text":"A "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareDelegate","isActive":true},{"type":"text","text":" that provides shareable links to the web reader pages."},{"type":"text","text":" "},{"type":"text","text":"Use this provider to generate URLs pointing to web reader content."}],"title":"WebReaderShareProvider","type":"topic","role":"symbol","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/WebReaderShareProvider","kind":"symbol","url":"\/documentation\/psreaderui\/webreadershareprovider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"WebReaderShareProvider"}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/ShareProvider":{"title":"ShareProvider","type":"topic","navigatorTitle":[{"kind":"identifier","text":"ShareProvider"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"ShareProvider"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareProvider","url":"\/documentation\/psreaderui\/shareprovider","kind":"symbol","abstract":[{"text":"A composite share provider allowing multiple share strategies to be chained.","type":"text"},{"text":" ","type":"text"},{"text":"Configure this provider to choose preferred or fallback sharing behaviors