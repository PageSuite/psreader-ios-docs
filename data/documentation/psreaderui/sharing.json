agraph"}],[{"inlineContent":[{"type":"text","text":"Web reader link preferred, article link as fallback"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Most pages via web reader; article pages also eligible","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".preferArticleLink"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Article link preferred, web reader as fallback"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Article pages via CMS link; all other pages via web reader"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":".onlyArticleLink()"},{"type":"text","text":" is the default policy when no share delegate is"},{"type":"text","text":" "},{"type":"text","text":"assigned. Assign a delegate explicitly only if you need a different policy."}]}],"name":"Tip","type":"aside","style":"tip"},{"type":"heading","text":"Quick Setup","level":2,"anchor":"Quick-Setup"},{"inlineContent":[{"text":"To enable web reader sharing, create a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/WebReaderShareProvider"},{"text":" with your","type":"text"},{"text":" ","type":"text"},{"text":"shortcode and assign it through a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareProvider"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["let webProvider = PSReaderUI.WebReaderShareProvider(","    urlMask: nil,","    shortCode: \"SHORTCODE\"",")","","globalConfig.shareDelegate = PSReaderUI.ShareProvider(","    sharePolicy: .preferArticleLink(","        webProvider: webProvider,","        articleLinkProvider: PSReaderUI.ArticleLinkShareProvider()","    )",")"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"To disable sharing entirely:","type":"text"}],"type":"paragraph"},{"code":["globalConfig.shareDelegate = PSReaderUI.ShareProvider(sharePolicy: .disabled)"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Policy Examples","level":2,"anchor":"Policy-Examples"},{"type":"heading","text":"Web Reader Only","level":3,"anchor":"Web-Reader-Only"},{"inlineContent":[{"type":"text","text":"Share every page as a web reader link. Useful when the publisher does not have"},{"type":"text","text":" "},{"type":"text","text":"article pages on their website:"}],"type":"paragraph"},{"code":["let webProvider = PSReaderUI.WebReaderShareProvider(","    urlMask: nil,","    shortCode: \"SHORTCODE\"",")","","globalConfig.shareDelegate = PSReaderUI.ShareProvider(","    sharePolicy: .onlyWebReader(webProvider: webProvider)",")"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Custom Web Reader Domain","level":3,"anchor":"Custom-Web-Reader-Domain"},{"inlineContent":[{"type":"text","text":"If your web reader is hosted on a custom domain, pass it as the "},{"type":"codeVoice","code":"urlMask"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["let webProvider = PSReaderUI.WebReaderShareProvider(","    urlMask: \"reader.mypublication.com\",","    shortCode: \"SHORTCODE\"",")"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"When ","type":"text"},{"code":"urlMask","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", the provider defaults to ","type":"text"},{"code":"reader.pagesuite.com","type":"codeVoice"},{"text":" for","type":"text"},{"text":" ","type":"text"},{"text":"feed editions and ","type":"text"},{"code":"edition.pagesuite.com","type":"codeVoice"},{"text":" for replica editions.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Article Link Only (Default)","level":3,"anchor":"Article-Link-Only-Default"},{"inlineContent":[{"type":"text","text":"Only pages that have a publisher-configured article link are shareable:"}],"type":"paragraph"},{"code":["globalConfig.shareDelegate = PSReaderUI.ShareProvider(","    sharePolicy: .onlyArticleLink()",")"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Prefer Article Link with Web Reader Fallback","level":3,"anchor":"Prefer-Article-Link-with-Web-Reader-Fallback"},{"inlineContent":[{"type":"text","text":"Share the article link when available, otherwise fall back to the web reader:"}],"type":"paragraph"},{"code":["let webProvider = PSReaderUI.WebReaderShareProvider(","    urlMask: nil,","    shortCode: \"SHORTCODE\"",")","","globalConfig.shareDelegate = PSReaderUI.ShareProvider(","    sharePolicy: .preferArticleLink(","        webProvider: webProvider,","        articleLinkProvider: PSReaderUI.ArticleLinkShareProvider()","    )",")"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"ShareContext","level":2,"anchor":"ShareContext"},{"inlineContent":[{"text":"When a share action is triggered, the delegate returns a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareContext"},{"text":" that","type":"text"},{"text":" ","type":"text"},{"text":"the SDK passes to ","type":"text"},{"type":"codeVoice","code":"UIActivityViewController"},{"text":". The struct has three fields:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":"activityItems","type":"codeVoice"}]},{"type":"text","text":" — the primary items to share (URLs, strings, images)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"applicationActivities"}]},{"type":"text","text":" — optional custom "},{"type":"codeVoice","code":"UIActivity"},{"type":"text","text":" instances to"},{"type":"text","text":" "},{"type":"text","text":"include in the share sheet."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":"subject","type":"codeVoice"}],"type":"strong"},{"text":" — an optional subject line used by activities like Mail.","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"The built-in providers automatically add a "},{"type":"strong","inlineContent":[{"type":"text","text":"Copy Link"}]},{"type":"text","text":" activity to"},{"type":"text","text":" "},{"type":"codeVoice","code":"applicationActivities"},{"type":"text","text":". If you implement a custom delegate, add your own"},{"type":"text","text":" "},{"type":"text","text":"activities as needed."}],"type":"paragraph"},{"type":"heading","text":"Replica vs Feed Sharing","level":2,"anchor":"Replica-vs-Feed-Sharing"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareDelegate","isActive":true},{"type":"text","text":" protocol defines "},{"type":"strong","inlineContent":[{"text":"separate methods","type":"text"}]},{"type":"text","text":" for feed and"},{"type":"text","text":" "},{"type":"text","text":"replica editions."}],"type":"paragraph"},{"type":"heading","text":"Feed Edition Methods","level":3,"anchor":"Feed-Edition-Methods"},{"inlineContent":[{"text":"Feed editions use page-level sharing:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"isShareable(page:inEdition:inPublished:)","type":"codeVoice"},{"type":"text","text":" — controls whether the share"},{"type":"text","text":" "},{"type":"text","text":"button is visible for a given page."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"shareContext(forPage:inEdition:inPublished:)"},{"type":"text","text":" — provides the share content."}]}]}]},{"type":"heading","text":"Replica Edition Methods","level":3,"anchor":"Replica-Edition-Methods"},{"inlineContent":[{"text":"Replica editions use spread-level sharing. A ","type":"text"},{"code":"PSReplicaPageSpread","type":"codeVoice"},{"text":" represents","type":"text"},{"text":" ","type":"text"},{"text":"what the user currently sees and has three cases:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":".single(PSPage)","type":"codeVoice"}]},{"type":"text","text":" — a single PDF page."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":".double(left: PSPage?, right: PSPage?)"}]},{"type":"text","text":" — a double-page spread in"},{"type":"text","text":" "},{"type":"text","text":"landscape mode."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":".article(PSArticle)"}],"type":"strong"},{"type":"text","text":" — an article view within the replica reader."}]}]}]},{"inlineContent":[{"text":"The delegate methods receive a ","type":"text"},{"code":"PSReplicaPageSpread","type":"codeVoice"},{"text":" and a","type":"text"},{"text":" ","type":"text"},{"code":"PSReplicaEdition","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"isShareable(spread:inReplicaEdition:)"},{"type":"text","text":" — controls share button visibility."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"shareContext(forSpread:inReplicaEdition:)"},{"text":" — provides the share content.","type":"text"}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArticleLinkShareProvider","type":"reference","isActive":true},{"type":"text","text":" only shares replica article spreads"},{"type":"text","text":" "},{"type":"text","text":"("},{"code":".article","type":"codeVoice"},{"type":"text","text":" case) where the article has a non-empty "},{"code":"shareLink","type":"codeVoice"},{"type":"text","text":". PDF page"},{"type":"text","text":" "},{"type":"text","text":"spreads are not shareable through this provider."}]}],"name":"Note","type":"aside","style":"note"},{"type":"heading","text":"Custom ShareDelegate","level":2,"anchor":"Custom-ShareDelegate"},{"inlineContent":[{"text":"For full control, implement ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareDelegate"},{"text":" directly. The protocol has","type":"text"},{"text":" ","type":"text"},{"text":"methods for both feed edition pages and replica spreads:","type":"text"}],"type":"paragraph"},{"code":["struct MyShareDelegate: PSReaderUI.ShareDelegate {","","    \/\/ MARK: Feed Edition Methods","","    func isShareable(","        page: PSEPage,","        inEdition edition: PSEEdition,","        inPublished published: PSEPublished","    ) -> Bool {","        \/\/ Only share article pages","        return page.type == \"templateArticle\"","    }","","    func shareContext(","        forPage page: PSEPage,","        inEdition edition: PSEEdition,","        inPublished published: PSEPublished","    ) -> ShareContext? {","        guard let article = page.articles?.first,","              let shareLink = article.sharelink,","              let url = URL(string: shareLink) else {","            return nil","        }","        return ShareContext(","            activityItems: [url],","            subject: article.headline","        )","    }","","    \/\/ MARK: Replica Edition Methods","","    func isShareable(","        spread: PSReplicaPageSpread,","        inReplicaEdition replicaEdition: PSReplicaEdition","    ) -> Bool {","        \/\/ Share all page spreads; only share articles that have a link","        switch spread {","        case .single, .double:","            return true","        case .article(let article):","            return !article.shareLink.isEmpty","        }","    }","","    func shareContext(","        forSpread spread: PSReplicaPageSpread,","        inReplicaEdition replicaEdition: PSReplicaEdition","    ) -> ShareContext? {","        let edition = replicaEdition.edition","","        switch spread {","        case .article(let article):","            \/\/ Share the article link","            guard let url = URL(string: article.shareLink) else { return nil }","            return ShareContext(","                activityItems: [url],","                subject: article.headline","            )","","        case .single(let page):","            \/\/ Share a text description of the page","            let text = \"\\(edition.publicationName) - \\(edition.name), page \\(page.num)\"","            return ShareContext(activityItems: [text])","","        case .double(let left, let right):","            let page = left ?? right","            guard let page else { return nil }","            let text = \"\\(edition.publicationName) - \\(edition.name), page \\(page.num)\"","            return ShareContext(activityItems: [text])","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"content":[{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"isShareable"},{"text":" methods have default implementations that return","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" when ","type":"text"},{"type":"codeVoice","code":"shareContext"},{"text":" returns a non-nil value. You only need to implement","type":"text"},{"text":" ","type":"text"},{"text":"them explicitly as a performance optimization to avoid building a share","type":"text"},{"text":" ","type":"text"},{"text":"context just to check visibility.","type":"text"}],"type":"paragraph"}],"name":"Tip","type":"aside","style":"tip"},{"type":"heading","text":"Print Integration","level":2,"anchor":"Print-Integration"},{"inlineContent":[{"type":"text","text":"Since v5.3, printing is consolidated into the share actions. The dedicated"},{"type":"text","text":" "},{"type":"text","text":"print icon has been removed from the reader navigation bar. Users access"},{"type":"text","text":" "},{"type":"text","text":"printing through the system share sheet, where it appears as a standard"},{"type":"text","text":" "},{"type":"codeVoice","code":"UIActivity"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"Printing requires no configuration. It is available automatically whenever","type":"text"},{"text":" ","type":"text"},{"text":"sharing is enabled (i.e., the share delegate is not set to ","type":"text"},{"type":"codeVoice","code":".disabled"},{"text":").","type":"text"}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"Configure how users share edition content from the reader."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Paywall-Integration":{"abstract":[{"text":"Restrict access to premium content with custom paywall screens.","type":"text"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","role":"article","kind":"article","url":"\/documentation\/psreaderui\/paywall-integration","type":"topic","title":"Paywall Integration"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/WebReaderShareProvider":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"WebReaderShareProvider","kind":"identifier"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/WebReaderShareProvider","url":"\/documentation\/psreaderui\/webreadershareprovider","type":"topic","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"WebReaderShareProvider","kind":"identifier"}],"title":"WebReaderShareProvider","abstract":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ShareDelegate","type":"reference","isActive":t