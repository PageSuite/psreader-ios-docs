{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Localization"},"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"inlineContent":[{"text":"Localization is provided by the ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LocalizationManager","isActive":true,"type":"reference"},{"text":" singleton. Every","type":"text"},{"text":" ","type":"text"},{"text":"user-facing string in the SDK is identified by a ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LocalizedStringKey","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The base "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LocalizationManager","isActive":true,"type":"reference"},{"type":"text","text":" uses "},{"code":"NSLocalizedString","type":"codeVoice"},{"type":"text","text":" to resolve each key,"},{"type":"text","text":" "},{"type":"text","text":"with the key’s "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LocalizedStringKey","isActive":true,"type":"reference"},{"type":"text","text":" "},{"code":"rawValue","type":"codeVoice"},{"type":"text","text":" as the lookup key and its"},{"type":"text","text":" "},{"type":"text","text":"built-in default as the fallback value. This means you can provide translations"},{"type":"text","text":" "},{"type":"text","text":"using a standard "},{"code":".strings","type":"codeVoice"},{"type":"text","text":" file or a String Catalog ("},{"code":".xcstrings","type":"codeVoice"},{"type":"text","text":") in your"},{"type":"text","text":" "},{"type":"text","text":"app bundle without writing any code."}],"type":"paragraph"},{"content":[{"type"