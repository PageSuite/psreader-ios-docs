{"type":"text","text":" "},{"type":"text","text":"variants, or fall through to the default behavior selectively:"}],"type":"paragraph"},{"syntax":"swift","code":["import PSReaderUI","","class CustomLocalizationManager: PSReaderUI.LocalizationManager {","    override func localizedString(for key: LocalizedStringKey) -> String {","        switch key {","        case .bookmarksTitle:","            return \"Saved\"","        case .downloadsTitle:","            return \"Offline\"","        default:","            return super.localizedString(for: key)","        }","    }","}","","PSReaderUI.LocalizationManager.shared = CustomLocalizationManager()"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Set the custom manager before creating any SDK view controllers so that the"},{"type":"text","text":" "},{"type":"text","text":"overridden strings are used from the start."}],"type":"paragraph"},{"text":"Reference","level":2,"type":"heading","anchor":"Reference"},{"inlineContent":[{"type":"text","text":"See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LocalizedStringKey"},{"type":"text","text":" for the complete list of keys and their default"},{"type":"text","text":" "},{"type":"text","text":"values."}],"type":"paragraph"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/psreaderui\/localization"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/psreaderui\/localization"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"type":"text","text":"Localize all user-facing strings in the PSReaderUI SDK."}],"kind":"article","seeAlsoSections":[{"identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Theming-and-Customization","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Standalone-View-Controllers"],"anchor":"Customization","