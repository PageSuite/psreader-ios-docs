s"},{"type":"text","text":" "},{"type":"text","text":"banner ads within the reader."}],"type":"paragraph"},{"type":"heading","level":2,"text":"Protocol Methods","anchor":"Protocol-Methods"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertDelegate"},{"type":"text","text":" protocol defines three methods, each returning an"},{"type":"text","text":" "},{"type":"text","text":"optional "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController"},{"type":"text","text":":"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertDelegate\/advertViewControllerForBottomBanner(inPublished:edition:)","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"— bottom banner in "},{"inlineContent":[{"type":"text","text":"feed edition"}],"type":"strong"},{"type":"text","text":" readers."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertDelegate\/advertViewControllerForBottomBanner(inReplicaEdition:)"},{"type":"text","text":" "},{"type":"text","text":"— bottom banner in "},{"inlineContent":[{"type":"text","text":"replica edition"}],"type":"strong"},{"type":"text","text":" readers."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertDelegate\/advertViewControllerForTopBanner(inReplicaEdition:)","isActive":true},{"text":" ","type":"text"},{"text":"— top banner in ","type":"text"},{"inlineContent":[{"text":"replica edition","type":"text"}],"type":"strong"},{"text":" readers.","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Return "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" from any method to omit the ad placement for that context."}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"Feed editions support bottom banners only. Replica editions support","type":"text"},{"text":" ","type":"text"},{"text":"both top and bottom banners.","type":"text"}],"type":"paragraph"}],"name":"Note","type":"aside","style":"note"},{"type":"heading","level":2,"text":"Creating an AdvertViewController","anchor":"Creating-an-AdvertViewController"},{"inlineContent":[{"type":"text","text":"Your ad view controller must conform to "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController","isActive":true},{"type":"text","text":". The SDK"},{"type":"text","text":" "},{"type":"text","text":"embeds it as a "},{"type":"strong","inlineContent":[{"type":"text","text":"child view controller"}]},{"type":"text","text":" within the reader interface — it is"},{"type":"text","text":" "},{"type":"text","text":"added via "},{"type":"codeVoice","code":"addChild"},{"type":"text","text":" and its view is placed inside the reader’s view hierarchy."},{"type":"text","text":" "},{"type":"text","text":"This means your ad banner participates in the standard UIKit containment"},{"type":"text","text":" "},{"type":"text","text":"lifecycle ("},{"type":"codeVoice","code":"willMove(toParent:)"},{"type":"text","text":", "},{"type":"codeVoice","code":"didMove(toParent:)"},{"type":"text","text":", etc.)."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import PSReaderUI","import PSReader","","class MyAdBanner: UIViewController, PSReaderUI.AdvertViewController {","    override func viewDidLoad() {","        super.viewDidLoad()","        \/\/ Load and display your ad content","    }","","    func didChangeTo(spread: PSEPageSpread?,","                     inEdition edition: PSEEdition,","                     inPublished published: PSEPublished) {","        refreshAd()","    }","","    func didChangeTo(spread: PSReplicaPageSpread?,","                     inReplicaEdition replicaEdition: PSReplicaEdition) {","        refreshAd()","    }","","    private func refreshAd(forPage pageNumber: Int) {","        \/\/ Refresh your ad or update section targeting","    }","}"]},{"inlineContent":[{"type":"text","text":"The banner’s height is determined by your view’s Auto Layout constraints. Set"},{"type":"text","text":" "},{"type":"text","text":"an intrinsic content size or explicit height constraint on your ad view to"},{"type":"text","text":" "},{"type":"text","text":"control how tall the banner appears in the reader."}],"type":"paragraph"},{"type":"heading","level":2,"text":"Assigning the Delegate","anchor":"Assigning-the-Delegate"},{"inlineContent":[{"type":"text","text":"Set the delegate on your "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct MyAdvertDelegate: PSReaderUI.AdvertDelegate {","    func advertViewControllerForBottomBanner(","        inPublished published: PSEPublished,","        edition: PSEEdition","    ) -> AdvertViewController? {","        return MyAdBanner()","    }","","    func advertViewControllerForBottomBanner(","        inReplicaEdition edition: PSEdition","    ) -> AdvertViewController? {","        return MyAdBanner()","    }","","    func advertViewControllerForTopBanner(","        inReplicaEdition edition: PSEdition","    ) -> AdvertViewController? {","        return nil \/\/ No top banner","    }","}","","globalConfig.advertDelegate = MyAdvertDelegate()"]},{"inlineContent":[{"type":"text","text":"The delegate is inherited by all reader configurations created from the"},{"type":"text","text":" "},{"type":"text","text":"global configuration."}],"type":"paragraph"},{"type":"heading","level":2,"text":"Responding to Page Changes","anchor":"Responding-to-Page-Changes"},{"inlineContent":[{"type":"text","text":"The SDK notifies your "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController","isActive":true},{"type":"text","text":" when the reader’s visible page"},{"type":"text","text":" "},{"type":"text","text":"changes. This is useful for refreshing ad content or updating section-level"},{"type":"text","text":" "},{"type":"text","text":"ad targeting as the user navigates through an edition."}],"type":"paragraph"},{"inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController","isActive":true,"type":"reference"},{"type":"text","text":" defines two page change callbacks — one for each"},{"type":"text","text":" "},{"type":"text","text":"edition type:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController\/didChangeTo(spread:inEdition:inPublished:)","type":"reference"},{"text":" ","type":"text"},{"text":"— called in ","type":"text"},{"inlineContent":[{"type":"text","text":"feed edition"}],"type":"strong"},{"text":" readers.","type":"text"}]}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController\/didChangeTo(spread:inReplicaEdition:)","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"— called in ","type":"text"},{"inlineContent":[{"type":"text","text":"replica edition"}],"type":"strong"},{"text":" readers.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Both methods receive the current page spread and edition context. The "},{"code":"spread","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"parameter is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" when there is no active page (for example, during a"},{"type":"text","text":" "},{"type":"text","text":"transition). Use "},{"code":"referencePage()","type":"codeVoice"},{"type":"text","text":" on the spread to get the primary page:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func didChangeTo(spread: PSEPageSpread?,","                 inEdition edition: PSEEdition,","                 inPublished published: PSEPublished) {","    guard let page = spread?.referencePage() else { return }","    \/\/ Use page.pageNumber for ad targeting or to trigger an ad refresh","    adView.setTargeting(page: page.pageNumber)","    adView.loadNewAd()","}","","func didChangeTo(spread: PSReplicaPageSpread?,","                 inReplicaEdition replicaEdition: PSReplicaEdition) {","    guard let page = spread?.referencePage() else { return }","    \/\/ Use page.num for the page number in replica editions","    adView.setTargeting(page: page.num)","    adView.loadNewAd()","}"]},{"inlineContent":[{"type":"text","text":"Both methods have default implementations that do nothing, so you only need to"},{"type":"text","text":" "},{"type":"text","text":"implement the ones relevant to your ad setup. If you only serve ads in feed"},{"type":"text","text":" "},{"type":"text","text":"editions, you can omit the replica variant and vice versa."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Paywall-Integration":{"kind":"article","url":"\/documentation\/psreaderui\/paywall-integration","role":"article","type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","title":"Paywall Integration","abstract":[{"type":"text","text":"Restrict access to premium content with custom paywall screens."}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/AdvertDelegate/advertViewControllerForTopBanner(inReplicaEdition:)":{"role":"symbol",