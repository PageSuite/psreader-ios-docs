{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements"},"kind":"article","hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"By default the PSReaderUI SDK does not display any advertisements."},{"type":"text","text":" "},{"type":"text","text":"Advertisement support is opt-in through the "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertDelegate","isActive":true},{"type":"text","text":" protocol."},{"type":"text","text":" "},{"type":"text","text":"Implement this delegate to provide view controllers that the SDK embeds as"},{"type":"text","text":" "},{"type":"text","text":"banner ads within the reader."}],"type":"paragraph"},{"anchor":"Protocol-Methods","level":2,"text":"Protocol Methods","type":"heading"},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertDelegate","type":"reference"},{"text":" protocol defines three methods, each returning an","type":"text"},{"text":" ","type":"text"},{"text":"optional ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController","type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertDelegate\/advertViewControllerForBottomBanner(inPublished:edition:)","type":"reference"},{"text":" ","type":"text"},{"text":"— bottom banner in ","type":"text"},{"inlineContent":[{"type":"text","text":"feed edition"}],"type":"strong"},{"text":" readers.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertDelegate\/advertViewControllerForBottomBanner(inReplicaEdition:)","type":"reference"},{"type":"text","text":" "},{"type":"text","text":"— bottom banner in "},{"inlineContent":[{"type":"text","text":"replica edition"}],"type":"strong"},{"type":"text","text":" readers."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertDelegate\/advertViewControllerForTopBanner(inReplicaEdition:)","type":"reference"},{"text":" ","type":"text"},{"text":"— top banner in ","type":"text"},{"inlineContent":[{"type":"text","text":"replica edition"}],"type":"strong"},{"text":" readers.","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Return ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" from any method to omit the ad placement for that context.","type":"text"}],"type":"paragraph"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"Feed editions support bottom banners only. Replica editions support"},{"type":"text","text":" "},{"type":"text","text":"both top and bottom banners."}],"type":"paragraph"}],"name":"Note","type":"aside"},{"anchor":"Creating-an-AdvertViewController","level":2,"text":"Creating an AdvertViewController","type":"heading"},{"inlineContent":[{"type":"text","text":"Your ad view controller must conform to "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController","isActive":true},{"type":"text","text":". The SDK"},{"type":"text","text":" "},{"type":"text","text":"embeds it as a "},{"inlineContent":[{"type":"text","text":"child view controller"}],"type":"strong"},{"type":"text","text":" within the reader interface — it is"},{"type":"text","text":" "},{"type":"text","text":"added via "},{"type":"codeVoice","code":"addChild"},{"type":"text","text":" and its view is placed inside the reader’s view hierarchy."},{"type":"text","text":" "},{"type":"text","text":"This means your ad banner participates in the standard UIKit containment"},{"type":"text","text":" "},{"type":"text","text":"lifecycle ("},{"type":"codeVoice","code":"willMove(toParent:)"},{"type":"text","text":", "},{"type":"codeVoice","code":"didMove(toParent:)"},{"type":"text","text":", etc.)."}],"type":"paragraph"},{"code":["import PSReaderUI","import PSReader","","class MyAdBanner: UIViewController, PSReaderUI.AdvertViewController {","    override func viewDidLoad() {","        super.viewDidLoad()","        \/\/ Load and display your ad content","    }","","    func didChangeTo(spread: PSEPageSpread?,","                     inEdition edition: PSEEdition,","                     inPublished published: PSEPublished) {","        refreshAd()","    }","","    func didChangeTo(spread: PSReplicaPageSpread?,","                     inReplicaEdition replicaEdition: PSReplicaEdition) {","        refreshAd()","    }","","    private func refreshAd(forPage pageNumber: Int) {","        \/\/ Refresh your ad or update section targeting","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The banner’s height is determined by your view’s Auto Layout constraints. Set","type":"text"},{"text":" ","type":"text"},{"text":"an intrinsic content size or explicit height constraint on your ad view to","type":"text"},{"text":" ","type":"text"},{"text":"control how tall the banner appears in the reader.","type":"text"}],"type":"paragraph"},{"anchor":"Assigning-the-Delegate","level":2,"text":"Assigning the Delegate","type":"heading"},{"inlineContent":[{"type":"text","text":"Set the delegate on your "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["struct MyAdvertDelegate: PSReaderUI.AdvertDelegate {","    func advertViewControllerForBottomBanner(","        inPublished published: PSEPublished,","        edition: PSEEdition","    ) -> AdvertViewController? {","        return MyAdBanner()","    }","","    func advertViewControllerForBottomBanner(","        inReplicaEdition edition: PSEdition","    ) -> AdvertViewController? {","        return MyAdBanner()","    }","","    func advertViewControllerForTopBanner(","        inReplicaEdition edition: PSEdition","    ) -> AdvertViewController? {","        return nil \/\/ No top banner","    }","}","","globalConfig.advertDelegate = MyAdvertDelegate()"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The delegate is inherited by all reader configurations created from the","type":"text"},{"text":" ","type":"text"},{"text":"global configuration.","type":"text"}],"type":"paragraph"},{"anchor":"Responding-to-Page-Changes","level":2,"text":"Responding to Page Changes","type":"heading"},{"inlineContent":[{"type":"text","text":"The SDK notifies your "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController"},{"type":"text","text":" when the reader’s visible page"},{"type":"text","text":" "},{"type":"text","text":"changes. This is useful for refreshing ad content or updating section-level"},{"type":"text","text":" "},{"type":"text","text":"ad targeting as the user navigates through an edition."}],"type":"paragraph"},{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController","isActive":true},{"type":"text","text":" defines two page change callbacks — one for each"},{"type":"text","text":" "},{"type":"text","text":"edition type:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController\/didChangeTo(spread:inEdition:inPublished:)"},{"type":"text","text":" "},{"type":"text","text":"— called in "},{"type":"strong","inlineContent":[{"type":"text","text":"feed edition"}]},{"type":"text","text":" readers."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController\/didChangeTo(spread:inReplicaEdition:)"},{"type":"text","text":" "},{"type":"text","text":"— called in "},{"inlineContent":[{"type":"text","text":"replica edition"}],"type":"strong"},{"type":"text","text":" readers."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Both methods receive the current page spread and edition context. The "},{"type":"codeVoice","code":"spread"},{"type":"text","text":" "},{"type":"text","text":"parameter is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" when there is no active page (for example, during a"},{"type":"text","text":" "},{"type":"text","text":"transition). Use "},{"type":"codeVoice","code":"referencePage()"},{"type":"text","text":" on the spread to get the primary page:"}],"type":"paragraph"},{"code":["func didChangeTo(spread: PSEPageSpread?,","                 inEdition edition: PSEEdition,","                 inPublished published: PSEPublished) {","    guard let page = spread?.referencePage() else { return }","    \/\/ Use page.pageNumber for ad targeting or to trigger an ad refresh","    adView.setTargeting(page: page.pageNumber)","    adView.loadNewAd()","}","","func didChangeTo(spread: PSReplicaPageSpread?,","                 inReplicaEdition replicaEdition: PSReplicaEdition) {","    guard let page = spread?.referencePage() else { return }","    \/\/ Use page.num for the page number in replica editions","    adView.setTargeting(page: page.num)","    adView.loadNewAd()","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Both methods have default implementations that do nothing, so you only need to"},{"type":"text","text":" "},{"type":"text","text":"implement the ones relevant to your ad setup. If you only serve ads in feed"},{"type":"text","text":" "},{"type":"text","text":"editions, you can omit the replica variant and vice versa."}],"type":"paragraph"}]}],"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"seeAlsoSections":[{"title":"Features","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics"],"generated":true,"anchor":"Features"}],"metadata":{"modules":[{"name":"PSReaderUI"}],"roleHeading":"Article","title":"Advertisements","role":"article"},"abstract":[{"type":"text","text":"Display custom advertisements within the reader."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/advertisements"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/psreaderui\/advertisements"]}],"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/AdvertDelegate/advertViewControllerForBottomBanner(inReplicaEdition:)":{"role":"symbol","title":"advertViewControllerForBottomBanner(inReplicaEdition:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"advertViewControllerForBottomBanner"},{"kind":"text","text":"("},{"kind":"externalParam","text":"inReplicaEdition"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"PSEdition","preciseIdentifier":"c:@M@PSReader@objc(cs)PSEdition"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"AdvertViewController","preciseIdentifier":"s:10PSReaderUI20AdvertViewControllerP"},{"kind":"text","text":"?"}],"kind":"symbol","identifier":"doc:\/\/com.page