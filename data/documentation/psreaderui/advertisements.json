{"primaryContentSections":[{"content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"By default the PSReaderUI SDK does not display any advertisements."},{"type":"text","text":" "},{"type":"text","text":"Advertisement support is opt-in through the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertDelegate"},{"type":"text","text":" protocol."},{"type":"text","text":" "},{"type":"text","text":"Implement this delegate to provide view controllers that the SDK embeds as"},{"type":"text","text":" "},{"type":"text","text":"banner ads within the reader."}],"type":"paragraph"},{"level":2,"anchor":"Protocol-Methods","text":"Protocol Methods","type":"heading"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertDelegate","isActive":true,"type":"reference"},{"text":" protocol defines three methods, each returning an","type":"text"},{"text":" ","type":"text"},{"text":"optional ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertDelegate\/advertViewControllerForBottomBanner(inPublished:edition:)","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"— bottom banner in ","type":"text"},{"inlineContent":[{"type":"text","text":"feed edition"}],"type":"strong"},{"text":" readers.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertDelegate\/advertViewControllerForBottomBanner(inReplicaEdition:)","type":"reference"},{"text":" ","type":"text"},{"text":"— bottom banner in ","type":"text"},{"inlineContent":[{"text":"replica edition","type":"text"}],"type":"strong"},{"text":" readers.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertDelegate\/advertViewControllerForTopBanner(inReplicaEdition:)","isActive":true},{"type":"text","text":" "},{"type":"text","text":"— top banner in "},{"type":"strong","inlineContent":[{"text":"replica edition","type":"text"}]},{"type":"text","text":" readers."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Return "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" from any method to omit the ad placement for that context."}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Feed editions support bottom banners only. Replica editions support"},{"type":"text","text":" "},{"type":"text","text":"both top and bottom banners."}]}],"type":"aside"},{"level":2,"anchor":"Creating-an-AdvertViewController","text":"Creating an AdvertViewController","type":"heading"},{"inlineContent":[{"type":"text","text":"Your ad view controller must conform to "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController","type":"reference","isActive":true},{"type":"text","text":". The SDK"},{"type":"text","text":" "},{"type":"text","text":"embeds it as a "},{"type":"strong","inlineContent":[{"type":"text","text":"child view controller"}]},{"type":"text","text":" within the reader interface — it is"},{"type":"text","text":" "},{"type":"text","text":"added via "},{"code":"addChild","type":"codeVoice"},{"type":"text","text":" and its view is placed inside the reader’s view hierarchy."},{"type":"text","text":" "},{"type":"text","text":"This means your ad banner participates in the standard UIKit containment"},{"type":"text","text":" "},{"type":"text","text":"lifecycle ("},{"code":"willMove(toParent:)","type":"codeVoice"},{"type":"text","text":", "},{"code":"didMove(toParent:)","type":"codeVoice"},{"type":"text","text":", etc.)."}],"type":"paragraph"},{"syntax":"swift","code":["import PSReaderUI","import PSReader","","class MyAdBanner: UIViewController, PSReaderUI.AdvertViewController {","    override func viewDidLoad() {","        super.viewDidLoad()","        \/\/ Load and display your ad content","    }","","    func didChangeTo(spread: PSEPageSpread?,","                     inEdition edition: PSEEdition,","                     inPublished published: PSEPublished) {","        refreshAd()","    }","","    func didChangeTo(spread: PSReplicaPageSpread?,","                     inReplicaEdition replicaEdition: PSReplicaEdition) {","        refreshAd()","    }","","    private func refreshAd(forPage pageNumber: Int) {","        \/\/ Refresh your ad or update section targeting","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"The banner’s height is determined by your view’s Auto Layout constraints. Set","type":"text"},{"text":" ","type":"text"},{"text":"an intrinsic content size or explicit height constraint on your ad view to","type":"text"},{"text":" ","type":"text"},{"text":"control how tall the banner appears in the reader.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Assigning-the-Delegate","text":"Assigning the Delegate","type":"heading"},{"inlineContent":[{"text":"Set the delegate on your ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","type":"reference","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct MyAdvertDelegate: PSReaderUI.AdvertDelegate {","    func advertViewControllerForBottomBanner(","        inPublished published: PSEPublished,","        edition: PSEEdition","    ) -> AdvertViewController? {","        return MyAdBanner()","    }","","    func advertViewControllerForBottomBanner(","        inReplicaEdition edition: PSEdition","    ) -> AdvertViewController? {","        return MyAdBanner()","    }","","    func advertViewControllerForTopBanner(","        inReplicaEdition edition: PSEdition","    ) -> AdvertViewController? {","        return nil \/\/ No top banner","    }","}","","globalConfig.advertDelegate = MyAdvertDelegate()"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The delegate is inherited by all reader configurations created from the"},{"type":"text","text":" "},{"type":"text","text":"global configuration."}],"type":"paragraph"},{"level":2,"anchor":"Responding-to-Page-Changes","text":"Responding to Page Changes","type":"heading"},{"inlineContent":[{"type":"text","text":"The SDK notifies your "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController","isActive":true},{"type":"text","text":" when the reader’s visible page"},{"type":"text","text":" "},{"type":"text","text":"changes. This is useful for refreshing ad content or updating section-level"},{"type":"text","text":" "},{"type":"text","text":"ad targeting as the user navigates through an edition."}],"type":"paragraph"},{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController","isActive":true},{"text":" defines two page change callbacks — one for each","type":"text"},{"text":" ","type":"text"},{"text":"edition type:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController\/didChangeTo(spread:inEdition:inPublished:)","type":"reference"},{"type":"text","text":" "},{"type":"text","text":"— called in "},{"type":"strong","inlineContent":[{"type":"text","text":"feed edition"}]},{"type":"text","text":" readers."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AdvertViewController\/didChangeTo(spread:inReplicaEdition:)"},{"type":"text","text":" "},{"type":"text","text":"— called in "},{"inlineContent":[{"text":"replica edition","type":"text"}],"type":"strong"},{"type":"text","text":" readers."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Both methods receive the current page spread and edition context. The "},{"code":"spread","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"parameter is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" when there is no active page (for example, during a"},{"type":"text","text":" "},{"type":"text","text":"transition). Use "},{"code":"referencePage()","type":"codeVoice"},{"type":"text","text":" on the spread to get the primary page:"}],"type":"paragraph"},{"syntax":"swift","code":["func didChangeTo(spread: PSEPageSpread?,","                 inEdition edition: PSEEdition,","                 inPublished published: PSEPublished) {","    guard let page = spread?.referencePage() else { return }","    \/\/ Use page.pageNumber for ad targeting or to trigger an ad refresh","    adView.setTargeting(page: page.pageNumber)","    adView.loadNewAd()","}","","func didChangeTo(spread: PSReplicaPageSpread?,","                 inReplicaEdition replicaEdition: PSReplicaEdition) {","    guard let page = spread?.referencePage() else { return }","    \/\/ Use page.num for the page number in replica editions","    adView.setTargeting(page: page.num)","    adView.loadNewAd()","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Both methods have default implementations that do nothing, so you only need to"},{"type":"text","text":" "},{"type":"text","text":"implement the ones relevant to your ad setup. If you only serve ads in feed"},{"type":"text","text":" "},{"type":"text","text":"editions, you can omit the replica variant and vice versa."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/psreaderui\/advertisements"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/psreaderui\/advertisements"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"article","sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements"},"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"abstract":[{"text":"Display custom advertisements within the reader.","type":"text"}],"metadata":{"modules":[{"name":"PSReaderUI"}],"roleHeading":"Article","title":"Advertisements","role":"article"},"seeAlsoSections":[{"title":"Features","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Deep-Linking","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Commenting","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Search"],"generated":true,"anchor":"Features"}],"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/GlobalConfiguration":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GlobalConfiguration","kind":"identifier"}],"title":"GlobalConfiguration","navigatorTitle":[{"text":"GlobalConfiguration","kind":"identifier"}],"type":"topic","abstract":[{"text":"A configuration object that provides global settings and delegates for","type":"text"},{"text":" ","type":"text"},{"text":"customizing the SDK’s behavior and appearance.","type":"text"}],"identifier