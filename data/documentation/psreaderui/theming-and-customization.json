{"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"PSReaderUI is designed to be customized. The configuration system follows a","type":"text"},{"text":" ","type":"text"},{"text":"cascading hierarchy: ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","type":"reference"},{"text":" supplies default values that flow","type":"text"},{"text":" ","type":"text"},{"text":"into ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselConfiguration","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration","type":"reference"},{"text":", and their sub-configurations. Override any value at","type":"text"},{"text":" ","type":"text"},{"text":"any level to apply targeted changes.","type":"text"}]},{"text":"Configuration Hierarchy","type":"heading","level":2,"anchor":"Configuration-Hierarchy"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you create a "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselConfiguration","isActive":true,"type":"reference"},{"type":"text","text":" or "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","isActive":true,"type":"reference"},{"type":"text","text":", pass"},{"type":"text","text":" "},{"type":"text","text":"your "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","isActive":true,"type":"reference"},{"type":"text","text":" to its initializer. The child configuration"},{"type":"text","text":" "},{"type":"text","text":"inherits the global fonts, brand color, delegates, and other settings. You"},{"type":"text","text":" "},{"type":"text","text":"can then override individual properties without affecting the rest:"}]},{"syntax":"swift","code":["let globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: apiKey,","    accountGUID: accountGUID,","    primaryFont: UIFont(name: \"Georgia\", size: 12)!,","    secondaryFont: .systemFont(ofSize: 12),","    brandColor: .systemBlue",")","","var carouselConfig = PSReaderUI.CarouselConfiguration(globalConfig: globalConfig)","carouselConfig.sectionRibbon.layout = .fillEqually","\/\/ brandColor, fonts, etc. are inherited from globalConfig"],"type":"codeListing"},{"text":"Fonts","type":"heading","level":2,"anchor":"Fonts"},{"type":"paragraph","inlineContent":[{"text":"Two font families control the SDK’s typography:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"primaryFont"}],"type":"strong"},{"text":" — used for titles, headlines, publication names, and other","type":"text"},{"text":" ","type":"text"},{"text":"prominent text. Set on ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration\/primaryFont","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":"secondaryFont","type":"codeVoice"}],"type":"strong"},{"text":" — used for labels, dates, captions, and secondary UI","type":"text"},{"text":" ","type":"text"},{"text":"elements. Set on ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration\/secondaryFont","isActive":true},{"text":".","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Individual components expose ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LabelConfiguration","isActive":true,"type":"reference"},{"text":" properties that let you","type":"text"},{"text":" ","type":"text"},{"text":"override the font, point size, and color for specific labels without changing","type":"text"},{"text":" ","type":"text"},{"text":"the global fonts:","type":"text"}]},{"syntax":"swift","code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","archiveConfig.editionNameLabel = LabelConfiguration(","    font: UIFont(name: \"Georgia-Bold\", size: 14)!,","    pointSize: 14,","    color: .label",")"],"type":"codeListing"},{"text":"Brand Color","type":"heading","level":2,"anchor":"Brand-Color"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration\/brandColor"},{"type":"text","text":" is used as an accent color throughout"},{"type":"text","text":" "},{"type":"text","text":"the SDK — in selection states, progress indicators, and interactive elements."}]},{"type":"paragraph","inlineContent":[{"text":"To support both light and dark appearances, provide a dynamic color:","type":"text"}]},{"syntax":"swift","code":["let brandColor = UIColor(dynamicProvider: {","    $0.userInterfaceStyle == .dark ? .white : .black","})"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Or define the color in your asset catalog for automatic trait resolution."}]},{"text":"Thumbnail Content Mode","type":"heading","level":2,"anchor":"Thumbnail-Content-Mode"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode","isActive":true,"type":"reference"},{"text":" enum controls how edition thumbnails are sized and","type":"text"},{"text":" ","type":"text"},{"text":"positioned within their containers across archive, bookmarks, downloads, and","type":"text"},{"text":" ","type":"text"},{"text":"splash screens. This is one of the most impactful visual customization points","type":"text"},{"text":" ","type":"text"},{"text":"— it determines the layout feel of your archive grid.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"There are three modes:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode\/fitToWidth"}]},{"type":"text","text":" — the image fills the container’s width"},{"type":"text","text":" "},{"type":"text","text":"and is cropped vertically if the aspect ratio differs. This is the default"},{"type":"text","text":" "},{"type":"text","text":"for archives, bookmarks, and downloads."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode\/fitToHeight","isActive":true}],"type":"strong"},{"text":" — the image fills the container’s","type":"text"},{"text":" ","type":"text"},{"text":"height and is cropped horizontally if needed. This is the default for the","type":"text"},{"text":" ","type":"text"},{"text":"reader splash screen.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode\/flexibleHeight(estimatedAspectRatio:)","isActive":true,"type":"reference"}]},{"type":"text","text":" — the image"},{"type":"text","text":" "},{"type":"text","text":"fills the container’s width while the cell height adjusts dynamically to"},{"type":"text","text":" "},{"type":"text","text":"preserve the image’s natural aspect ratio. Provide an "},{"type":"codeVoice","code":"estimatedAspectRatio"},{"type":"text","text":" "},{"type":"text","text":"to stabilize layout during loading; the SDK refines it automatically once"},{"type":"text","text":" "},{"type":"text","text":"images arrive."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Set the content mode on any configuration that displays thumbnails:","type":"text"}]},{"syntax":"swift","code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","","\/\/ Fixed-height cells that crop vertically (default)","archiveConfig.thumbnailContentMode = .fitToWidth","","\/\/ Dynamic-height cells that show the full image","archiveConfig.thumbnailContentMode = .flexibleHeight(estimatedAspectRatio: 0.75)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Pair the content mode with ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration\/cellAspectRatio","type":"reference"},{"text":" (or the","type":"text"},{"text":" ","type":"text"},{"text":"equivalent ","type":"text"},{"code":"aspectRatio","type":"codeVoice"},{"text":" on ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/BookmarksConfiguration","type":"reference"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DownloadsConfiguration","type":"reference"},{"text":") to fine-tune the grid dimensions.","type":"text"}]},{"content":[{"inlineContent":[{"type":"text","text":""},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode\/flexibleHeight(estimatedAspectRatio:)","type":"reference"},{"type":"text","text":" is not"},{"type":"text","text":" "},{"type":"text","text":"supported in the bookmarks or downloads views."}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"},{"text":"Dark Mode","type":"heading","level":2,"anchor":"Dark-Mode"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK respects the system appearance by default. To force a specific style"},{"type":"text","text":" "},{"type":"text","text":"across the entire SDK, set "},{"type":"codeVoice","code":"overrideUserInterfaceStyle"},{"type":"text","text":" on the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","isActive":true},{"type":"text","text":":"}]},{"syntax":"swift","code":["carouselVC.overrideUserInterfaceStyle = .dark"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This propagates to all child view controllers, including the reader, archive,"},{"type":"text","text":" "},{"type":"text","text":"bookmarks, and downloads views."}]},{"text":"Liquid Glass (iOS 26+)","type":"heading","level":2,"anchor":"Liquid-Glass-iOS-26+"},{"type":"paragraph","inlineContent":[{"text":"On iOS 26 and later, the SDK adopts the Liquid Glass design language by","type":"text"},{"text":" ","type":"text"},{"text":"default. The ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LiquidGlassPolicy","isActive":true,"type":"reference"},{"text":" enum controls this behavior:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":".automatic"}]},{"text":" (default) — uses Liquid Glass on iOS 26+ when supported.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":".disabled"}],"type":"strong"},{"type":"text","text":" — uses the standard appearance on all OS versions."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Set the policy globally or on specific configuration objects for granular","type":"text"},{"text":" ","type":"text"},{"text":"control:","type":"text"}]},{"syntax":"swift","code":["\/\/ Disable globally","globalConfig.liquidGlassPolicy = .disabled","","\/\/ Or disable only on the subsection ribbon","carouselConfig.subsectionRibbon.liquidGlassPolicy = .disabled"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The SDK also respects the host app’s ","type":"text"},{"code":"UIDesignRequiresCompatibility","type":"codeVoice"},{"text":" ","type":"text"},{"text":"Info.plist key and will fall back automatically when set.","type":"text"}]},{"text":"Custom Icons","type":"heading","level":2,"anchor":"Custom-Icons"},{"type":"paragraph","inlineContent":[{"text":"Implement ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AssetDelegate","type":"reference"},{"text":" to replace any of the SDK’s built-in icons with","type":"text"},{"text":" ","type":"text"},{"text":"your own images. See the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageResourceName","type":"reference"},{"text":" symbol page for the full list","type":"text"},{"text":" ","type":"text"},{"text":"of icon identifiers and their usage context.","type":"text"}]},{"syntax":"swift","code":["struct MyAssetDelegate: PSReaderUI.AssetDelegate {","    func imageResource(for name: ImageResourceName) -> UIImage? {","        switch name {","        case .share:","            return UIImage(named: \"my-share-icon\")","        default:","            return name.defaultImage()","        }","    }","}","","globalConfig.assetDelegate = MyAssetDelegate()"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For the legacy replica reader, override"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AssetDelegate\/legacyImageResource(for:)"},{"type":"text","text":" using "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyImageResourceName"},{"type":"text","text":" "},{"type":"text","text":"identifiers."}]},{"text":"Placeholder Images","type":"heading","level":2,"anchor":"Placeholder-Images"},{"type":"paragraph","inlineContent":[{"text":"The SDK can use placeholder images when a thumbnail is unavailable — for","type":"text"},{"text":" ","type":"text"},{"text":"example, when an article has no associated image or a thumbnail fails to load.","type":"text"},{"text":" ","type":"text"},{"text":"By default the SDK shows a solid skeleton view (a grey box that adapts to","type":"text"},{"text":" ","type":"text"},{"text":"light and dark mode). Implement","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AssetDelegate\/placeholderImage(size:with:completion:)"},{"text":" to provide a custom","type":"text"},{"text":" ","type":"text"},{"text":"placeholder instead:","type":"text"}]},{"syntax":"swift","code":["struct MyAssetDelegate: PSReaderUI.AssetDelegate {","    func placeholderImage(","        size: CGSize,","        with traits: UITraitCollection,","        completion: @escaping (UIImage?) -> Void","    ) {","        let name = traits.userInterfaceStyle == .dark","            ? \"placeholder-dark\"","            : \"placeholder-light\"","","        let image = UIImage(named: name)","        completion(image)","    }","}","","globalConfig.assetDelegate = MyAssetDelegate()"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"size"},{"type":"text","text":" parameter reflects the thumbnail container’s dimensions, which you"},{"type":"text","text":" "},{"type":"text","text":"can use to select or generate an appropriately sized image. The "},{"type":"codeVoice","code":"traits"},{"type":"text","text":" "},{"type":"text","text":"parameter carries the current "},{"type":"codeVoice","code":"UITraitCollection"},{"type":"text","text":" — use it to adapt to"},{"type":"text","text":" "},{"type":"text","text":"light or dark mode via "},{"type":"codeVoice","code":"userInterfaceStyle"},{"type":"text","text":", or to account for display scale,"},{"type":"text","text":" "},{"type":"text","text":"size classes, and other environment traits."}]},{"type":"paragraph","inlineContent":[{"text":"Return ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" from the completion handler to keep the current placeholder","type":"text"},{"text":" ","type":"text"},{"text":"presentation unchanged.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The asset delegate is inherited from ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","type":"reference"},{"text":" by default. To","type":"text"},{"text":" ","type":"text"},{"text":"use a different delegate specifically for bookmarks, set it directly on the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/BookmarksConfiguration\/assetDelegate","type":"reference"},{"text":" property.","type":"text"}]},{"text":"Date Formatting","type":"heading","level":2,"anchor":"Date-Formatting"},{"type":"paragraph","inlineContent":[{"text":"Edition dates are formatted through the ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EditionDateFormatter","type":"reference","isActive":true},{"text":" protocol.","type":"text"},{"text":" ","type":"text"},{"text":"The SDK provides ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultEditionDateFormatter","type":"reference","isActive":true},{"text":", which wraps a standard","type":"text"},{"text":" ","type":"text"},{"code":"DateFormatter","type":"codeVoice"},{"text":":","type":