{"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"PSReaderUI is designed to be customized. The configuration system follows a"},{"type":"text","text":" "},{"type":"text","text":"cascading hierarchy: "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","isActive":true},{"type":"text","text":" supplies default values that flow"},{"type":"text","text":" "},{"type":"text","text":"into "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselConfiguration","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration","isActive":true},{"type":"text","text":", and their sub-configurations. Override any value at"},{"type":"text","text":" "},{"type":"text","text":"any level to apply targeted changes."}],"type":"paragraph"},{"text":"Configuration Hierarchy","level":2,"anchor":"Configuration-Hierarchy","type":"heading"},{"inlineContent":[{"type":"text","text":"When you create a "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselConfiguration","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","isActive":true},{"type":"text","text":", pass"},{"type":"text","text":" "},{"type":"text","text":"your "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","isActive":true},{"type":"text","text":" to its initializer. The child configuration"},{"type":"text","text":" "},{"type":"text","text":"inherits the global fonts, brand color, delegates, and other settings. You"},{"type":"text","text":" "},{"type":"text","text":"can then override individual properties without affecting the rest:"}],"type":"paragraph"},{"code":["let globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: apiKey,","    accountGUID: accountGUID,","    primaryFont: UIFont(name: \"Georgia\", size: 12)!,","    secondaryFont: .systemFont(ofSize: 12),","    brandColor: .systemBlue",")","","var carouselConfig = PSReaderUI.CarouselConfiguration(globalConfig: globalConfig)","carouselConfig.sectionRibbon.layout = .fillEqually","\/\/ brandColor, fonts, etc. are inherited from globalConfig"],"syntax":"swift","type":"codeListing"},{"text":"Fonts","level":2,"anchor":"Fonts","type":"heading"},{"inlineContent":[{"type":"text","text":"Two font families control the SDK’s typography:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":"primaryFont","type":"codeVoice"}],"type":"strong"},{"text":" — used for titles, headlines, publication names, and other","type":"text"},{"text":" ","type":"text"},{"text":"prominent text. Set on ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration\/primaryFont","isActive":true,"type":"reference"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"secondaryFont"}],"type":"strong"},{"type":"text","text":" — used for labels, dates, captions, and secondary UI"},{"type":"text","text":" "},{"type":"text","text":"elements. Set on "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration\/secondaryFont"},{"type":"text","text":"."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Individual components expose ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LabelConfiguration","type":"reference"},{"text":" properties that let you","type":"text"},{"text":" ","type":"text"},{"text":"override the font, point size, and color for specific labels without changing","type":"text"},{"text":" ","type":"text"},{"text":"the global fonts:","type":"text"}],"type":"paragraph"},{"code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","archiveConfig.editionNameLabel = LabelConfiguration(","    font: UIFont(name: \"Georgia-Bold\", size: 14)!,","    pointSize: 14,","    color: .label",")"],"syntax":"swift","type":"codeListing"},{"text":"Brand Color","level":2,"anchor":"Brand-Color","type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration\/brandColor","type":"reference","isActive":true},{"type":"text","text":" is used as an accent color throughout"},{"type":"text","text":" "},{"type":"text","text":"the SDK — in selection states, progress indicators, and interactive elements."}],"type":"paragraph"},{"inlineContent":[{"text":"To support both light and dark appearances, provide a dynamic color:","type":"text"}],"type":"paragraph"},{"code":["let brandColor = UIColor(dynamicProvider: {","    $0.userInterfaceStyle == .dark ? .white : .black","})"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Or define the color in your asset catalog for automatic trait resolution.","type":"text"}],"type":"paragraph"},{"text":"Thumbnail Content Mode","level":2,"anchor":"Thumbnail-Content-Mode","type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode","type":"reference","isActive":true},{"type":"text","text":" enum controls how edition thumbnails are sized and"},{"type":"text","text":" "},{"type":"text","text":"positioned within their containers across archive, bookmarks, downloads, and"},{"type":"text","text":" "},{"type":"text","text":"splash screens. This is one of the most impactful visual customization points"},{"type":"text","text":" "},{"type":"text","text":"— it determines the layout feel of your archive grid."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"There are three modes:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode\/fitToWidth","type":"reference","isActive":true}],"type":"strong"},{"text":" — the image fills the container’s width","type":"text"},{"text":" ","type":"text"},{"text":"and is cropped vertically if the aspect ratio differs. This is the default","type":"text"},{"text":" ","type":"text"},{"text":"for archives, bookmarks, and downloads.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode\/fitToHeight","isActive":true,"type":"reference"}]},{"type":"text","text":" — the image fills the container’s"},{"type":"text","text":" "},{"type":"text","text":"height and is cropped horizontally if needed. This is the default for the"},{"type":"text","text":" "},{"type":"text","text":"reader splash screen."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode\/flexibleHeight(estimatedAspectRatio:)","type":"reference","isActive":true}]},{"type":"text","text":" — the image"},{"type":"text","text":" "},{"type":"text","text":"fills the container’s width while the cell height adjusts dynamically to"},{"type":"text","text":" "},{"type":"text","text":"preserve the image’s natural aspect ratio. Provide an "},{"type":"codeVoice","code":"estimatedAspectRatio"},{"type":"text","text":" "},{"type":"text","text":"to stabilize layout during loading; the SDK refines it automatically once"},{"type":"text","text":" "},{"type":"text","text":"images arrive."}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Set the content mode on any configuration that displays thumbnails:"}],"type":"paragraph"},{"code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","","\/\/ Fixed-height cells that crop vertically (default)","archiveConfig.thumbnailContentMode = .fitToWidth","","\/\/ Dynamic-height cells that show the full image","archiveConfig.thumbnailContentMode = .flexibleHeight(estimatedAspectRatio: 0.75)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Pair the content mode with "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration\/cellAspectRatio","isActive":true},{"type":"text","text":" (or the"},{"type":"text","text":" "},{"type":"text","text":"equivalent "},{"code":"aspectRatio","type":"codeVoice"},{"type":"text","text":" on "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/BookmarksConfiguration","isActive":true},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DownloadsConfiguration","isActive":true},{"text":") to fine-tune the grid dimensions.","type":"text"}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode\/flexibleHeight(estimatedAspectRatio:)"},{"type":"text","text":" is not"},{"type":"text","text":" "},{"type":"text","text":"supported in the bookmarks or downloads views."}]}],"type":"aside"},{"text":"Dark Mode","level":2,"anchor":"Dark-Mode","type":"heading"},{"inlineContent":[{"text":"The SDK respects the system appearance by default. To force a specific style","type":"text"},{"text":" ","type":"text"},{"text":"across the entire SDK, set ","type":"text"},{"code":"overrideUserInterfaceStyle","type":"codeVoice"},{"text":" on the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["carouselVC.overrideUserInterfaceStyle = .dark"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"This propagates to all child view controllers, including the reader, archive,","type":"text"},{"text":" ","type":"text"},{"text":"bookmarks, and downloads views.","type":"text"}],"type":"paragraph"},{"text":"Liquid Glass (iOS 26+)","level":2,"anchor":"Liquid-Glass-iOS-26+","type":"heading"},{"inlineContent":[{"type":"text","text":"On iOS 26 and later, the SDK adopts the Liquid Glass design language by"},{"type":"text","text":" "},{"type":"text","text":"default. The "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LiquidGlassPolicy","type":"reference","isActive":true},{"type":"text","text":" enum controls this behavior:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":".automatic"}]},{"text":" (default) — uses Liquid Glass on iOS 26+ when supported.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":".disabled"}]},{"type":"text","text":" — uses the standard appearance on all OS versions."}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Set the policy globally or on specific configuration objects for granular","type":"text"},{"text":" ","type":"text"},{"text":"control:","type":"text"}],"type":"paragraph"},{"code":["\/\/ Disable globally","globalConfig.liquidGlassPolicy = .disabled","","\/\/ Or disable only on the subsection ribbon","carouselConfig.subsectionRibbon.liquidGlassPolicy = .disabled"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The SDK also respects the host app’s "},{"type":"codeVoice","code":"UIDesignRequiresCompatibility"},{"type":"text","text":" "},{"type":"text","text":"Info.plist key and will fall back automatically when set."}],"type":"paragraph"},{"text":"Custom Icons","level":2,"anchor":"Custom-Icons","type":"heading"},{"inlineContent":[{"text":"Implement ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AssetDelegate","type":"reference"},{"text":" to replace any of the SDK’s built-in icons with","type":"text"},{"text":" ","type":"text"},{"text":"your own images. See the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageResourceName","type":"reference"},{"text":" symbol page for the full list","type":"text"},{"text":" ","type":"text"},{"text":"of icon identifiers and their usage context.","type":"text"}],"type":"paragraph"},{"code":["struct MyAssetDelegate: PSReaderUI.AssetDelegate {","    func imageResource(for name: ImageResourceName) -> UIImage? {","        switch name {","        case .share:","            return UIImage(named: \"my-share-icon\")","        default:","            return name.defaultImage()","        }","    }","}","","globalConfig.assetDelegate = MyAssetDelegate()"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"For the legacy replica reader, override"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AssetDelegate\/legacyImageResource(for:)","type":"reference"},{"type":"text","text":" using "},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyImageResourceName","type":"reference"},{"type":"text","text":" "},{"type":"text","text":"identifiers."}],"type":"paragraph"},{"text":"Placeholder Images","level":2,"anchor":"Placeholder-Images","type":"heading"},{"inlineContent":[{"type":"text","text":"The SDK can use placeholder images when a thumbnail is unavailable — for"},{"type":"text","text":" "},{"type":"text","text":"example, when an article has no associated image or a thumbnail fails to load."},{"type":"text","text":" "},{"type":"text","text":"By default the SDK shows a solid skeleton view (a grey box that adapts to"},{"type":"text","text":" "},{"type":"text","text":"light and dark mode). Implement"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AssetDelegate\/placeholderImage(size:with:completion:)"},{"type":"text","text":" to provide a custom"},{"type":"text","text":" "},{"type":"text","text":"placeholder instead:"}],"type":"paragraph"},{"code":["struct MyAssetDelegate: PSReaderUI.AssetDelegate {","    func placeholderImage(","        size: CGSize,","        with traits: UITraitCollection,","        completion: @escaping (UIImage?) -> Void","    ) {","        let name = traits.userInterfaceStyle == .dark","            ? \"placeholder-dark\"","            : \"placeholder-light\"","","        let image = UIImage(named: name)","        completion(image)","    }","}","","globalConfig.assetDelegate = MyAssetDelegate()"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The "},{"code":"size","type":"codeVoice"},{"type":"text","text":" parameter reflects the thumbnail container’s dimensions, which you"},{"type":"text","text":" "},{"type":"text","text":"can use to select or generate an appropriately sized image. The "},{"code":"traits","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"parameter carries the current "},{"code":"UITraitCollection","type":"codeVoice"},{"type":"text","text":" — use it to adapt to"},{"type":"text","text":" "},{"type":"text","text":"light or dark mode via "},{"code":"userInterfaceStyle","type":"codeVoice"},{"type":"text","text":", or to account for display scale,"},{"type":"text","text":" "},{"type":"text","text":"size classes, and other environment traits."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Return "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" from the completion handler to keep the current placeholder"},{"type":"text","text":" "},{"type":"text","text":"presentation unchanged."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The asset delegate is inherited from "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","type":"reference","isActive":true},{"type":"text","text":" by default. To"},{"type":"text","text":" "},{"type":"text","text":"use a different delegate specifically for bookmarks, set it directly on the"},{"type":"text","text":" "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/BookmarksConfiguration\/assetDelegate","type":"reference","isActive":true},{"type":"text","text":" property."}],"type":"paragraph"},{"text":"Date Formatting","level":2,"anchor":"Date-Formatting","type":"heading"},{"inlineContent":[{"type":"text","text":"Edition dates are formatted through the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EditionDateFormatter"},{"type":"text","text":" protocol."},{"type":"text","text":" "},{"type":"text","text":"The SDK provides "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultEditionDateFormatter"},{"type":"text","text":", which wraps a standard"},{"type":"text","text":" "},{"type":"codeVoice","code":"DateFormatter"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["let dateFormatter = DefaultEditionDateFormatter(","    dateFormat: \"d MMMM yyyy\",","    timeZone: .current",")","globalConfig.dateFormatter = dateFormatter"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"If your publications use custom names instead of dates, implement","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EditionDateFormatter","type":"reference"},{"text":" to return the appropriate label for each edition.","type":"text"}],"type":"paragraph"},{"text":"Ribbon and Navigation Customization","level":2,"anchor":"Ribbon-and-Navigation-Customization","type":"heading"},{"inlineContent":[{"type":"text","text":"The carousel’s section and subsection ribbons are configurable via"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SectionRibbonConfiguration","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SubsectionRibbonConfiguration","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"code":["carouselConfig.sectionRibbon.layout = .fillEqually  \/\/ or .fitLeft, .fitCenter","carouselConfig.subsectionRibbon.alignment = .center  \/\/ or .left"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The reader navigation bar appearance is controlled through"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderNavigationBarConfiguration","isActive":true},{"type":"text","text":" on the "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","archiveConfig.readerConfig.navigationBar.titleLabel.color = .label"],"syntax":"swift","type":"codeListing"},{"text":"Content Browser","level":2,"anchor":"Content-Browser","type":"heading"},{"inlineContent":[{"text":"The reader’s content browser is the panel that lets users navigate between","type":"text"},{"text":" ","type":"text"},{"text":"sections, pages, and articles within an open edition. It is configured via","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderBrowserConfiguration","type":"reference"},{"text":", which provides independent control over fonts,","type":"text"},{"text":" ","type":"text"},{"text":"colors, and the Liquid Glass policy. Customize the browser without affecting","type":"text"},{"text":" ","type":"text"},{"text":"the rest of the reader by setting properties on","type":"text"},{"text":" ","type":"text"},{"code":"archiveConfig.readerConfig.browserConfig","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Legacy Replica Reader","level":2,"anchor":"Legacy-Replica-Reader","type":"heading"},{"inlineContent":[{"type":"text","text":"When using the legacy replica reader"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration\/useLegacyReplicaReader","isActive":true},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"type":"text","text":"), additional"},{"type":"text","text":" "},{"type":"text","text":"customization options are available through "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyReaderConfiguration","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"This includes navigation bar items, share templating, and legacy-specific"},{"type":"text","text":" "},{"type":"text","text":"icon overrides via "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyImageResourceName","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]}],"seeAlsoSections":[{"generated":true,"anchor":"Customization","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Standalone-View-Controllers","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Localization"],"title":"Customization"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/psreaderui\/theming-and-customization"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/psreaderui\/theming-and-customization"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"article","sections":[],"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Theming-and-Customization","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Adjust fonts, colors, icons, and layouts to match your app’s brand."}],"metadata":{"modules":[{"name":"PSReaderUI"}],"title":"Theming and Customization","roleHeading":"Article","role":"article"},"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/BookmarksConfiguration/assetDelegate":{"abstract":[{"text":"Delegate providing custom images used within the bookmarks view.","type":"text"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/BookmarksConfiguration\/assetDelegate","type":"topic","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"assetDelegate"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"AssetDelegate","preciseIdentifier":"s:10PSReaderUI13AssetDelegateP"}],"kind":"symbol","title":"assetDelegate","url":"\/documentation\/psreaderui\/bookmarksconfiguration\/assetdelegate","role":"symbol"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/LabelConfiguration":{"abstract":[{"type":"text","text":"Configuration object that specifies the appearance of "},{"type":"codeVoice","code":"UILabels"},{"type":"text","text":" used"},{"type":"text","text":" "},{"type":"text","text":"throughout the PSReaderUI SDK."}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"LabelConfiguration"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LabelConfiguration","title":"LabelConfiguration","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"LabelConfiguration"}],"url":"\/documentation\/psreaderui\/labelconfiguration","kind":"symbol","type":"topic"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/CarouselViewController":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"CarouselViewController"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","type":"topic","abstract":[{"type":"text","text":"The primary view controller provided by the SDK for presenting digital publication"},{"type":"text","text":" "},{"type":"text","text":"content through an intuitive carousel interface."}],"url":"\/documentation\/psreaderui\/carouselviewcontroller","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"CarouselViewController"}],"kind":"symbol","title":"CarouselViewController"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/SubsectionRibbonConfiguration":{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SubsectionRibbonConfiguration","kind":"symbol","role":"symbol","title":"SubsectionRibbonConfiguration","navigatorTitle":[{"kind":"identifier","text":"SubsectionRibbonConfiguration"}],"url":"\/documentation\/psreaderui\/subsectionribbonconfiguration","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SubsectionRibbonConfiguration"}],"type":"topic","abstract":[{"te