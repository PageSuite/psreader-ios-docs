ig)","archiveConfig.readerConfig.navigationBar.titleLabel.color = .label"],"type":"codeListing"},{"text":"Content Browser","type":"heading","level":2,"anchor":"Content-Browser"},{"type":"paragraph","inlineContent":[{"text":"The reader’s content browser is the panel that lets users navigate between","type":"text"},{"text":" ","type":"text"},{"text":"sections, pages, and articles within an open edition. It is configured via","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderBrowserConfiguration"},{"text":", which provides independent control over fonts,","type":"text"},{"text":" ","type":"text"},{"text":"colors, and the Liquid Glass policy. Customize the browser without affecting","type":"text"},{"text":" ","type":"text"},{"text":"the rest of the reader by setting properties on","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"archiveConfig.readerConfig.browserConfig"},{"text":".","type":"text"}]},{"text":"Legacy Replica Reader","type":"heading","level":2,"anchor":"Legacy-Replica-Reader"},{"type":"paragraph","inlineContent":[{"text":"When using the legacy replica reader","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration\/useLegacyReplicaReader","isActive":true},{"text":" is ","type":"text"},{"code":"true","type":"codeVoice"},{"text":"), additional","type":"text"},{"text":" ","type":"text"},{"text":"customization options are available through ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyReaderConfiguration","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"This includes navigation bar items, share templating, and legacy-specific","type":"text"},{"text":" ","type":"text"},{"text":"icon overrides via ","type":"