{"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"abstract":[{"type":"text","text":"Adjust fonts, colors, icons, and layouts to match your app’s brand."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/theming-and-customization"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/psreaderui\/theming-and-customization"]}],"sections":[],"metadata":{"roleHeading":"Article","title":"Theming and Customization","modules":[{"name":"PSReaderUI"}],"role":"article"},"seeAlsoSections":[{"title":"Customization","anchor":"Customization","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Standalone-View-Controllers","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Localization"],"generated":true}],"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Theming-and-Customization","interfaceLanguage":"swift"},"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"PSReaderUI is designed to be customized. The configuration system follows a","type":"text"},{"text":" ","type":"text"},{"text":"cascading hierarchy: ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","type":"reference","isActive":true},{"text":" supplies default values that flow","type":"text"},{"text":" ","type":"text"},{"text":"into ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselConfiguration","type":"reference","isActive":true},{"text":", ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","type":"reference","isActive":true},{"text":",","type":"text"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration","type":"reference"},{"type":"text","text":", and their sub-configurations. Override any value at"},{"type":"text","text":" "},{"type":"text","text":"any level to apply targeted changes."}]},{"text":"Configuration Hierarchy","anchor":"Configuration-Hierarchy","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you create a "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselConfiguration","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","type":"reference","isActive":true},{"type":"text","text":", pass"},{"type":"text","text":" "},{"type":"text","text":"your "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","type":"reference","isActive":true},{"type":"text","text":" to its initializer. The child configuration"},{"type":"text","text":" "},{"type":"text","text":"inherits the global fonts, brand color, delegates, and other settings. You"},{"type":"text","text":" "},{"type":"text","text":"can then override individual properties without affecting the rest:"}]},{"code":["let globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: apiKey,","    accountGUID: accountGUID,","    primaryFont: UIFont(name: \"Georgia\", size: 12)!,","    secondaryFont: .systemFont(ofSize: 12),","    brandColor: .systemBlue",")","","var carouselConfig = PSReaderUI.CarouselConfiguration(globalConfig: globalConfig)","carouselConfig.sectionRibbon.layout = .fillEqually","\/\/ brandColor, fonts, etc. are inherited from globalConfig"],"syntax":"swift","type":"codeListing"},{"text":"Fonts","anchor":"Fonts","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Two font families control the SDK’s typography:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":"primaryFont","type":"codeVoice"}],"type":"strong"},{"type":"text","text":" — used for titles, headlines, publication names, and other"},{"type":"text","text":" "},{"type":"text","text":"prominent text. Set on "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration\/primaryFont"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":"secondaryFont","type":"codeVoice"}]},{"type":"text","text":" — used for labels, dates, captions, and secondary UI"},{"type":"text","text":" "},{"type":"text","text":"elements. Set on "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration\/secondaryFont","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Individual components expose "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LabelConfiguration","isActive":true,"type":"reference"},{"type":"text","text":" properties that let you"},{"type":"text","text":" "},{"type":"text","text":"override the font, point size, and color for specific labels without changing"},{"type":"text","text":" "},{"type":"text","text":"the global fonts:"}]},{"code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","archiveConfig.editionNameLabel = LabelConfiguration(","    font: UIFont(name: \"Georgia-Bold\", size: 14)!,","    pointSize: 14,","    color: .label",")"],"syntax":"swift","type":"codeListing"},{"text":"Brand Color","anchor":"Brand-Color","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration\/brandColor","type":"reference","isActive":true},{"type":"text","text":" is used as an accent color throughout"},{"type":"text","text":" "},{"type":"text","text":"the SDK — in selection states, progress indicators, and interactive elements."}]},{"type":"paragraph","inlineContent":[{"text":"To support both light and dark appearances, provide a dynamic color:","type":"text"}]},{"code":["let brandColor = UIColor(dynamicProvider: {","    $0.userInterfaceStyle == .dark ? .white : .black","})"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Or define the color in your asset catalog for automatic trait resolution.","type":"text"}]},{"text":"Thumbnail Content Mode","anchor":"Thumbnail-Content-Mode","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode","isActive":true},{"type":"text","text":" enum controls how edition thumbnails are sized and"},{"type":"text","text":" "},{"type":"text","text":"positioned within their containers across archive, bookmarks, downloads, and"},{"type":"text","text":" "},{"type":"text","text":"splash screens. This is one of the most impactful visual customization points"},{"type":"text","text":" "},{"type":"text","text":"— it determines the layout feel of your archive grid."}]},{"type":"paragraph","inlineContent":[{"text":"There are three modes:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode\/fitToWidth","type":"reference","isActive":true}],"type":"strong"},{"text":" — the image fills the container’s width","type":"text"},{"text":" ","type":"text"},{"text":"and is cropped vertically if the aspect ratio differs. This is the default","type":"text"},{"text":" ","type":"text"},{"text":"for archives, bookmarks, and downloads.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode\/fitToHeight"}],"type":"strong"},{"type":"text","text":" — the image fills the container’s"},{"type":"text","text":" "},{"type":"text","text":"height and is cropped horizontally if needed. This is the default for the"},{"type":"text","text":" "},{"type":"text","text":"reader splash screen."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode\/flexibleHeight(estimatedAspectRatio:)","isActive":true,"type":"reference"}],"type":"strong"},{"text":" — the image","type":"text"},{"text":" ","type":"text"},{"text":"fills the container’s width while the cell height adjusts dynamically to","type":"text"},{"text":" ","type":"text"},{"text":"preserve the image’s natural aspect ratio. Provide an ","type":"text"},{"type":"codeVoice","code":"estimatedAspectRatio"},{"text":" ","type":"text"},{"text":"to stabilize layout during loading; the SDK refines it automatically once","type":"text"},{"text":" ","type":"text"},{"text":"images arrive.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set the content mode on any configuration that displays thumbnails:"}]},{"code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","","\/\/ Fixed-height cells that crop vertically (default)","archiveConfig.thumbnailContentMode = .fitToWidth","","\/\/ Dynamic-height cells that show the full image","archiveConfig.thumbnailContentMode = .flexibleHeight(estimatedAspectRatio: 0.75)"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Pair the content mode with "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration\/cellAspectRatio"},{"type":"text","text":" (or the"},{"type":"text","text":" "},{"type":"text","text":"equivalent "},{"type":"codeVoice","code":"aspectRatio"},{"type":"text","text":" on "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/BookmarksConfiguration"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DownloadsConfiguration"},{"text":") to fine-tune the grid dimensions.","type":"text"}]},{"style":"note","name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode\/flexibleHeight(estimatedAspectRatio:)"},{"text":" is not","type":"text"},{"text":" ","type":"text"},{"text":"supported in the bookmarks or downloads views.","type":"text"}]}]},{"text":"Dark Mode","anchor":"Dark-Mode","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK respects the system appearance by default. To force a specific style"},{"type":"text","text":" "},{"type":"text","text":"across the entire SDK, set "},{"code":"overrideUserInterfaceStyle","type":"codeVoice"},{"type":"text","text":" on the"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","type":"reference"},{"type":"text","text":":"}]},{"code":["carouselVC.overrideUserInterfaceStyle = .dark"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This propagates to all child view controllers, including the reader, archive,"},{"type":"text","text":" "},{"type":"text","text":"bookmarks, and downloads views."}]},{"text":"Liquid Glass (iOS 26+)","anchor":"Liquid-Glass-iOS-26+","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"On iOS 26 and later, the SDK adopts the Liquid Glass design language by","type":"text"},{"text":" ","type":"text"},{"text":"default. The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LiquidGlassPolicy","type":"reference"},{"text":" enum controls this behavior:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":".automatic"}],"type":"strong"},{"type":"text","text":" (default) — uses Liquid Glass on iOS 26+ when supported."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":".disabled"}]},{"type":"text","text":" — uses the standard appearance on all OS versions."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set the policy globally or on specific configuration objects for granular"},{"type":"text","text":" "},{"type":"text","text":"control:"}]},{"code":["\/\/ Disable globally","globalConfig.liquidGlassPolicy = .disabled","","\/\/ Or disable only on the subsection ribbon","carouselConfig.subsectionRibbon.liquidGlassPolicy = .disabled"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK also respects the host app’s "},{"type":"codeVoice","code":"UIDesignRequiresCompatibility"},{"type":"text","text":" "},{"type":"text","text":"Info.plist key and will fall back automatically when set."}]},{"text":"Custom Icons","anchor":"Custom-Icons","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement "},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AssetDelegate","type":"reference"},{"type":"text","text":" to replace any of the SDK’s built-in icons with"},{"type":"text","text":" "},{"type":"text","text":"your own images. See the "},{"isActive"