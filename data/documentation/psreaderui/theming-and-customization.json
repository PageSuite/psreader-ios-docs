{"kind":"article","sections":[],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"PSReaderUI is designed to be customized. The configuration system follows a","type":"text"},{"text":" ","type":"text"},{"text":"cascading hierarchy: ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","type":"reference"},{"text":" supplies default values that flow","type":"text"},{"text":" ","type":"text"},{"text":"into ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselConfiguration","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration","isActive":true,"type":"reference"},{"text":", and their sub-configurations. Override any value at","type":"text"},{"text":" ","type":"text"},{"text":"any level to apply targeted changes.","type":"text"}]},{"type":"heading","level":2,"text":"Configuration Hierarchy","anchor":"Configuration-Hierarchy"},{"type":"paragraph","inlineContent":[{"text":"When you create a ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselConfiguration","isActive":true,"type":"reference"},{"text":" or ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","isActive":true,"type":"reference"},{"text":", pass","type":"text"},{"text":" ","type":"text"},{"text":"your ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","isActive":true,"type":"reference"},{"text":" to its initializer. The child configuration","type":"text"},{"text":" ","type":"text"},{"text":"inherits the global fonts, brand color, delegates, and other settings. You","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can then override individual properties without affecting the rest:"}]},{"type":"codeListing","syntax":"swift","code":["let globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: apiKey,","    accountGUID: accountGUID,","    primaryFont: UIFont(name: \"Georgia\", size: 12)!,","    secondaryFont: .systemFont(ofSize: 12),","    brandColor: .systemBlue",")","","var carouselConfig = PSReaderUI.CarouselConfiguration(globalConfig: globalConfig)","carouselConfig.sectionRibbon.layout = .fillEqually","\/\/ brandColor, fonts, etc. are inherited from globalConfig"]},{"type":"heading","level":2,"text":"Fonts","anchor":"Fonts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Two font families control the SDK’s typography:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"primaryFont"}],"type":"strong"},{"text":" — used for titles, headlines, publication names, and other","type":"text"},{"text":" ","type":"text"},{"text":"prominent text. Set on ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration\/primaryFont","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":"secondaryFont","type":"codeVoice"}]},{"text":" — used for labels, dates, captions, and secondary UI","type":"text"},{"text":" ","type":"text"},{"text":"elements. Set on ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration\/secondaryFont","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Individual components expose "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LabelConfiguration","isActive":true},{"type":"text","text":" properties that let you"},{"type":"text","text":" "},{"type":"text","text":"override the font, point size, and color for specific labels without changing"},{"type":"text","text":" "},{"type":"text","text":"the global fonts:"}]},{"type":"codeListing","syntax":"swift","code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","archiveConfig.editionNameLabel = LabelConfiguration(","    font: UIFont(name: \"Georgia-Bold\", size: 14)!,","    pointSize: 14,","    color: .label",")"]},{"type":"heading","level":2,"text":"Brand Color","anchor":"Brand-Color"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration\/brandColor","isActive":true,"type":"reference"},{"text":" is used as an accent color throughout","type":"text"},{"text":" ","type":"text"},{"text":"the SDK — in selection states, progress indicators, and interactive elements.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To support both light and dark appearances, provide a dynamic color:"}]},{"type":"codeListing","code":["let brandColor = UIColor(dynamicProvider: {","    $0.userInterfaceStyle == .dark ? .white : .black","})"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Or define the color in your asset catalog for automatic trait resolution.","type":"text"}]},{"anchor":"Thumbnail-Content-Mode","type":"heading","level":2,"text":"Thumbnail Content Mode"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode"},{"type":"text","text":" enum controls how edition thumbnails are sized and"},{"type":"text","text":" "},{"type":"text","text":"positioned within their containers across archive, bookmarks, downloads, and"},{"type":"text","text":" "},{"type":"text","text":"splash screens. This is one of the most impactful visual customization points"},{"type":"text","text":" "},{"type":"text","text":"— it determines the layout feel of your archive grid."}]},{"type":"paragraph","inlineContent":[{"text":"There are three modes:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode\/fitToWidth","isActive":true,"type":"reference"}],"type":"strong"},{"type":"text","text":" — the image fills the container’s width"},{"type":"text","text":" "},{"type":"text","text":"and is cropped vertically if the aspect ratio differs. This is the default"},{"type":"text","text":" "},{"type":"text","text":"for archives, bookmarks, and downloads."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode\/fitToHeight"}]},{"type":"text","text":" — the image fills the container’s"},{"type":"text","text":" "},{"type":"text","text":"height and is cropped horizontally if needed. This is the default for the"},{"type":"text","text":" "},{"type":"text","text":"reader splash screen."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode\/flexibleHeight(estimatedAspectRatio:)"}]},{"type":"text","text":" — the image"},{"type":"text","text":" "},{"type":"text","text":"fills the container’s width while the cell height adjusts dynamically to"},{"type":"text","text":" "},{"type":"text","text":"preserve the image’s natural aspect ratio. Provide an "},{"type":"codeVoice","code":"estimatedAspectRatio"},{"type":"text","text":" "},{"type":"text","text":"to stabilize layout during loading; the SDK refines it automatically once"},{"type":"text","text":" "},{"type":"text","text":"images arrive."}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Set the content mode on any configuration that displays thumbnails:"}],"type":"paragraph"},{"type":"codeListing","code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","","\/\/ Fixed-height cells that crop vertically (default)","archiveConfig.thumbnailContentMode = .fitToWidth","","\/\/ Dynamic-height cells that show the full image","archiveConfig.thumbnailContentMode = .flexibleHeight(estimatedAspectRatio: 0.75)"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Pair the content mode with "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration\/cellAspectRatio","isActive":true},{"type":"text","text":" (or the"},{"type":"text","text":" "},{"type":"text","text":"equivalent "},{"type":"codeVoice","code":"aspectRatio"},{"type":"text","text":" on "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/BookmarksConfiguration","isActive":true},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DownloadsConfiguration","isActive":true},{"text":") to fine-tune the grid dimensions.","type":"text"}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":""},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageContentMode\/flexibleHeight(estimatedAspectRatio:)"},{"type":"text","text":" is not"},{"type":"text","text":" "},{"type":"text","text":"supported in the bookmarks or downloads views."}],"type":"paragraph"}],"type":"aside"},{"level":2,"anchor":"Dark-Mode","type":"heading","text":"Dark Mode"},{"inlineContent":[{"text":"The SDK respects the system appearance by default. To force a specific style","type":"text"},{"text":" ","type":"text"},{"text":"across the entire SDK, set ","type":"text"},{"type":"codeVoice","code":"overrideUserInterfaceStyle"},{"text":" on the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","type":"reference","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["carouselVC.overrideUserInterfaceStyle = .dark"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This propagates to all child view controllers, including the reader, archive,"},{"type":"text","text":" "},{"type":"text","text":"bookmarks, and downloads views."}],"type":"paragraph"},{"level":2,"anchor":"Liquid-Glass-iOS-26+","type":"heading","text":"Liquid Glass (iOS 26+)"},{"inlineContent":[{"text":"On iOS 26 and later, the SDK adopts the Liquid Glass design language by","type":"text"},{"text":" ","type":"text"},{"text":"default. The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LiquidGlassPolicy"},{"text":" enum controls this behavior:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":".automatic","type":"codeVoice"}]},{"text":" (default) — uses Liquid Glass on iOS 26+ when supported.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":".disabled","type":"codeVoice"}],"type":"strong"},{"text":" — uses the standard appearance on all OS versions.","type":"text"}]}]}]},{"inlineContent":[{"text":"Set the policy globally or on specific configuration objects for granular","type":"text"},{"text":" ","type":"text"},{"text":"control:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Disable globally","globalConfig.liquidGlassPolicy = .disabled","","\/\/ Or disable only on the subsection ribbon","carouselConfig.subsectionRibbon.liquidGlassPolicy = .disabled"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The SDK also respects the host app’s "},{"type":"codeVoice","code":"UIDesignRequiresCompatibility"},{"type":"text","text":" "},{"type":"text","text":"Info.plist key and will fall back automatically when set."}],"type":"paragraph"},{"level":2,"anchor":"Custom-Icons","type":"heading","text":"Custom Icons"},{"inlineContent":[{"type":"text","text":"Implement "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AssetDelegate"},{"type":"text","text":" to replace any of the SDK’s built-in icons with"},{"type":"text","text":" "},{"type":"text","text":"your own images. See the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ImageResourceName"},{"type":"text","text":" symbol page for the full list"},{"type":"text","text":" "},{"type":"text","text":"of icon identifiers and their usage context."}],"type":"paragraph"},{"syntax":"swift","code":["struct MyAssetDelegate: PSReaderUI.AssetDelegate {","    func imageResource(for name: ImageResourceName) -> UIImage? {","        switch name {","        case .share:","            return UIImage(named: \"my-share-icon\")","        default:","            return name.defaultImage()","        }","    }","}","","globalConfig.assetDelegate = MyAssetDelegate()"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"For the legacy replica reader, override"},{"type":"text","text":" "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AssetDelegate\/legacyImageResource(for:)","isActive":true,"type":"reference"},{"type":"text","text":" using "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyImageResourceName","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"identifiers."}],"type":"paragraph"},{"level":2,"anchor":"Placeholder-Images","type":"heading","text":"Placeholder Images"},{"inlineContent":[{"type":"text","text":"The SDK can use placeholder images when a thumbnail is unavailable — for"},{"type":"text","text":" "},{"type":"text","text":"example, when an article has no associated image or a thumbnail fails to load."},{"type":"text","text":" "},{"type":"text","text":"By default the SDK shows a solid skeleton view (a grey box that adapts to"},{"type":"text","text":" "},{"type":"text","text":"light and dark mode). Implement"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/AssetDelegate\/placeholderImage(size:with:completion:)","isActive":true},{"type":"text","text":" to provide a custom"},{"type":"text","text":" "},{"type":"text","text":"placeholder instead:"}],"type":"paragraph"},{"syntax":"swift","code":["struct MyAssetDelegate: PSReaderUI.AssetDelegate {","    func placeholderImage(","        size: CGSize,","        with traits: UITraitCollection,","        completion: @escaping (UIImage?) -> Void","    ) {","        let name = traits.userInterfaceStyle == .dark","            ? \"placeholder-dark\"","            : \"placeholder-light\"","","        let image = UIImage(named: name)","        completion(image)","    }","}","","globalConfig.assetDelegate = MyAssetDelegate()"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"size"},{"type":"text","text":" parameter reflects the thumbnail container’s dimensions, which you"},{"type":"text","text":" "},{"type":"text","text":"can use to select or generate an appropriately sized image. The "},{"type":"codeVoice","code":"traits"},{"type":"text","text":" "},{"type":"text","text":"parameter carries the current "},{"type":"codeVoice","code":"UITraitCollection"},{"type":"text","text":" — use it to adapt to"},{"type":"text","text":" "},{"type":"text","text":"light or dark mode via "},{"type":"codeVoice","code":"userInterfaceStyle"},{"type":"text","text":", or to account for display scale,"},{"type":"text","text":" "},{"type":"text","text":"size classes, and other environment traits."}],"type":"paragraph"},{"inlineContent":[{"text":"Return ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" from the completion handler to keep the current placeholder","type":"text"},{"text":" ","type":"text"},{"text":"presentation unchanged.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The asset delegate is inherited from "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","isActive":true},{"type":"text","text":" by default. To"},{"type":"text","text":" "},{"type":"text","text":"use a different delegate specifically for bookmarks, set it directly on the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/BookmarksConfiguration\/assetDelegate","isActive":true},{"type":"text","text":" property."}],"type":"paragraph"},{"level":2,"anchor":"Date-Formatting","type":"heading","text":"Date Formatting"},{"inlineContent":[{"type":"text","text":"Edition dates are formatted through the "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EditionDateFormatter","isActive":true},{"type":"text","text":" protocol."},{"type":"text","text":" "},{"type":"text","text":"The SDK provides "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DefaultEditionDateFormatter","isActive":true},{"type":"text","text":", which wraps a standard"},{"type":"text","text":" "},{"code":"DateFormatter","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["let dateFormatter = DefaultEditionDateFormatter(","    dateFormat: \"d MMMM yyyy\",","    timeZone: .current",")","globalConfig.dateFormatter = dateFormatter"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"If your publications use custom names instead of dates, implement"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/EditionDateFormatter"},{"type":"text","text":" to return the appropriate label for each edition."}],"type":"paragraph"},{"level":2,"anchor":"Ribbon-and-Navigation-Customization","type":"heading","text":"Ribbon and Navigation Customization"},{"inlineContent":[{"text":"The carousel’s section and subsection ribbons are configurable via","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SectionRibbonConfiguration","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SubsectionRibbonConfiguration","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["carouselConfig.sectionRibbon.layout = .fillEqually  \/\/ or .fitLeft, .fitCenter","carouselConfig.subsectionRibbon.alignment = .center  \/\/ or .left"],"type":"codeListing"},{"inlineContent":[{"text":"The reader navigation bar appearance is controlled through","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderNavigationBarConfiguration","type":"reference"},{"text":" on the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration","type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","archiveConfig.readerConfig.navigationBar.titleLabel.color = .label"],"type":"codeListing"},{"level":2,"anchor":"Content-Browser","type":"heading","text":"Content Browser"},{"inlineContent":[{"text":"The reader’s content browser is the panel that lets users navigate between","type":"text"},{"text":" ","type":"text"},{"text":"sections, pages, and articles within an open edition. It is configured via","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderBrowserConfiguration"},{"text":", which provides independent control over fonts,","type":"text"},{"text":" ","type":"text"},{"text":"colors, and the Liquid Glass policy. Customize the browser without affecting","type":"text"},{"text":" ","type":"text"},{"text":"the rest of the reader by setting properties on","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"archiveConfig.readerConfig.browserConfig"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Legacy-Replica-Reader","type":"heading","text":"Legacy Replica Reader"},{"inlineContent":[{"text":"When using the legacy replica reader","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration\/useLegacyReplicaReader","type":"reference","isActive":true},{"text":" is ","type":"text"},{"code":"true","type":"codeVoice"},{"text":"), additional","type":"text"},{"text":" ","type":"text"},{"text":"customization options are available through ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyReaderConfiguration","type":"reference","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"This includes navigation bar items, share templating, and legacy-specific","type":"text"},{"text":" ","type":"text"},{"text":"icon overrides via ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyImageResourceName","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Theming-and-Customization"},"metadata":{"role":"article","modules":[{"name":"PSReaderUI"}],"roleHeading":"Article","title":"Theming and Customization"},"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"variants":[{"paths":["\/documentation\/psreaderui\/theming-and-customization"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/psreaderui\/theming-and-customization"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"type":"text","text":"Adjust fonts, colors, icons, and layouts to match your app’s brand."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Standalone-View-Controllers","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Localization"],"anchor":"Customization","title":"Customization"}],"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/ReaderBrowserConfiguration":{"title":"ReaderBrowserConfiguration","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ReaderBrowserConfiguration","kind":"identifier"}],"navigatorTitle":[{"text":"ReaderBrowserConfiguration","kind":"identifier"}],"role":"symbol","url":"\/documentation\/psreaderui\/readerbrowserconfiguration","abstract":[{"type":"text","text":"Configuration object used to customize the appearance of the reader content browser."}],"type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderBrowserConfiguration","kind":"symbol"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/GlobalConfiguration/brandColor":{"role":"symbol","type":"topic","kind":"symbol","title":"brandColor","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration\/brandColor","abstract":[{"type":"text","text":"The primary brand \/ accent color used throughout the SDK’s interface."}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"brandColor","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:objc(cs)UIColor","text":"UIColor","kind":"typeIdentifier"}],"url":"\/documentation\/psreaderui\/globalconfiguration\/brandcolor"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/GlobalConfiguration/secondaryFont":{"type":"topic","role":"symbol","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration\/secondaryFont","kind":"symbol","title":"secondaryFont","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"secondaryFont","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UIFont","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)UIFont"}],"abstract":[{"text":"The secondary font used throughout the SDK’s UI. This is used for general UI labels.","type":"text"}],"url":"\/documentation\/psreaderui\/globalconfiguration\/secondaryfont"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/DownloadsConfiguration":{"kind":"symbol","url":"\/documentation\/psreaderui\/downloadsconfiguration","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"DownloadsConfiguration"}],"role":"symbol","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/DownloadsConfiguration","title":"DownloadsConfiguration","abstract":[{"type":"text","text":"Configuration for customizing the appearance and behavior of download archives."}],"navigatorTitle":[{"kind":"identifier","text":"DownloadsConfiguration"}],"type":"topic"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/CarouselViewController":{"url":"\/document