{"seeAlsoSections":[{"generated":true,"anchor":"Features","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Deep-Linking","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Commenting","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Search"],"title":"Features"}],"metadata":{"role":"article","modules":[{"name":"PSReaderUI"}],"roleHeading":"Article","title":"Paywall Integration"},"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration"},"abstract":[{"type":"text","text":"Restrict access to premium content with custom paywall screens."}],"kind":"article","primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default the PSReaderUI SDK does "},{"type":"strong","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" restrict access to any content."},{"type":"text","text":" "},{"type":"text","text":"Paywalls are entirely opt-in: you implement the "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallDelegate","isActive":true},{"type":"text","text":" protocol,"},{"type":"text","text":" "},{"type":"text","text":"provide view controllers that conform to "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","isActive":true},{"type":"text","text":", and assign"},{"type":"text","text":" "},{"type":"text","text":"the delegate to your "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","isActive":true},{"type":"text","text":"."}]},{"type":"heading","anchor":"How-It-Works","text":"How It Works","level":2},{"type":"paragraph","inlineContent":[{"text":"When a user attempts to open an edition, download an edition, or tap a search","type":"text"},{"text":" ","type":"text"},{"text":"result, the SDK consults a paywall delegate. When the SDK finds a delegate, the flow is:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"User taps an edition to open or download it.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The SDK calls the relevant ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallDelegate","isActive":true,"type":"reference"},{"text":" method.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Your delegate returns a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController"},{"text":" (or ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" to skip the paywall).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The SDK sets the ","type":"text"},{"type":"codeVoice","code":"onDismiss"},{"text":" closure on your view controller and presents it ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"modally"}]},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"When the user finishes, your view controller calls ","type":"text"},{"code":"onDismiss(true)","type":"codeVoice"},{"text":" to","type":"text"},{"text":" ","type":"text"},{"text":"grant access or ","type":"text"},{"code":"onDismiss(false)","type":"codeVoice"},{"text":" to deny it.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"The SDK dismisses your view controller automatically — ","type":"text"},{"inlineContent":[{"type":"text","text":"do not"}],"type":"strong"},{"text":" dismiss it yourself.","type":"text"}],"type":"paragraph"}]}]},{"type":"aside","style":"important","name":"Important","content":[{"inlineContent":[{"text":"The SDK owns the presentation and dismissal lifecycle. Do not call","type":"text"},{"text":" ","type":"text"},{"code":"dismiss(animated:)","type":"codeVoice"},{"text":" on the paywall view controller or its presenting","type":"text"},{"text":" ","type":"text"},{"text":"controller. Doing so may leave the SDK in an inconsistent state.","type":"text"}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"text":"The delegate methods receive different model objects depending on the edition","type":"text"},{"text":" ","type":"text"},{"text":"type. Knowing their properties helps you make informed paywall decisions.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"PSEdition"},{"type":"text","text":" represents a replica (PDF) edition."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"PSEPublished"},{"type":"text","text":" represents a feed edition."}]}]}]},{"type":"heading","anchor":"Creating-a-PaywallViewController","text":"Creating a PaywallViewController","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Your paywall screen must conform to "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","isActive":true},{"type":"text","text":". The protocol"},{"type":"text","text":" "},{"type":"text","text":"requires a single property:"}]},{"type":"codeListing","syntax":"swift","code":["import PSReaderUI","","class MyPaywallScreen: UIViewController, PSReaderUI.PaywallViewController {","    var onDismiss: ((Bool) -> Void)?","","    \/\/ Build your paywall UI...","","    @objc func userDidSubscribe() {","        onDismiss?(true) \/\/ Grant access","    }","","    @objc func userDidCancel() {","        onDismiss?(false) \/\/ Deny access","    }","}"]},{"type":"aside","style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"Call ","type":"text"},{"code":"onDismiss","type":"codeVoice"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"exactly once"}],"type":"strong"},{"text":" when the user completes or","type":"text"},{"text":" ","type":"text"},{"text":"cancels the paywall flow. If you never call ","type":"text"},{"code":"onDismiss","type":"codeVoice"},{"text":", the paywall remains","type":"text"},{"text":" ","type":"text"},{"text":"on screen indefinitely. Calling it more than once may cause unexpected","type":"text"},{"text":" ","type":"text"},{"text":"behavior.","type":"text"}]}]},{"type":"heading","anchor":"Implementing-PaywallDelegate","text":"Implementing PaywallDelegate","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The delegate has five methods — two for opening editions, two for downloading"},{"type":"text","text":" "},{"type":"text","text":"them, and one for search results:"}]},{"type":"codeListing","syntax":"swift","code":["struct MyPaywallDelegate: PSReaderUI.PaywallDelegate {","","    func paywallViewControllerForAction(","        openReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        return MyPaywallScreen()","    }","","    func paywallViewControllerForAction(","        openFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        return MyPaywallScreen()","    }","","    func paywallViewControllerForAction(","        downloadReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        \/\/ Default implementation delegates to openReplicaEdition.","        return paywallViewControllerForAction(openReplicaEdition: edition)","    }","","    func paywallViewControllerForAction(","        downloadFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        \/\/ Default implementation delegates to openFeedEdition.","        return paywallViewControllerForAction(openFeedEdition: published)","    }","","    func paywallViewControllerForAction(","        openSearchResult result: SearchResult","    ) -> PaywallViewController? {","        \/\/ Default implementation returns nil (no paywall).","        return nil","    }","}"]},{"type":"aside","style":"tip","name":"Tip","content":[{"inlineContent":[{"text":"The download methods have default implementations that delegate to the","type":"text"},{"text":" ","type":"text"},{"text":"corresponding open methods, and the search result method defaults to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"You only need to override them if your paywall logic differs.","type":"text"}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that separate methods exist for replica and feed editions. See"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions"},{"type":"text","text":" for background on the two systems."}]},{"type":"heading","anchor":"Conditional-Paywalls","text":"Conditional Paywalls","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Return "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" from any delegate method to skip the paywall for that edition."},{"type":"text","text":" "},{"type":"text","text":"This lets you implement conditional access logic:"}]},{"type":"codeListing","syntax":"swift","code":["struct MyPaywallDelegate: PSReaderUI.PaywallDelegate {","","    let userIsSubscribed: Bool","","    func paywallViewControllerForAction(","        openFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        \/\/ No paywall for subscribers","        if userIsSubscribed { return nil }","","        \/\/ No paywall for supplements","        if published.isSupplement { return nil }","","        return MyPaywallScreen()","    }","","    func paywallViewControllerForAction(","        openReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        if userIsSubscribed { return nil }","        return MyPaywallScreen()","    }","}"]},{"type":"heading","anchor":"Assigning-the-Delegate","text":"Assigning the Delegate","level":2},{"type":"heading","anchor":"Global-Level","text":"Global Level","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set the delegate on your "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration"},{"type":"text","text":" to apply it across the entire"},{"type":"text","text":" "},{"type":"text","text":"SDK. For most use cases, this is all you need."}]},{"type":"codeListing","syntax":"swift","code":["var globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: apiKey,","    accountGUID: accountGUID",")","globalConfig.paywallDelegate = MyPaywallDelegate()"]},{"type":"heading","anchor":"Carousel-Level","text":"Carousel Level","level":3},{"type":"paragraph","inlineContent":[{"text":"Set the delegate on a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselConfiguration"},{"text":" to override the global delegate","type":"text"},{"text":" ","type":"text"},{"text":"for all sections within a specific carousel:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["var carouselConfig = PSReaderUI.CarouselConfiguration(globalConfig: globalConfig)","carouselConfig.paywallDelegate = MyCarouselPaywallDelegate()"]},{"type":"heading","anchor":"Per-Section-Level","text":"Per-Section Level","level":3},{"type":"paragraph","inlineContent":[{"text":"Set the delegate on an ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","isActive":true,"type":"reference"},{"text":" to override the paywall for a","type":"text"},{"text":" ","type":"text"},{"text":"single section. This is useful when different publications within the same","type":"text"},{"text":" ","type":"text"},{"text":"carousel have different access rules:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["var premiumArchiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","premiumArchiveConfig.paywallDelegate = PremiumPaywallDelegate()","","let sections: [PSReaderUI.CarouselViewController.SectionItem] = [","    \/\/ This section uses the per-section paywall","    .section(.init(","        name: \"Premium\",","        type: .feedArchive(guid: \"PREMIUM_GUID\", config: premiumArchiveConfig)","    )),","    \/\/ This section falls back to the global or carousel paywall","    .section(.init(","        name: \"Free\",","        type: .feedArchive(guid: \"FREE_GUID\")","    ))","]"]},{"type":"heading","anchor":"Search-Result-Paywalls","text":"Search Result Paywalls","level":2},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"openSearchResult","type":"codeVoice"},{"text":" method is called when a user taps a search result. By","type":"text"},{"text":" ","type":"text"},{"text":"default it returns ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", meaning search results open without a paywall.","type":"text"},{"text":" ","type":"text"},{"text":"Override it to restrict access:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["func paywallViewControllerForAction(","    openSearchResult result: SearchResult",") -> PaywallViewController? {","    guard !subscriptionManager.isSubscribed else { return nil }","    return SubscriptionPaywall()","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchResult","isActive":true},{"type":"text","text":" provides "},{"code":"editionId","type":"codeVoice"},{"type":"text","text":", "},{"code":"publicationId","type":"codeVoice"},{"type":"text","text":", and"},{"type":"text","text":" "},{"code":"applicationId","type":"codeVoice"},{"type":"text","text":" properties that you can use to make per-publication or"},{"type":"text","text":" "},{"type":"text","text":"per-edition access decisions."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Search","isActive":true},{"type":"text","text":" for the full search integration guide."}]},{"type":"heading","anchor":"Open-vs-Download-Paywalls","text":"Open vs Download Paywalls","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"In most cases the same paywall applies to both actions. However, some"},{"type":"text","text":" "},{"type":"text","text":"publishers may want to allow free streaming while requiring a subscription to"},{"type":"text","text":" "},{"type":"text","text":"download."}]},{"type":"paragraph","inlineContent":[{"text":"The download delegate methods have default implementations that call through to","type":"text"},{"text":" ","type":"text"},{"text":"the corresponding open methods. Override them to differentiate:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct StreamingPaywallDelegate: PSReaderUI.PaywallDelegate {","","    func paywallViewControllerForAction(","        openReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        \/\/ Free to open and read (streaming)","        return nil","    }","","    func paywallViewControllerForAction(","        openFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        return nil","    }","","    func paywallViewControllerForAction(","        downloadReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        \/\/ Require subscription for offline downloads","        return MyPaywallScreen()","    }","","    func paywallViewControllerForAction(","        downloadFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        return MyPaywallScreen()","    }","}"]},{"type":"heading","anchor":"Troubleshooting","text":"Troubleshooting","level":2},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Paywall never dismisses"}],"type":"strong"},{"text":" ","type":"text"},{"text":"Your ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","type":"reference","isActive":true},{"text":" must call ","type":"text"},{"type":"codeVoice","code":"onDismiss"},{"text":" at some point. If the user","type":"text"},{"text":" ","type":"text"},{"text":"cancels, call ","type":"text"},{"type":"codeVoice","code":"onDismiss(false)"},{"text":". If you never invoke the closure, the SDK has","type":"text"},{"text":" ","type":"text"},{"text":"no signal to dismiss the view controller and it remains on screen.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Wrong paywall appears for a section","type":"text"}]},{"text":" ","type":"text"},{"text":"Check the delegate cascade. A per-section delegate on ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","isActive":true},{"text":" ","type":"text"},{"text":"takes priority over the carousel and global delegates. Verify which level your","type":"text"},{"text":" ","type":"text"},{"text":"delegate is assigned to and whether a more specific override exists.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Download always shows a paywall even though open is free","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"text":"The default download methods delegate to the open methods. If your open method","type":"text"},{"text":" ","type":"text"},{"text":"returns ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" but downloads still show a paywall, you may have a separate","type":"text"},{"text":" ","type":"text"},{"text":"delegate assigned at a different cascade level that overrides the download","type":"text"},{"text":" ","type":"text"},{"text":"methods. Check all three levels.","type":"text"}]},{"type":"heading","anchor":"Complete-Example","text":"Complete Example","level":2},{"type":"paragraph","inlineContent":[{"text":"An end-to-end integration tying everything together:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import PSReaderUI","","\/\/ 1. Create a paywall view controller","class SubscriptionPaywall: UIViewController, PSReaderUI.PaywallViewController {","    var onDismiss: ((Bool) -> Void)?","","    override func viewDidLoad() {","        super.viewDidLoad()","        \/\/ Set up your subscription UI...","    }","","    @objc func subscribe() {","        \/\/ Handle subscription logic, then grant access","        onDismiss?(true)","    }","","    @objc func cancel() {","        onDismiss?(false)","    }","}","","\/\/ 2. Implement the delegate","struct AppPaywallDelegate: PSReaderUI.PaywallDelegate {","","    let subscriptionManager: SubscriptionManager","","    func paywallViewControllerForAction(","        openReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        guard !subscriptionManager.isSubscribed else { return nil }","        return SubscriptionPaywall()","    }","","    func paywallViewControllerForAction(","        openFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        guard !subscriptionManager.isSubscribed else { return nil }","        if published.isSupplement { return nil }","        return SubscriptionPaywall()","    }","}","","\/\/ 3. Assign to the global configuration","var globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: \"YOUR_API_KEY\",","    accountGUID: \"YOUR_ACCOUNT_GUID\"",")","globalConfig.paywallDelegate = AppPaywallDelegate(","    subscriptionManager: mySubscriptionManager",")","","\/\/ 4. Create and present the carousel","let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    sections: [","        .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\")","    ]",")"]}]}],"sections":[],"variants":[{"paths":["\/documentation\/psreaderui\/paywall-integration"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/psreaderui\/paywall-integration"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/PaywallDelegate":{"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"PaywallDelegate"}],"role":"symbol","url":"\/documentation\/psreaderui\/paywalldelegate","abstract":[{"text":"A delegate protocol used to provide paywall view controllers for controlling","type":"text"},{"text":" ","type":"text"},{"text":"access to premium content within the SDK.","type":"text"}],"title":"PaywallDelegate","navigatorTitle":[{"kind":"identifier","text":"PaywallDelegate"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallDelegate","kind":"symbol","type":"topic"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/PaywallViewController":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"PaywallViewController"}],"title":"PaywallViewController","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"PaywallViewController"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","url":"\/documentati