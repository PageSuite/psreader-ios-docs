{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration"},"sections":[],"variants":[{"paths":["\/documentation\/psreaderui\/paywall-integration"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/psreaderui\/paywall-integration"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"type":"text","text":"Restrict access to premium content with custom paywall screens."}],"metadata":{"role":"article","modules":[{"name":"PSReaderUI"}],"title":"Paywall Integration","roleHeading":"Article"},"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default the PSReaderUI SDK does "},{"type":"strong","inlineContent":[{"type":"text","text":"not"}]},{"type":"text","text":" restrict access to any content."},{"type":"text","text":" "},{"type":"text","text":"Paywalls are entirely opt-in: you implement the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallDelegate"},{"type":"text","text":" protocol,"},{"type":"text","text":" "},{"type":"text","text":"provide view controllers that conform to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController"},{"type":"text","text":", and assign"},{"type":"text","text":" "},{"type":"text","text":"the delegate to your "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration"},{"type":"text","text":"."}]},{"type":"heading","text":"How It Works","anchor":"How-It-Works","level":2},{"type":"paragraph","inlineContent":[{"text":"When a user attempts to open an edition, download an edition, or tap a search","type":"text"},{"text":" ","type":"text"},{"text":"result, the SDK consults a paywall delegate. When the SDK finds a delegate, the flow is:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"User taps an edition to open or download it.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The SDK calls the relevant "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallDelegate","isActive":true},{"type":"text","text":" method."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Your delegate returns a "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","isActive":true},{"type":"text","text":" (or "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" to skip the paywall)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The SDK sets the ","type":"text"},{"code":"onDismiss","type":"codeVoice"},{"text":" closure on your view controller and presents it ","type":"text"},{"inlineContent":[{"text":"modally","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When the user finishes, your view controller calls "},{"type":"codeVoice","code":"onDismiss(true)"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"grant access or "},{"type":"codeVoice","code":"onDismiss(false)"},{"type":"text","text":" to deny it."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The SDK dismisses your view controller automatically — ","type":"text"},{"inlineContent":[{"type":"text","text":"do not"}],"type":"strong"},{"text":" dismiss it yourself.","type":"text"}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK owns the presentation and dismissal lifecycle. Do not call"},{"type":"text","text":" "},{"type":"codeVoice","code":"dismiss(animated:)"},{"type":"text","text":" on the paywall view controller or its presenting"},{"type":"text","text":" "},{"type":"text","text":"controller. Doing so may leave the SDK in an inconsistent state."}]}],"type":"aside","name":"Important","style":"important"},{"type":"paragraph","inlineContent":[{"text":"The delegate methods receive different model objects depending on the edition","type":"text"},{"text":" ","type":"text"},{"text":"type. Knowing their properties helps you make informed paywall decisions.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"PSEdition","type":"codeVoice"},{"type":"text","text":" represents a replica (PDF) edition."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"PSEPublished"},{"text":" represents a feed edition.","type":"text"}]}]}]},{"type":"heading","text":"Creating a PaywallViewController","anchor":"Creating-a-PaywallViewController","level":2},{"type":"paragraph","inlineContent":[{"text":"Your paywall screen must conform to ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","isActive":true},{"text":". The protocol","type":"text"},{"text":" ","type":"text"},{"text":"requires a single property:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import PSReaderUI","","class MyPaywallScreen: UIViewController, PSReaderUI.PaywallViewController {","    var onDismiss: ((Bool) -> Void)?","","    \/\/ Build your paywall UI...","","    @objc func userDidSubscribe() {","        onDismiss?(true) \/\/ Grant access","    }","","    @objc func userDidCancel() {","        onDismiss?(false) \/\/ Deny access","    }","}"]},{"content":[{"inlineContent":[{"type":"text","text":"Call "},{"type":"codeVoice","code":"onDismiss"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"exactly once"}]},{"type":"text","text":" when the user completes or"},{"type":"text","text":" "},{"type":"text","text":"cancels the paywall flow. If you never call "},{"type":"codeVoice","code":"onDismiss"},{"type":"text","text":", the paywall remains"},{"type":"text","text":" "},{"type":"text","text":"on screen indefinitely. Calling it more than once may cause unexpected"},{"type":"text","text":" "},{"type":"text","text":"behavior."}],"type":"paragraph"}],"type":"aside","name":"Important","style":"important"},{"type":"heading","text":"Implementing PaywallDelegate","anchor":"Implementing-PaywallDelegate","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The delegate has five methods — two for opening editions, two for downloading"},{"type":"text","text":" "},{"type":"text","text":"them, and one for search results:"}]},{"type":"codeListing","syntax":"swift","code":["struct MyPaywallDelegate: PSReaderUI.PaywallDelegate {","","    func paywallViewControllerForAction(","        openReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        return MyPaywallScreen()","    }","","    func paywallViewControllerForAction(","        openFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        return MyPaywallScreen()","    }","","    func paywallViewControllerForAction(","        downloadReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        \/\/ Default implementation delegates to openReplicaEdition.","        return paywallViewControllerForAction(openReplicaEdition: edition)","    }","","    func paywallViewControllerForAction(","        downloadFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        \/\/ Default implementation delegates to openFeedEdition.","        return paywallViewControllerForAction(openFeedEdition: published)","    }","","    func paywallViewControllerForAction(","        openSearchResult result: SearchResult","    ) -> PaywallViewController? {","        \/\/ Default implementation returns nil (no paywall).","        return nil","    }","}"]},{"content":[{"inlineContent":[{"type":"text","text":"The download methods have default implementations that delegate to the"},{"type":"text","text":" "},{"type":"text","text":"corresponding open methods, and the search result method defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"You only need to override them if your paywall logic differs."}],"type":"paragraph"}],"type":"aside","name":"Tip","style":"tip"},{"type":"paragraph","inlineContent":[{"text":"Note that separate methods exist for replica and feed editions. See","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions","type":"reference"},{"text":" for background on the two systems.","type":"text"}]},{"type":"heading","text":"Conditional Paywalls","anchor":"Conditional-Paywalls","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Return "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" from any delegate method to skip the paywall for that edition."},{"type":"text","text":" "},{"type":"text","text":"This lets you implement conditional access logic:"}]},{"type":"codeListing","syntax":"swift","code":["struct MyPaywallDelegate: PSReaderUI.PaywallDelegate {","","    let userIsSubscribed: Bool","","    func paywallViewControllerForAction(","        openFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        \/\/ No paywall for subscribers","        if userIsSubscribed { return nil }","","        \/\/ No paywall for supplements","        if published.isSupplement { return nil }","","        return MyPaywallScreen()","    }","","    func paywallViewControllerForAction(","        openReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        if userIsSubscribed { return nil }","        return MyPaywallScreen()","    }","}"]},{"type":"heading","text":"Assigning the Delegate","anchor":"Assigning-the-Delegate","level":2},{"type":"heading","text":"Global Level","anchor":"Global-Level","level":3},{"type":"paragraph","inlineContent":[{"text":"Set the delegate on your ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration"},{"text":" to apply it across the entire","type":"text"},{"text":" ","type":"text"},{"text":"SDK. For most use cases, this is all you need.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["var globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: apiKey,","    accountGUID: accountGUID",")","globalConfig.paywallDelegate = MyPaywallDelegate()"]},{"type":"heading","text":"Carousel Level","anchor":"Carousel-Level","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set the delegate on a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselConfiguration"},{"type":"text","text":" to override the global delegate"},{"type":"text","text":" "},{"type":"text","text":"for all sections within a specific carousel:"}]},{"type":"codeListing","syntax":"swift","code":["var carouselConfig = PSReaderUI.CarouselConfiguration(globalConfig: globalConfig)","carouselConfig.paywallDelegate = MyCarouselPaywallDelegate()"]},{"type":"heading","text":"Per-Section Level","anchor":"Per-Section-Level","level":3},{"type":"paragraph","inlineContent":[{"text":"Set the delegate on an ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration"},{"text":" to override the paywall for a","type":"text"},{"text":" ","type":"text"},{"text":"single section. This is useful when different publications within the same","type":"text"},{"text":" ","type":"text"},{"text":"carousel have different access rules:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["var premiumArchiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","premiumArchiveConfig.paywallDelegate = PremiumPaywallDelegate()","","let sections: [PSReaderUI.CarouselViewController.SectionItem] = [","    \/\/ This section uses the per-section paywall","    .section(.init(","        name: \"Premium\",","        type: .feedArchive(guid: \"PREMIUM_GUID\", config: premiumArchiveConfig)","    )),","    \/\/ This section falls back to the global or carousel paywall","    .section(.init(","        name: \"Free\",","        type: .feedArchive(guid: \"FREE_GUID\")","    ))","]"]},{"type":"heading","text":"Search Result Paywalls","anchor":"Search-Result-Paywalls","level":2},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"openSearchResult","type":"codeVoice"},{"text":" method is called when a user taps a search result. By","type":"text"},{"text":" ","type":"text"},{"text":"default it returns ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", meaning search results open without a paywall.","type":"text"},{"text":" ","type":"text"},{"text":"Override it to restrict access:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["func paywallViewControllerForAction(","    openSearchResult result: SearchResult",") -> PaywallViewController? {","    guard !subscriptionManager.isSubscribed else { return nil }","    return SubscriptionPaywall()","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchResult","isActive":true},{"type":"text","text":" provides "},{"type":"codeVoice","code":"editionId"},{"type":"text","text":", "},{"type":"codeVoice","code":"publicationId"},{"type":"text","text":", and"},{"type":"text","text":" "},{"type":"codeVoice","code":"applicationId"},{"type":"text","text":" properties that you can use to make per-publication or"},{"type":"text","text":" "},{"type":"text","text":"per-edition access decisions."}]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Search"},{"text":" for the full search integration guide.","type":"text"}]},{"type":"heading","text":"Open vs Download Paywalls","anchor":"Open-vs-Download-Paywalls","level":2},{"type":"paragraph","inlineContent":[{"text":"In most cases the same paywall applies to both actions. However, some","type":"text"},{"text":" ","type":"text"},{"text":"publishers may want to allow free streaming while requiring a subscription to","type":"text"},{"text":" ","type":"text"},{"text":"download.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The download delegate methods have default implementations that call through to"},{"type":"text","text":" "},{"type":"text","text":"the corresponding open methods. Override them to differentiate:"}]},{"type":"codeListing","syntax":"swift","code":["struct StreamingPaywallDelegate: PSReaderUI.PaywallDelegate {","","    func paywallViewControllerForAction(","        openReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        \/\/ Free to open and read (streaming)","        return nil","    }","","    func paywallViewControllerForAction(","        openFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        return nil","    }","","    func paywallViewControllerForAction(","        downloadReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        \/\/ Require subscription for offline downloads","        return MyPaywallScreen()","    }","","    func paywallViewControllerForAction(","        downloadFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        return MyPaywallScreen()","    }","}"]},{"type":"heading","text":"Troubleshooting","anchor":"Troubleshooting","level":2},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Paywall never dismisses","type":"text"}]},{"type":"text","text":" "},{"type":"text","text":"Your "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","isActive":true},{"type":"text","text":" must call "},{"type":"codeVoice","code":"onDismiss"},{"type":"text","text":" at some point. If the user"},{"type":"text","text":" "},{"type":"text","text":"cancels, call "},{"type":"codeVoice","code":"onDismiss(false)"},{"type":"text","text":". If you never invoke the closure, the SDK has"},{"type":"text","text":" "},{"type":"text","text":"no signal to dismiss the view controller and it remains on screen."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Wrong paywall appears for a section"}]},{"type":"text","text":" "},{"type":"text","text":"Check the delegate cascade. A per-section delegate on "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","isActive":true},{"type":"text","text":" "},{"type":"text","text":"takes priority over the carousel and global delegates. Verify which level your"},{"type":"text","text":" "},{"type":"text","text":"delegate is assigned to and whether a more specific override exists."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Download always shows a paywall even though open is free"}]},{"type":"text","text":" "},{"type":"text","text":"The default download methods delegate to the open methods. If your open method"},{"type":"text","text":" "},{"type":"text","text":"returns "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" but downloads still show a paywall, you may have a separate"},{"type":"text","text":" "},{"type":"text","text":"delegate assigned at a different cascade level that overrides the download"},{"type":"text","text":" "},{"type":"text","text":"methods. Check all three levels."}]},{"type":"heading","text":"Complete Example","anchor":"Complete-Example","level":2},{"type":"paragraph","inlineContent":[{"text":"An end-to-end integration tying everything together:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import PSReaderUI","","\/\/ 1. Create a paywall view controller","class SubscriptionPaywall: UIViewController, PSReaderUI.PaywallViewController {","    var onDismiss: ((Bool) -> Void)?","","    override func viewDidLoad() {","        super.viewDidLoad()","        \/\/ Set up your subscription UI...","    }","","    @objc func subscribe() {","        \/\/ Handle subscription logic, then grant access","        onDismiss?(true)","    }","","    @objc func cancel() {","        onDismiss?(false)","    }","}","","\/\/ 2. Implement the delegate","struct AppPaywallDelegate: PSReaderUI.PaywallDelegate {","","    let subscriptionManager: SubscriptionManager","","    func paywallViewControllerForAction(","        openReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        guard !subscriptionManager.isSubscribed else { return nil }","        return SubscriptionPaywall()","    }","","    func paywallViewControllerForAction(","        openFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        guard !subscriptionManager.isSubscribed else { return nil }","        if published.isSupplement { return nil }","        return SubscriptionPaywall()","    }","}","","\/\/ 3. Assign to the global configuration","var globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: \"YOUR_API_KEY\",","    accountGUID: \"YOUR_ACCOUNT_GUID\"",")","globalConfig.paywallDelegate = AppPaywallDelegate(","    subscriptionManager: mySubscriptionManager",")","","\/\/ 4. Create and present the carousel","let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    sections: [","        .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\")","    ]",")"]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"seeAlsoSections":[{"title":"Features","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Deep-Linking","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Commenting","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Search"],"generated":true,"anchor":"Features"}],"kind":"article","references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/SearchResult":{"abstract":[{"type":"text","text":"A single search result returned by the PageSuite search API."}],"navigatorTitle":[{"text":"SearchResult","kind":"identifier"}],"title":"SearchResult","url":"\/documentation\/psreaderui\/searchresult","kind":"symbol","role":"symbol","type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchResult","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SearchResult","kind":"identifier"}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Replica-and-Feed-Editions":{"title":"Replica and Feed Editions","url":"\/documentation\/psreaderui\/replica-and-feed-editions","kind":"article","abstract":[{"text":"Understand the two backend systems that power PSReaderUI content.","type":"text"}],"type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions","role":"article"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/CarouselConfiguration":{"url":"\/documentation\/psreaderui\/carouselconfiguration","abstract":[{"type":"text","text":"Configuration object for customizing the PSReaderUI carousel interface."}],"navigatorTitle":[{"kind":"identifier","text":"CarouselConfiguration"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"CarouselConfiguration"}],"title":"CarouselConfiguration","role":"symbol","type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselConfiguration"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI":{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI","kind":"symbol","title":"PSReaderUI","url":"\/documentation\/psreaderui","role":"collection","type":"topic","abstract":[{"text":"A UI framework for building digital newspaper and magazine reader experiences on iOS.","type":"text"}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Sharing":{"role":"article","url":"\/documentation\/psreaderui\/sharing","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","kind":"article","type":"topic","title":"Sharing","abstract":[{"text":"Configure how users share edition content from the reader.","type":"text"}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Commenting":{"type":"topic","kind":"article","abstract":[{"text":"Add comment counts, comment buttons, and commenting integration to the reader.","type":"text"}],"role":"article","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Commenting","title":"Commenting","url":"\/documentation\/psreaderui\/commenting"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Analytics":{"type":"topic","title":"Analytics","kind":"article","role":"article","abstract":[{"type":"text","text":"Track user interactions and content engagement across the PSReaderUI SDK."}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","url":"\/documentation\/psreaderui\/analytics"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/PaywallViewController":{"type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"PaywallViewController"}],"abstract":[{"text":"A view controller protocol used by the SDK to present paywalls when","type":"text"},{"text":" ","type":"text"},{"text":"accessing restricted content.","type":"text"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"PaywallViewController"}],"url":"\/documentation\/psreaderui\/paywallviewcontroller","kind":"symbol","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","title":"PaywallViewController"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Advertisements":{"type":"topic","title":"Advertisements","abstract":[{"type":"text","text":"Display custom advertisements within the reader."}],"url":"\/documentation\/psreaderui\/advertisements","role":"article","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","kind":"article"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Deep-Linking":{"title":"Deep Linking","role":"article","kind":"article","type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Deep-Linking","abstract":[{"type":"text","text":"Open a specific feed edition directly, bypassing the archive screen."}],"url":"\/documentation\/psreaderui\/deep-linking"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Media-Playback":{"title":"Media Playback","kind":"article","url":"\/documentation\/psreaderui\/media-playback","role":"article","type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback","abstract":[{"type":"text","text":"Enable video and media playback within the reader."}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Text-to-Speech":{"type":"topic","title":"Text-to-Speech","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","abstract":[{"text":"Add audio playback of article content using the SDK’s text-to-speech system.","type":"text"}],"url":"\/documentation\/psreaderui\/text-to-speech","kind":"article","role":"article"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/ArchiveConfiguration":{"title":"ArchiveConfiguration","type":"topic","role":"symbol","abstract":[{"type":"text","text":"Configuration for customizing the appearance and behavior of publication archive views."}],"url":"\/documentation\/psreaderui\/archiveconfiguration","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ArchiveConfiguration","kind":"identifier"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","navigatorTitle":[{"text":"ArchiveConfiguration","kind":"identifier"}],"kind":"symbol"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Search":{"abstract":[{"type":"text","text":"Search across feed edition content for articles and pages."}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Search","kind":"article","title":"Search","url":"\/documentation\/psreaderui\/search","role":"article","type":"topic"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/GlobalConfiguration":{"navigatorTitle":[{"kind":"identifier","text":"GlobalConfiguration"}],"url":"\/documentation\/psreaderui\/globalconfiguration","role":"symbol","title":"GlobalConfiguration","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"GlobalConfiguration"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","kind":"symbol","abstract":[{"type":"text","text":"A configuration object that provides global settings and delegates for"},{"type":"text","text":" "},{"type":"text","text":"customizing the SDK’s behavior and appearance."}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/PaywallDelegate":{"title":"PaywallDelegate","url":"\/documentation\/psreaderui\/paywalldelegate","navigatorTitle":[{"kind":"identifier","text":"PaywallDelegate"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallDelegate","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"PaywallDelegate"}],"abstract":[{"text":"A delegate protocol used to provide paywall view controllers for controlling","type":"text"},{"text":" ","type":"text"},{"text":"access to premium content within the SDK.","type":"text"}],"role":"symbol"}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"value":"occ","path":"\/identifier\/interfaceLanguage","op":"replace"},{"value":null,"path":"\/topicSections","op":"add"},{"value":[{"generated":true,"identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Deep-Linking","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Commenting","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Search"],"title":"Features","anchor":"Features"}],"path":"\/seeAlsoSections","op":"replace"}]}]}