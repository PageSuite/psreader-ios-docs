{"primaryContentSections":[{"content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"By default the PSReaderUI SDK does ","type":"text"},{"type":"strong","inlineContent":[{"text":"not","type":"text"}]},{"text":" restrict access to any content.","type":"text"},{"text":" ","type":"text"},{"text":"Paywalls are entirely opt-in: you implement the ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallDelegate","isActive":true,"type":"reference"},{"text":" protocol,","type":"text"},{"text":" ","type":"text"},{"text":"provide view controllers that conform to ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","isActive":true,"type":"reference"},{"text":", and assign","type":"text"},{"text":" ","type":"text"},{"text":"the delegate to your ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"anchor":"How-It-Works","text":"How It Works","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"When a user attempts to open or download an edition, the SDK consults a","type":"text"},{"text":" ","type":"text"},{"text":"paywall delegate. When the SDK finds a delegate, the flow is:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"User taps an edition to open or download it."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The SDK calls the relevant "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallDelegate","isActive":true,"type":"reference"},{"type":"text","text":" method."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Your delegate returns a ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","isActive":true,"type":"reference"},{"text":" (or ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" to skip the paywall).","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The SDK sets the ","type":"text"},{"code":"onDismiss","type":"codeVoice"},{"text":" closure on your view controller and presents it ","type":"text"},{"inlineContent":[{"text":"modally","type":"text"}],"type":"strong"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"When the user finishes, your view controller calls "},{"type":"codeVoice","code":"onDismiss(true)"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"grant access or "},{"type":"codeVoice","code":"onDismiss(false)"},{"type":"text","text":" to deny it."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The SDK dismisses your view controller automatically — ","type":"text"},{"inlineContent":[{"type":"text","text":"do not"}],"type":"strong"},{"text":" dismiss it yourself.","type":"text"}]}]}],"type":"orderedList"},{"style":"important","type":"aside","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"The SDK owns the presentation and dismissal lifecycle. Do not call","type":"text"},{"text":" ","type":"text"},{"code":"dismiss(animated:)","type":"codeVoice"},{"text":" on the paywall view controller or its presenting","type":"text"},{"text":" ","type":"text"},{"text":"controller. Doing so may leave the SDK in an inconsistent state.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The delegate methods receive different model objects depending on the edition"},{"type":"text","text":" "},{"type":"text","text":"type. Knowing their properties helps you make informed paywall decisions."}]},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"PSEdition"},{"text":" represents a replica (PDF) edition.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"PSEPublished","type":"codeVoice"},{"type":"text","text":" represents a feed edition."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Creating-a-PaywallViewController","text":"Creating a PaywallViewController","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Your paywall screen must conform to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController"},{"type":"text","text":". The protocol"},{"type":"text","text":" "},{"type":"text","text":"requires a single property:"}]},{"code":["import PSReaderUI","","class MyPaywallScreen: UIViewController, PSReaderUI.PaywallViewController {","    var onDismiss: ((Bool) -> Void)?","","    \/\/ Build your paywall UI...","","    @objc func userDidSubscribe() {","        onDismiss?(true) \/\/ Grant access","    }","","    @objc func userDidCancel() {","        onDismiss?(false) \/\/ Deny access","    }","}"],"type":"codeListing","syntax":"swift"},{"content":[{"inlineContent":[{"text":"Call ","type":"text"},{"code":"onDismiss","type":"codeVoice"},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"text":"exactly once","type":"text"}]},{"text":" when the user completes or","type":"text"},{"text":" ","type":"text"},{"text":"cancels the paywall flow. If you never call ","type":"text"},{"code":"onDismiss","type":"codeVoice"},{"text":", the paywall remains","type":"text"},{"text":" ","type":"text"},{"text":"on screen indefinitely. Calling it more than once may cause unexpected","type":"text"},{"text":" ","type":"text"},{"text":"behavior.","type":"text"}],"type":"paragraph"}],"style":"important","type":"aside","name":"Important"},{"text":"Implementing PaywallDelegate","anchor":"Implementing-PaywallDelegate","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The delegate has four methods — two for opening editions and two for"},{"type":"text","text":" "},{"type":"text","text":"downloading them:"}]},{"code":["struct MyPaywallDelegate: PSReaderUI.PaywallDelegate {","","    func paywallViewControllerForAction(","        openReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        return MyPaywallScreen()","    }","","    func paywallViewControllerForAction(","        openFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        return MyPaywallScreen()","    }","","    func paywallViewControllerForAction(","        downloadReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        \/\/ Default implementation delegates to openReplicaEdition.","        return paywallViewControllerForAction(openReplicaEdition: edition)","    }","","    func paywallViewControllerForAction(","        downloadFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        \/\/ Default implementation delegates to openFeedEdition.","        return paywallViewControllerForAction(openFeedEdition: published)","    }","}"],"type":"codeListing","syntax":"swift"},{"content":[{"inlineContent":[{"type":"text","text":"The download methods have default implementations that delegate to the"},{"type":"text","text":" "},{"type":"text","text":"corresponding open methods. You only need to override them if your paywall"},{"type":"text","text":" "},{"type":"text","text":"logic differs between opening and downloading."}],"type":"paragraph"}],"style":"tip","type":"aside","name":"Tip"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that separate methods exist for replica and feed editions. See"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions"},{"type":"text","text":" for background on the two systems."}]},{"text":"Conditional Paywalls","anchor":"Conditional-Paywalls","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Return "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" from any delegate method to skip the paywall for that edition."},{"type":"text","text":" "},{"type":"text","text":"This lets you implement conditional access logic:"}]},{"code":["struct MyPaywallDelegate: PSReaderUI.PaywallDelegate {","","    let userIsSubscribed: Bool","","    func paywallViewControllerForAction(","        openFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        \/\/ No paywall for subscribers","        if userIsSubscribed { return nil }","","        \/\/ No paywall for supplements","        if published.isSupplement { return nil }","","        return MyPaywallScreen()","    }","","    func paywallViewControllerForAction(","        openReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        if userIsSubscribed { return nil }","        return MyPaywallScreen()","    }","}"],"type":"codeListing","syntax":"swift"},{"text":"Assigning the Delegate","anchor":"Assigning-the-Delegate","level":2,"type":"heading"},{"text":"Global Level","anchor":"Global-Level","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Set the delegate on your ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration"},{"text":" to apply it across the entire","type":"text"},{"text":" ","type":"text"},{"text":"SDK. For most use cases, this is all you need.","type":"text"}]},{"code":["var globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: apiKey,","    accountGUID: accountGUID",")","globalConfig.paywallDelegate = MyPaywallDelegate()"],"type":"codeListing","syntax":"swift"},{"text":"Carousel Level","anchor":"Carousel-Level","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set the delegate on a "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselConfiguration","isActive":true},{"type":"text","text":" to override the global delegate"},{"type":"text","text":" "},{"type":"text","text":"for all sections within a specific carousel:"}]},{"code":["var carouselConfig = PSReaderUI.CarouselConfiguration(globalConfig: globalConfig)","carouselConfig.paywallDelegate = MyCarouselPaywallDelegate()"],"type":"codeListing","syntax":"swift"},{"text":"Per-Section Level","anchor":"Per-Section-Level","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set the delegate on an "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","isActive":true},{"type":"text","text":" to override the paywall for a"},{"type":"text","text":" "},{"type":"text","text":"single section. This is useful when different publications within the same"},{"type":"text","text":" "},{"type":"text","text":"carousel have different access rules:"}]},{"code":["var premiumArchiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","premiumArchiveConfig.paywallDelegate = PremiumPaywallDelegate()","","let sections: [PSReaderUI.CarouselViewController.SectionItem] = [","    \/\/ This section uses the per-section paywall","    .section(.init(","        name: \"Premium\",","        type: .feedArchive(guid: \"PREMIUM_GUID\", config: premiumArchiveConfig)","    )),","    \/\/ This section falls back to the global or carousel paywall","    .section(.init(","        name: \"Free\",","        type: .feedArchive(guid: \"FREE_GUID\")","    ))","]"],"type":"codeListing","syntax":"swift"},{"text":"Open vs Download Paywalls","anchor":"Open-vs-Download-Paywalls","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In most cases the same paywall applies to both actions. However, some"},{"type":"text","text":" "},{"type":"text","text":"publishers may want to allow free streaming while requiring a subscription to"},{"type":"text","text":" "},{"type":"text","text":"download."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The download delegate methods have default implementations that call through to"},{"type":"text","text":" "},{"type":"text","text":"the corresponding open methods. Override them to differentiate:"}]},{"code":["struct StreamingPaywallDelegate: PSReaderUI.PaywallDelegate {","","    func paywallViewControllerForAction(","        openReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        \/\/ Free to open and read (streaming)","        return nil","    }","","    func paywallViewControllerForAction(","        openFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        return nil","    }","","    func paywallViewControllerForAction(","        downloadReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        \/\/ Require subscription for offline downloads","        return MyPaywallScreen()","    }","","    func paywallViewControllerForAction(","        downloadFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        return MyPaywallScreen()","    }","}"],"type":"codeListing","syntax":"swift"},{"text":"Troubleshooting","anchor":"Troubleshooting","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Paywall never dismisses","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"text":"Your ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","isActive":true},{"text":" must call ","type":"text"},{"type":"codeVoice","code":"onDismiss"},{"text":" at some point. If the user","type":"text"},{"text":" ","type":"text"},{"text":"cancels, call ","type":"text"},{"type":"codeVoice","code":"onDismiss(false)"},{"text":". If you never invoke the closure, the SDK has","type":"text"},{"text":" ","type":"text"},{"text":"no signal to dismiss the view controller and it remains on screen.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Wrong paywall appears for a section","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"text":"Check the delegate cascade. A per-section delegate on ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","type":"reference"},{"text":" ","type":"text"},{"text":"takes priority over the carousel and global delegates. Verify which level your","type":"text"},{"text":" ","type":"text"},{"text":"delegate is assigned to and whether a more specific override exists.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Download always shows a paywall even though open is free","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"text":"The default download methods delegate to the open methods. If your open method","type":"text"},{"text":" ","type":"text"},{"text":"returns ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" but downloads still show a paywall, you may have a separate","type":"text"},{"text":" ","type":"text"},{"text":"delegate assigned at a different cascade level that overrides the download","type":"text"},{"text":" ","type":"text"},{"text":"methods. Check all three levels.","type":"text"}]},{"text":"Complete Example","anchor":"Complete-Example","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An end-to-end integration tying everything together:"}]},{"code":["import PSReaderUI","","\/\/ 1. Create a paywall view controller","class SubscriptionPaywall: UIViewController, PSReaderUI.PaywallViewController {","    var onDismiss: ((Bool) -> Void)?","","    override func viewDidLoad() {","        super.viewDidLoad()","        \/\/ Set up your subscription UI...","    }","","    @objc func subscribe() {","        \/\/ Handle subscription logic, then grant access","        onDismiss?(true)","    }","","    @objc func cancel() {","        onDismiss?(false)","    }","}","","\/\/ 2. Implement the delegate","struct AppPaywallDelegate: PSReaderUI.PaywallDelegate {","","    let subscriptionManager: SubscriptionManager","","    func paywallViewControllerForAction(","        openReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        guard !subscriptionManager.isSubscribed else { return nil }","        return SubscriptionPaywall()","    }","","    func paywallViewControllerForAction(","        openFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        guard !subscriptionManager.isSubscribed else { return nil }","        if published.isSupplement { return nil }","        return SubscriptionPaywall()","    }","}","","\/\/ 3. Assign to the global configuration","var globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: \"YOUR_API_KEY\",","    accountGUID: \"YOUR_ACCOUNT_GUID\"",")","globalConfig.paywallDelegate = AppPaywallDelegate(","    subscriptionManager: mySubscriptionManager",")","","\/\/ 4. Create and present the carousel","let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    sections: [","        .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\")","    ]",")"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"kind":"article","seeAlsoSections":[{"title":"Features","generated":true,"anchor":"Features","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics"]}],"variants":[{"paths":["\/documentation\/psreaderui\/paywall-integration"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/psreaderui\/paywall-integration"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"PSReaderUI"}],"role":"article","title":"Paywall Integration","roleHeading":"Article"},"abstract":[{"text":"Restrict access to premium content with custom paywall screens.","type":"text"}],"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Analytics":{"type":"topic","title":"Analytics","abstract":[{"text":"Track user interactions and content engagement across the PSReaderUI SDK.","type":"text"}],"url":"\/documentation\/psreaderui\/analytics","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","kind":"article","role":"article"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Text-to-Speech":{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","url":"\/documentation\/psreaderui\/text-to-speech","kind":"article","type":"topic","abstract":[{"type":"text","text":"Add audio playback of article content using the SDK’s text-to-speech system."}],"title":"Text-to-Speech","role":"article"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/PaywallDelegate":{"url":"\/documentation\/psreaderui\/paywalldelegate","abstract":[{"text":"A delegate protocol used to provide paywall view controllers for controlling","type":"text"},{"text":" ","type":"text"},{"text":"access to premium content within the SDK.","type":"text"}],"title":"PaywallDelegate","role":"symbol","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallDelegate","navigatorTitle":[{"kind":"identifier","text":"PaywallDelegate"}],"type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"PaywallDelegate"}],"kind":"symbol"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/GlobalConfiguration":{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","type":"topic","role":"symbol","title":"GlobalConfiguration","abstract":[{"type":"text","text":"A configuration object that provides global settings and delegates for"},{"type":"text","text":" "},{"type":"text","text":"customizing the SDK’s behavior and appearance."}],"navigatorTitle":[{"kind":"identifier","text":"GlobalConfiguration"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"GlobalConfiguration"}],"url":"\/documentation\/psreaderui\/globalconfiguration","kind":"symbol"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Replica-and-Feed-Editions":{"title":"Replica and Feed Editions","type":"topic","role":"article","kind":"article","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions","abstract":[{"type":"text","text":"Understand the two backend systems that power PSReaderUI content."}],"url":"\/documentation\/psreaderui\/replica-and-feed-editions"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Advertisements":{"url":"\/documentation\/psreaderui\/advertisements","type":"topic","abstract":[{"text":"Display custom advertisements within the reader.","type":"text"}],"kind":"article","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","role":"article","title":"Advertisements"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI":{"url":"\/documentation\/psreaderui","type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI","kind":"symbol","title":"PSReaderUI","abstract":[{"type":"text","text":"A UI framework for building digital newspaper and magazine reader experiences on iOS."}],"role":"collection"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/ArchiveConfiguration":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ArchiveConfiguration","kind":"identifier"}],"role":"symbol","type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","url":"\/documentation\/psreaderui\/archiveconfiguration","title":"ArchiveConfiguration","navigatorTitle":[{"text":"ArchiveConfiguration","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"Configuration for customizing the appearance and behavior of publication archive views."}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/CarouselConfiguration":{"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"CarouselConfiguration"}],"abstract":[{"type":"text","text":"Configuration object for customizing the PSReaderUI carousel interface."}],"navigatorTitle":[{"kind":"identifier","text":"CarouselConfiguration"}],"title":"CarouselConfiguration","type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselConfiguration","url":"\/documentation\/psreaderui\/carouselconfiguration"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/PaywallViewController":{"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"PaywallViewController"}],"type":"topic","abstract":[{"text":"A view controller protocol used by the SDK to present paywalls when","type":"text"},{"text":" ","type":"text"},{"text":"accessing restricted content.","type":"text"}],"role":"symbol","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","navigatorTitle":[{"kind":"identifier","text":"PaywallViewController"}],"url":"\/documentation\/psreaderui\/paywallviewcontroller","kind":"symbol","title":"PaywallViewController"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Sharing":{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","abstract":[{"type":"text","text":"Configure how users share edition content from the reader."}],"type":"topic","kind":"article","url":"\/documentation\/psreaderui\/sharing","title":"Sharing","role":"article"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Media-Playback":{"kind":"article","title":"Media Playback","url":"\/documentation\/psreaderui\/media-playback","type":"topic","role":"article","abstract":[{"text":"Enable video and media playback within the reader.","type":"text"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback"}},"variantOverrides":[{"patch":[{"value":"occ","path":"\/identifier\/interfaceLanguage","op":"replace"},{"value":null,"path":"\/topicSections","op":"add"},{"value":[{"title":"Features","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics"],"anchor":"Features","generated":true}],"path":"\/seeAlsoSections","op":"replace"}],"traits":[{"interfaceLanguage":"occ"}]}]}