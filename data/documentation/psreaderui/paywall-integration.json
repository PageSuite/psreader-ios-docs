{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Restrict access to premium content with custom paywall screens."}],"kind":"article","hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"seeAlsoSections":[{"generated":true,"anchor":"Features","title":"Features","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Deep-Linking","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Commenting","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Search"]}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"inlineContent":[{"text":"By default the PSReaderUI SDK does ","type":"text"},{"inlineContent":[{"text":"not","type":"text"}],"type":"strong"},{"text":" restrict access to any content.","type":"text"},{"text":" ","type":"text"},{"text":"Paywalls are entirely opt-in: you implement the ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallDelegate","isActive":true,"type":"reference"},{"text":" protocol,","type":"text"},{"text":" ","type":"text"},{"text":"provide view controllers that conform to ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","isActive":true,"type":"reference"},{"text":", and assign","type":"text"},{"text":" ","type":"text"},{"text":"the delegate to your ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"How-It-Works","text":"How It Works","level":2},{"inlineContent":[{"text":"When a user attempts to open an edition, download an edition, or tap a search","type":"text"},{"text":" ","type":"text"},{"text":"result, the SDK consults a paywall delegate. When the SDK finds a delegate, the flow is:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"User taps an edition to open or download it.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The SDK calls the relevant ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallDelegate","isActive":true},{"text":" method.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Your delegate returns a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","type":"reference"},{"text":" (or ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" to skip the paywall).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK sets the "},{"type":"codeVoice","code":"onDismiss"},{"type":"text","text":" closure on your view controller and presents it "},{"type":"strong","inlineContent":[{"text":"modally","type":"text"}]},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"text":"When the user finishes, your view controller calls ","type":"text"},{"type":"codeVoice","code":"onDismiss(true)"},{"text":" to","type":"text"},{"text":" ","type":"text"},{"text":"grant access or ","type":"text"},{"type":"codeVoice","code":"onDismiss(false)"},{"text":" to deny it.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The SDK dismisses your view controller automatically — ","type":"text"},{"inlineContent":[{"type":"text","text":"do not"}],"type":"strong"},{"text":" dismiss it yourself.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK owns the presentation and dismissal lifecycle. Do not call"},{"type":"text","text":" "},{"type":"codeVoice","code":"dismiss(animated:)"},{"type":"text","text":" on the paywall view controller or its presenting"},{"type":"text","text":" "},{"type":"text","text":"controller. Doing so may leave the SDK in an inconsistent state."}]}],"type":"aside","style":"important","name":"Important"},{"inlineContent":[{"type":"text","text":"The delegate methods receive different model objects depending on the edition"},{"type":"text","text":" "},{"type":"text","text":"type. Knowing their properties helps you make informed paywall decisions."}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"PSEdition"},{"text":" represents a replica (PDF) edition.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"PSEPublished"},{"type":"text","text":" represents a feed edition."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","anchor":"Creating-a-PaywallViewController","text":"Creating a PaywallViewController","level":2},{"inlineContent":[{"type":"text","text":"Your paywall screen must conform to "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","isActive":true,"type":"reference"},{"type":"text","text":". The protocol"},{"type":"text","text":" "},{"type":"text","text":"requires a single property:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import PSReaderUI","","class MyPaywallScreen: UIViewController, PSReaderUI.PaywallViewController {","    var onDismiss: ((Bool) -> Void)?","","    \/\/ Build your paywall UI...","","    @objc func userDidSubscribe() {","        onDismiss?(true) \/\/ Grant access","    }","","    @objc func userDidCancel() {","        onDismiss?(false) \/\/ Deny access","    }","}"]},{"content":[{"inlineContent":[{"text":"Call ","type":"text"},{"type":"codeVoice","code":"onDismiss"},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"exactly once"}]},{"text":" when the user completes or","type":"text"},{"text":" ","type":"text"},{"text":"cancels the paywall flow. If you never call ","type":"text"},{"type":"codeVoice","code":"onDismiss"},{"text":", the paywall remains","type":"text"},{"text":" ","type":"text"},{"text":"on screen indefinitely. Calling it more than once may cause unexpected","type":"text"},{"text":" ","type":"text"},{"text":"behavior.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"},{"type":"heading","anchor":"Implementing-PaywallDelegate","text":"Implementing PaywallDelegate","level":2},{"inlineContent":[{"type":"text","text":"The delegate has five methods — two for opening editions, two for downloading"},{"type":"text","text":" "},{"type":"text","text":"them, and one for search results:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct MyPaywallDelegate: PSReaderUI.PaywallDelegate {","","    func paywallViewControllerForAction(","        openReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        return MyPaywallScreen()","    }","","    func paywallViewControllerForAction(","        openFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        return MyPaywallScreen()","    }","","    func paywallViewControllerForAction(","        downloadReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        \/\/ Default implementation delegates to openReplicaEdition.","        return paywallViewControllerForAction(openReplicaEdition: edition)","    }","","    func paywallViewControllerForAction(","        downloadFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        \/\/ Default implementation delegates to openFeedEdition.","        return paywallViewControllerForAction(openFeedEdition: published)","    }","","    func paywallViewControllerForAction(","        openSearchResult result: SearchResult","    ) -> PaywallViewController? {","        \/\/ Default implementation returns nil (no paywall).","        return nil","    }","}"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The download methods have default implementations that delegate to the"},{"type":"text","text":" "},{"type":"text","text":"corresponding open methods, and the search result method defaults to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"You only need to override them if your paywall logic differs."}]}],"type":"aside","style":"tip","name":"Tip"},{"inlineContent":[{"text":"Note that separate methods exist for replica and feed editions. See","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions","isActive":true},{"text":" for background on the two systems.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Conditional-Paywalls","text":"Conditional Paywalls","level":3},{"inlineContent":[{"type":"text","text":"Return "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" from any delegate method to skip the paywall for that edition."},{"type":"text","text":" "},{"type":"text","text":"This lets you implement conditional access logic:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct MyPaywallDelegate: PSReaderUI.PaywallDelegate {","","    let userIsSubscribed: Bool","","    func paywallViewControllerForAction(","        openFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        \/\/ No paywall for subscribers","        if userIsSubscribed { return nil }","","        \/\/ No paywall for supplements","        if published.isSupplement { return nil }","","        return MyPaywallScreen()","    }","","    func paywallViewControllerForAction(","        openReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        if userIsSubscribed { return nil }","        return MyPaywallScreen()","    }","}"]},{"type":"heading","anchor":"Assigning-the-Delegate","text":"Assigning the Delegate","level":2},{"type":"heading","anchor":"Global-Level","text":"Global Level","level":3},{"inlineContent":[{"type":"text","text":"Set the delegate on your "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","isActive":true,"type":"reference"},{"type":"text","text":" to apply it across the entire"},{"type":"text","text":" "},{"type":"text","text":"SDK. For most use cases, this is all you need."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["var globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: apiKey,","    accountGUID: accountGUID",")","globalConfig.paywallDelegate = MyPaywallDelegate()"]},{"type":"heading","anchor":"Carousel-Level","text":"Carousel Level","level":3},{"inlineContent":[{"text":"Set the delegate on a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselConfiguration"},{"text":" to override the global delegate","type":"text"},{"text":" ","type":"text"},{"text":"for all sections within a specific carousel:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["var carouselConfig = PSReaderUI.CarouselConfiguration(globalConfig: globalConfig)","carouselConfig.paywallDelegate = MyCarouselPaywallDelegate()"]},{"type":"heading","anchor":"Per-Section-Level","text":"Per-Section Level","level":3},{"inlineContent":[{"type":"text","text":"Set the delegate on an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration"},{"type":"text","text":" to override the paywall for a"},{"type":"text","text":" "},{"type":"text","text":"single section. This is useful when different publications within the same"},{"type":"text","text":" "},{"type":"text","text":"carousel have different access rules:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["var premiumArchiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","premiumArchiveConfig.paywallDelegate = PremiumPaywallDelegate()","","let sections: [PSReaderUI.CarouselViewController.SectionItem] = [","    \/\/ This section uses the per-section paywall","    .section(.init(","        name: \"Premium\",","        type: .feedArchive(guid: \"PREMIUM_GUID\", config: premiumArchiveConfig)","    )),","    \/\/ This section falls back to the global or carousel paywall","    .section(.init(","        name: \"Free\",","        type: .feedArchive(guid: \"FREE_GUID\")","    ))","]"]},{"type":"heading","anchor":"Search-Result-Paywalls","text":"Search Result Paywalls","level":2},{"inlineContent":[{"text":"The ","type":"text"},{"code":"openSearchResult","type":"codeVoice"},{"text":" method is called when a user taps a search result. By","type":"text"},{"text":" ","type":"text"},{"text":"default it returns ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", meaning search results open without a paywall.","type":"text"},{"text":" ","type":"text"},{"text":"Override it to restrict access:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func paywallViewControllerForAction(","    openSearchResult result: SearchResult",") -> PaywallViewController? {","    guard !subscriptionManager.isSubscribed else { return nil }","    return SubscriptionPaywall()","}"]},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchResult","isActive":true},{"text":" provides ","type":"text"},{"type":"codeVoice","code":"editionId"},{"text":", ","type":"text"},{"type":"codeVoice","code":"publicationId"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"applicationId"},{"text":" properties that you can use to make per-publication or","type":"text"},{"text":" ","type":"text"},{"text":"per-edition access decisions.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Search"},{"text":" for the full search integration guide.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Open-vs-Download-Paywalls","text":"Open vs Download Paywalls","level":2},{"inlineContent":[{"text":"In most cases the same paywall applies to both actions. However, some","type":"text"},{"text":" ","type":"text"},{"text":"publishers may want to allow free streaming while requiring a subscription to","type":"text"},{"text":" ","type":"text"},{"text":"download.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The download delegate methods have default implementations that call through to"},{"type":"text","text":" "},{"type":"text","text":"the corresponding open methods. Override them to differentiate:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct StreamingPaywallDelegate: PSReaderUI.PaywallDelegate {","","    func paywallViewControllerForAction(","        openReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        \/\/ Free to open and read (streaming)","        return nil","    }","","    func paywallViewControllerForAction(","        openFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        return nil","    }","","    func paywallViewControllerForAction(","        downloadReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        \/\/ Require subscription for offline downloads","        return MyPaywallScreen()","    }","","    func paywallViewControllerForAction(","        downloadFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        return MyPaywallScreen()","    }","}"]},{"type":"heading","anchor":"Troubleshooting","text":"Troubleshooting","level":2},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Paywall never dismisses"}],"type":"strong"},{"type":"text","text":" "},{"type":"text","text":"Your "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","type":"reference","isActive":true},{"type":"text","text":" must call "},{"type":"codeVoice","code":"onDismiss"},{"type":"text","text":" at some point. If the user"},{"type":"text","text":" "},{"type":"text","text":"cancels, call "},{"type":"codeVoice","code":"onDismiss(false)"},{"type":"text","text":". If you never invoke the closure, the SDK has"},{"type":"text","text":" "},{"type":"text","text":"no signal to dismiss the view controller and it remains on screen."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Wrong paywall appears for a section","type":"text"}]},{"text":" ","type":"text"},{"text":"Check the delegate cascade. A per-section delegate on ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"takes priority over the carousel and global delegates. Verify which level your","type":"text"},{"text":" ","type":"text"},{"text":"delegate is assigned to and whether a more specific override exists.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Download always shows a paywall even though open is free","type":"text"}]},{"type":"text","text":" "},{"type":"text","text":"The default download methods delegate to the open methods. If your open method"},{"type":"text","text":" "},{"type":"text","text":"returns "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" but downloads still show a paywall, you may have a separate"},{"type":"text","text":" "},{"type":"text","text":"delegate assigned at a different cascade level that overrides the download"},{"type":"text","text":" "},{"type":"text","text":"methods. Check all three levels."}],"type":"paragraph"},{"type":"heading","anchor":"Complete-Example","text":"Complete Example","level":2},{"inlineContent":[{"type":"text","text":"An end-to-end integration tying everything together:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import PSReaderUI","","\/\/ 1. Create a paywall view controller","class SubscriptionPaywall: UIViewController, PSReaderUI.PaywallViewController {","    var onDismiss: ((Bool) -> Void)?","","    override func viewDidLoad() {","        super.viewDidLoad()","        \/\/ Set up your subscription UI...","    }","","    @objc func subscribe() {","        \/\/ Handle subscription logic, then grant access","        onDismiss?(true)","    }","","    @objc func cancel() {","        onDismiss?(false)","    }","}","","\/\/ 2. Implement the delegate","struct AppPaywallDelegate: PSReaderUI.PaywallDelegate {","","    let subscriptionManager: SubscriptionManager","","    func paywallViewControllerForAction(","        openReplicaEdition edition: PSEdition","    ) -> PaywallViewController? {","        guard !subscriptionManager.isSubscribed else { return nil }","        return SubscriptionPaywall()","    }","","    func paywallViewControllerForAction(","        openFeedEdition published: PSEPublished","    ) -> PaywallViewController? {","        guard !subscriptionManager.isSubscribed else { return nil }","        if published.isSupplement { return nil }","        return SubscriptionPaywall()","    }","}","","\/\/ 3. Assign to the global configuration","var globalConfig = PSReaderUI.GlobalConfiguration(","    apiKey: \"YOUR_API_KEY\",","    accountGUID: \"YOUR_ACCOUNT_GUID\"",")","globalConfig.paywallDelegate = AppPaywallDelegate(","    subscriptionManager: mySubscriptionManager",")","","\/\/ 4. Create and present the carousel","let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    sections: [","        .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\")","    ]",")"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/paywall-integration"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/psreaderui\/paywall-integration"]}],"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"PSReaderUI"}],"roleHeading":"Article","title":"Paywall Integration","role":"article"},"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Replica-and-Feed-Editions":{"abstract":[{"text":"Understand the two backend systems that power PSReaderUI content.","type":"text"}],"type":"topic","title":"Replica and Feed Editions","role":"article","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions","kind":"article","url":"\/documentation\/psreaderui\/replica-and-feed-editions"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/GlobalConfiguration":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GlobalConfiguration","kind":"identifier"}],"title":"GlobalConfiguration","navigatorTitle":[{"text":"GlobalConfiguration","kind":"identifier"}],"type":"topic","abstract":[{"text":"A configuration object that provides global settings and delegates for","type":"text"},{"text":" ","type":"text"},{"text":"customizing the SDK’s behavior and appearance.","type":"text"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/GlobalConfiguration","kind":"symbol","url":"\/documentation\/psreaderui\/globalconfiguration"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/SearchResult":{"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SearchResult"}],"type":"topic","title":"SearchResult","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchResult","kind":"symbol","abstract":[{"type":"text","text":"A single search result returned by the PageSuite search API."}],"navigatorTitle":[{"kind":"identifier","text":"SearchResult"}],"url":"\/documentation\/psreaderui\/searchresult"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/CarouselConfiguration":{"role":"symbol","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CarouselConfiguration","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"CarouselConfiguration","kind":"identifier"}],"title":"CarouselConfiguration","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselConfiguration","url":"\/documentation\/psreaderui\/carouselconfiguration","abstract":[{"text":"Configuration object for customizing the PSReaderUI carousel interface.","type":"text"}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/PaywallDelegate":{"abstract":[{"type":"text","text":"A delegate protocol used to provide paywall view controllers for controlling"},{"type":"text","text":" "},{"type":"text","text":"access to premium content within the SDK."}],"kind":"symbol","type":"topic","title":"PaywallDelegate","url":"\/documentation\/psreaderui\/paywalldelegate","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallDelegate","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"PaywallDelegate"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"PaywallDelegate"}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Media-Playback":{"role":"article","url":"\/documentation\/psreaderui\/media-playback","abstract":[{"type":"text","text":"Enable video and media playback within the reader."}],"kind":"article","title":"Media Playback","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback","type":"topic"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/ArchiveConfiguration":{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","navigatorTitle":[{"kind":"identifier","text":"ArchiveConfiguration"}],"kind":"symbol","url":"\/documentation\/psreaderui\/archiveconfiguration","abstract":[{"type":"text","text":"Configuration for customizing the appearance and behavior of publication archive views."}],"role":"symbol","title":"ArchiveConfiguration","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ArchiveConfiguration"}],"type":"topic"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/PaywallViewController":{"title":"PaywallViewController","kind":"symbol","role":"symbol","type":"topic","url":"\/documentation\/psreaderui\/paywallviewcontroller","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/PaywallViewController","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"PaywallViewController"}],"navigatorTitle":[{"kind":"identifier","text":"PaywallViewController"}],"abstract":[{"type":"text","text":"A view controller protocol used by the SDK to present paywalls when"},{"type":"text","text":" "},{"type":"text","text":"accessing restricted content."}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Search":{"url":"\/documentation\/psreaderui\/search","kind":"article","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Search","role":"article","title":"Search","abstract":[{"type":"text","text":"Search across feed edition content for articles and pages."}],"type":"topic"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Commenting":{"type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Commenting","abstract":[{"text":"Add comment counts, comment buttons, and commenting integration to the reader.","type":"text"}],"role":"article","kind":"article","title":"Commenting","url":"\/documentation\/psreaderui\/commenting"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Text-to-Speech":{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","kind":"article","role":"article","url":"\/documentation\/psreaderui\/text-to-speech","type":"topic","abstract":[{"text":"Add audio playback of article content using the SDK’s text-to-speech system.","type":"text"}],"title":"Text-to-Speech"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Sharing":{"url":"\/documentation\/psreaderui\/sharing","kind":"article","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","role":"article","abstract":[{"type":"text","text":"Configure how users share edition content from the reader."}],"type":"topic","title":"Sharing"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI":{"kind":"symbol","url":"\/documentation\/psreaderui","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI","title":"PSReaderUI","abstract":[{"type":"text","text":"A UI framework for building digital newspaper and magazine reader experiences on iOS."}],"type":"topic","role":"collection"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Analytics":{"role":"article","title":"Analytics","type":"topic","abstract":[{"text":"Track user interactions and content engagement across the PSReaderUI SDK.","type":"text"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","kind":"article","url":"\/documentation\/psreaderui\/analytics"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Advertisements":{"abstract":[{"text":"Display custom advertisements within the reader.","type":"text"}],"url":"\/documentation\/psreaderui\/advertisements","role":"article","title":"Advertisements","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","kind":"article","type":"topic"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Deep-Linking":{"title":"Deep Linking","role":"article","url":"\/documentation\/psreaderui\/deep-linking","type":"topic","abstract":[{"text":"Open a specific feed edition directly, bypassing the archive screen.","type":"text"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Deep-Linking","kind":"article"}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"op":"replace","value":"occ","path":"\/identifier\/interfaceLanguage"},{"op":"add","value":null,"path":"\/topicSections"},{"op":"replace","value":[{"anchor":"Features","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Deep-Linking","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Commenting","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Advertisements","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Media-Playback","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Search"],"title":"Features","generated":true}],"path":"\/seeAlsoSections"}]}]}