{"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions"},"metadata":{"title":"Replica and Feed Editions","roleHeading":"Article","role":"article","modules":[{"name":"PSReaderUI"}]},"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"abstract":[{"type":"text","text":"Understand the two backend systems that power PSReaderUI content."}],"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The PSReaderUI SDK supports two distinct backend systems for delivering digital"},{"type":"text","text":" "},{"type":"text","text":"publication content. Which system your publications use determines the content"},{"type":"text","text":" "},{"type":"text","text":"types you configure, the analytics events you receive, and which delegate"},{"type":"text","text":" "},{"type":"text","text":"methods the SDK calls."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Consult the PageSuite portal or your account manager to determine which system"},{"type":"text","text":" "},{"type":"text","text":"applies to your publications."}]},{"type":"heading","text":"Shortcodes","anchor":"Shortcodes","level":2},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"shortcode"}]},{"text":" is a remote configuration set up in the PageSuite portal that","type":"text"},{"text":" ","type":"text"},{"text":"maps to your publication setup. When you use a shortcode with ","type":"text"},{"type":"codeVoice","code":".dynamicArchive"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"the SDK fetches this configuration and automatically populates the correct","type":"text"},{"text":" ","type":"text"},{"text":"publications — routing to either the feed or replica system as appropriate.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":[".dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the "},{"type":"strong","inlineContent":[{"type":"text","text":"recommended approach"}]},{"type":"text","text":" for loading content. You don’t need to"},{"type":"text","text":" "},{"type":"text","text":"manage GUIDs yourself or know which backend system your publications use — the"},{"type":"text","text":" "},{"type":"text","text":"shortcode handles it. See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup"},{"type":"text","text":" for more detail on configuring"},{"type":"text","text":" "},{"type":"text","text":"sections."}]},{"type":"heading","text":"Feed Editions","anchor":"Feed-Editions","level":2},{"type":"paragraph","inlineContent":[{"text":"Feed editions are the ","type":"text"},{"inlineContent":[{"text":"modern","type":"text"}],"type":"strong"},{"text":" content system. They deliver a mix of HTML","type":"text"},{"text":" ","type":"text"},{"text":"article templates and PDF pages, enabling responsive layouts that adapt to","type":"text"},{"text":" ","type":"text"},{"text":"different screen sizes and orientations. Key advantages over replica editions","type":"text"},{"text":" ","type":"text"},{"text":"include:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Rich templates","type":"text"}]},{"type":"text","text":" — elaborate article layouts such as multi-column templates"},{"type":"text","text":" "},{"type":"text","text":"that go beyond a static PDF reproduction."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In-flow advertising"}]},{"type":"text","text":" — greater support for ads placed directly within"},{"type":"text","text":" "},{"type":"text","text":"article content."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Faster backend"}]},{"text":" — improved content delivery for quicker load times.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Feed edition publications are identified by an "},{"type":"strong","inlineContent":[{"type":"text","text":"application GUID"}]},{"type":"text","text":". When"},{"type":"text","text":" "},{"type":"text","text":"configuring sections manually (without a shortcode), use the "},{"type":"codeVoice","code":".feedArchive"},{"type":"text","text":" "},{"type":"text","text":"content type:"}]},{"type":"codeListing","syntax":"swift","code":[".section(.init(name: \"Editions\", type: .feedArchive(guid: \"APP_GUID\")))"]},{"type":"heading","text":"Replica Editions","anchor":"Replica-Editions","level":2},{"type":"paragraph","inlineContent":[{"text":"Replica editions are the ","type":"text"},{"inlineContent":[{"type":"text","text":"legacy"}],"type":"strong"},{"text":" content system. They deliver PDF-only","type":"text"},{"text":" ","type":"text"},{"text":"pages that reproduce the print layout of a publication. Users navigate through","type":"text"},{"text":" ","type":"text"},{"text":"a faithful digital replica of the printed product.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Replica publications are identified by a "},{"type":"strong","inlineContent":[{"type":"text","text":"publication GUID"}]},{"type":"text","text":". When configuring"},{"type":"text","text":" "},{"type":"text","text":"sections manually (without a shortcode), use the "},{"type":"codeVoice","code":".replicaArchive"},{"type":"text","text":" content type:"}]},{"type":"codeListing","syntax":"swift","code":[".section(.init(name: \"Editions\", type: .replicaArchive(guid: \"PUB_GUID\")))"]},{"type":"heading","text":"Transition","anchor":"Transition","level":2},{"type":"paragraph","inlineContent":[{"text":"PageSuite is transitioning publications from the replica system to feed","type":"text"},{"text":" ","type":"text"},{"text":"editions. New publications are typically set up as feed editions, while","type":"text"},{"text":" ","type":"text"},{"text":"existing replica publications may be migrated over time. Your account manager","type":"text"},{"text":" ","type":"text"},{"text":"can advise on the timeline and steps for any migration.","type":"text"}]},{"type":"heading","text":"Impact on the SDK","anchor":"Impact-on-the-SDK","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The backend system affects several areas of the SDK:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Content types","type":"text"}]},{"type":"text","text":" — Use "},{"type":"codeVoice","code":".feedArchive"},{"type":"text","text":" for feed editions and"},{"type":"text","text":" "},{"type":"codeVoice","code":".replicaArchive"},{"type":"text","text":" for replica editions when configuring sections manually."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"codeVoice","code":".dynamicArchive"},{"type":"text","text":" with a shortcode to let the SDK choose automatically."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Analytics events"}],"type":"strong"},{"text":" — Feed editions emit ","type":"text"},{"code":"feedEdition*","type":"codeVoice"},{"text":" events; replica","type":"text"},{"text":" ","type":"text"},{"text":"editions emit ","type":"text"},{"code":"replica*","type":"codeVoice"},{"text":" events. See ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","isActive":true},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Paywall delegate methods","type":"text"}],"type":"strong"},{"type":"text","text":" — Separate delegate methods exist for opening"},{"type":"text","text":" "},{"type":"text","text":"and downloading feed vs replica editions. See "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Share delegate methods"}],"type":"strong"},{"text":" — Separate methods handle sharing for feed pages","type":"text"},{"text":" ","type":"text"},{"text":"and replica spreads. See ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","type":"reference"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Audio delegate methods","type":"text"}],"type":"strong"},{"type":"text","text":" — Separate methods handle TTS for feed pages"},{"type":"text","text":" "},{"type":"text","text":"and replica spreads. See "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","type":"reference","isActive":true},{"type":"text","text":"."}]}]}]},{"type":"heading","text":"Replica Reader Variants","anchor":"Replica-Reader-Variants","level":2},{"type":"paragraph","inlineContent":[{"text":"Replica editions can be displayed using one of two reader implementations:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Legacy reader"}]},{"text":" — the original PDF reader with its own navigation and","type":"text"},{"text":" ","type":"text"},{"text":"toolbar UI. Configured via ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyReaderConfiguration","isActive":true},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Modern reader","type":"text"}]},{"type":"text","text":" — a newer implementation whose look and feel matches the"},{"type":"text","text":" "},{"type":"text","text":"feed edition reader, providing a consistent experience across both systems."}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The active reader is controlled by ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration\/useLegacyReplicaReader"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The default is currently ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" (legacy), but will change to ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" (modern)","type":"text"},{"text":" ","type":"text"},{"text":"in a future release. If you are starting a new integration, consider using the","type":"text"},{"text":" ","type":"text"},{"text":"modern reader from the outset.","type":"text"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/psreaderui\/replica-and-feed-editions"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/psreaderui\/replica-and-feed-editions"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI":{"role":"collection","type":"topic","kind":"symbol","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI","url":"\/documentation\/psreaderui","abstract":[{"type":"text","text":"A UI framework for building digital newspaper and magazine reader experiences on iOS."}],"title":"PSReaderUI"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Text-to-Speech":{"kind":"article","title":"Text-to-Speech","type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","role":"article","abstract":[{"type":"text","text":"Add audio playback of article content using the SDK’s text-to-speech system."}],"url":"\/documentation\/psreaderui\/text-to-speech"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/LegacyReaderConfiguration":{"url":"\/documentation\/psreaderui\/legacyreaderconfiguration","type":"topic","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LegacyReaderConfiguration","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"LegacyReaderConfiguration","kind":"identifier"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyReaderConfiguration","title":"LegacyReaderConfiguration","abstract":[{"text":"Configuration object for customizing the appearance, behavior, and sharing","type":"text"},{"text":" ","type":"text"},{"text":"strategies of the legacy replica reader.","type":"text"}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Analytics":{"abstract":[{"type":"text","text":"Track user interactions and content engagement across the PSReaderUI SDK."}],"title":"Analytics","type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","kind":"article","url":"\/documentation\/psreaderui\/analytics","role":"article"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/ReaderConfiguration/useLegacyReplicaReader":{"kind":"symbol","abstract":[{"text":"When ","type":"text"},{"code":"true","type":"codeVoice"},{"text":", uses the legacy replica reader instead of the modern implementation.","type":"text"}],"type":"topic","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"useLegacyReplicaReader"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration\/useLegacyReplicaReader","title":"useLegacyReplicaReader","role":"symbol","url":"\/documentation\/psreaderui\/readerconfiguration\/uselegacyreplicareader"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Paywall-Integration":{"url":"\/documentation\/psreaderui\/paywall-integration","type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","title":"Paywall Integration","role":"article","abstract":[{"type":"text","text":"Restrict access to premium content with custom paywall screens."}],"kind":"article"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Carousel-Setup":{"type":"topic","abstract":[{"type":"text","text":"Configure the carousel’s sections, content sources, and layout."}],"title":"Carousel Setup","kind":"article","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup","url":"\/documentation\/psreaderui\/carousel-setup","role":"article"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Sharing":{"kind":"article","url":"\/documentation\/psreaderui\/sharing","abstract":[{"text":"Configure how users share edition content from the reader.","type":"text"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","title":"Sharing","role":"article","type":"topic"}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"op":"replace","value":"occ","path":"\/identifier\/interfaceLanguage"},{"op":"add","value":null,"path":"\/topicSections"},{"op":"add","value":null,"path":"\/seeAlsoSections"}]}]}