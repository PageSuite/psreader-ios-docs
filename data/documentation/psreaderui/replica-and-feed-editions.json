{"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"kind":"article","variants":[{"paths":["\/documentation\/psreaderui\/replica-and-feed-editions"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/psreaderui\/replica-and-feed-editions"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"role":"article","roleHeading":"Article","modules":[{"name":"PSReaderUI"}],"title":"Replica and Feed Editions"},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"text":"Understand the two backend systems that power PSReaderUI content.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"The PSReaderUI SDK supports two distinct backend systems for delivering digital"},{"type":"text","text":" "},{"type":"text","text":"publication content. Which system your publications use determines the content"},{"type":"text","text":" "},{"type":"text","text":"types you configure, the analytics events you receive, and which delegate"},{"type":"text","text":" "},{"type":"text","text":"methods the SDK calls."}],"type":"paragraph"},{"inlineContent":[{"text":"Consult the PageSuite portal or your account manager to determine which system","type":"text"},{"text":" ","type":"text"},{"text":"applies to your publications.","type":"text"}],"type":"paragraph"},{"text":"Shortcodes","level":2,"anchor":"Shortcodes","type":"heading"},{"inlineContent":[{"type":"text","text":"A "},{"type":"strong","inlineContent":[{"text":"shortcode","type":"text"}]},{"type":"text","text":" is a remote configuration set up in the PageSuite portal that"},{"type":"text","text":" "},{"type":"text","text":"maps to your publication setup. When you use a shortcode with "},{"type":"codeVoice","code":".dynamicArchive"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the SDK fetches this configuration and automatically populates the correct"},{"type":"text","text":" "},{"type":"text","text":"publications — routing to either the feed or replica system as appropriate."}],"type":"paragraph"},{"code":[".dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\")"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"This is the ","type":"text"},{"inlineContent":[{"type":"text","text":"recommended approach"}],"type":"strong"},{"text":" for loading content. You don’t need to","type":"text"},{"text":" ","type":"text"},{"text":"manage GUIDs yourself or know which backend system your publications use — the","type":"text"},{"text":" ","type":"text"},{"text":"shortcode handles it. See ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup"},{"text":" for more detail on configuring","type":"text"},{"text":" ","type":"text"},{"text":"sections.","type":"text"}],"type":"paragraph"},{"text":"Feed Editions","level":2,"anchor":"Feed-Editions","type":"heading"},{"inlineContent":[{"text":"Feed editions are the ","type":"text"},{"type":"strong","inlineContent":[{"text":"modern","type":"text"}]},{"type":"text","text":" content system. They deliver a mix of HTML"},{"type":"text","text":" "},{"type":"text","text":"article templates and PDF pages, enabling responsive layouts that adapt to"},{"type":"text","text":" "},{"type":"text","text":"different screen sizes and orientations. Key advantages over replica editions"},{"type":"text","text":" "},{"type":"text","text":"include:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Rich templates","type":"text"}]},{"type":"text","text":" — elaborate article layouts such as multi-column templates"},{"type":"text","text":" "},{"type":"text","text":"that go beyond a static PDF reproduction."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"In-flow advertising"}],"type":"strong"},{"text":" — greater support for ads placed directly within","type":"text"},{"text":" ","type":"text"},{"text":"article content.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Faster backend","type":"text"}]},{"type":"text","text":" — improved content delivery for quicker load times."}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Feed edition publications are identified by an "},{"type":"strong","inlineContent":[{"type":"text","text":"application GUID"}]},{"type":"text","text":". When"},{"type":"text","text":" "},{"type":"text","text":"configuring sections manually (without a shortcode), use the "},{"type":"codeVoice","code":".feedArchive"},{"type":"text","text":" "},{"type":"text","text":"content type:"}],"type":"paragraph"},{"code":[".section(.init(name: \"Editions\", type: .feedArchive(guid: \"APP_GUID\")))"],"syntax":"swift","type":"codeListing"},{"text":"Replica Editions","level":2,"anchor":"Replica-Editions","type":"heading"},{"inlineContent":[{"text":"Replica editions are the ","type":"text"},{"inlineContent":[{"text":"legacy","type":"text"}],"type":"strong"},{"text":" content system. They deliver PDF-only","type":"text"},{"text":" ","type":"text"},{"text":"pages that reproduce the print layout of a publication. Users navigate through","type":"text"},{"text":" ","type":"text"},{"text":"a faithful digital replica of the printed product.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Replica publications are identified by a ","type":"text"},{"inlineContent":[{"text":"publication GUID","type":"text"}],"type":"strong"},{"text":". When configuring","type":"text"},{"text":" ","type":"text"},{"text":"sections manually (without a shortcode), use the ","type":"text"},{"code":".replicaArchive","type":"codeVoice"},{"text":" content type:","type":"text"}],"type":"paragraph"},{"code":[".section(.init(name: \"Editions\", type: .replicaArchive(guid: \"PUB_GUID\")))"],"syntax":"swift","type":"codeListing"},{"text":"Transition","level":2,"anchor":"Transition","type":"heading"},{"inlineContent":[{"text":"PageSuite is transitioning publications from the replica system to feed","type":"text"},{"text":" ","type":"text"},{"text":"editions. New publications are typically set up as feed editions, while","type":"text"},{"text":" ","type":"text"},{"text":"existing replica publications may be migrated over time. Your account manager","type":"text"},{"text":" ","type":"text"},{"text":"can advise on the timeline and steps for any migration.","type":"text"}],"type":"paragraph"},{"text":"Impact on the SDK","level":2,"anchor":"Impact-on-the-SDK","type":"heading"},{"inlineContent":[{"type":"text","text":"The backend system affects several areas of the SDK:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Content types"}],"type":"strong"},{"type":"text","text":" — Use "},{"type":"codeVoice","code":".feedArchive"},{"type":"text","text":" for feed editions and"},{"type":"text","text":" "},{"type":"codeVoice","code":".replicaArchive"},{"type":"text","text":" for replica editions when configuring sections manually."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"codeVoice","code":".dynamicArchive"},{"type":"text","text":" with a shortcode to let the SDK choose automatically."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Analytics events","type":"text"}],"type":"strong"},{"type":"text","text":" — Feed editions emit "},{"type":"codeVoice","code":"feedEdition*"},{"type":"text","text":" events; replica"},{"type":"text","text":" "},{"type":"text","text":"editions emit "},{"type":"codeVoice","code":"replica*"},{"type":"text","text":" events. See "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Paywall delegate methods"}],"type":"strong"},{"type":"text","text":" — Separate delegate methods exist for opening"},{"type":"text","text":" "},{"type":"text","text":"and downloading feed vs replica editions. See "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","isActive":true,"type":"reference"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Share delegate methods","type":"text"}]},{"type":"text","text":" — Separate methods handle sharing for feed pages"},{"type":"text","text":" "},{"type":"text","text":"and replica spreads. See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Audio delegate methods"}]},{"text":" — Separate methods handle TTS for feed pages","type":"text"},{"text":" ","type":"text"},{"text":"and replica spreads. See ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Replica Reader Variants","level":2,"anchor":"Replica-Reader-Variants","type":"heading"},{"inlineContent":[{"text":"Replica editions can be displayed using one of two reader implementations:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Legacy reader","type":"text"}]},{"text":" — the original PDF reader with its own navigation and","type":"text"},{"text":" ","type":"text"},{"text":"toolbar UI. Configured via ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyReaderConfiguration"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Modern reader"}],"type":"strong"},{"type":"text","text":" — a newer implementation whose look and feel matches the"},{"type":"text","text":" "},{"type":"text","text":"feed edition reader, providing a consistent experience across both systems."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"The active reader is controlled by "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration\/useLegacyReplicaReader","type":"reference","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The default is currently "},{"type":"codeVoice","code":"true"},{"type":"text","text":" (legacy), but will change to "},{"type":"codeVoice","code":"false"},{"type":"text","text":" (modern)"},{"type":"text","text":" "},{"type":"text","text":"in a future release. If you are starting a new integration, consider using the"},{"type":"text","text":" "},{"type":"text","text":"modern reader from the outset."}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions","interfaceLanguage":"swift"},"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Analytics":{"abstract":[{"type":"text","text":"Track user interactions and content engagement across the PSReaderUI SDK."}],"role":"article","kind":"article","url":"\/documentation\/psreaderui\/analytics","title":"Analytics","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","type":"topic"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI":{"type":"topic","abstract":[{"text":"A UI framework for building digital newspaper and magazine reader experiences on iOS.","type":"text"}],"url":"\/documentation\/psreaderui","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI","title":"PSReaderUI","role":"collection","kind":"symbol"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Sharing":{"url":"\/documentation\/psreaderui\/sharing","kind":"article","title":"Sharing","abstract":[{"type":"text","text":"Configure how users share edition content from the reader."}],"role":"article","type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/ReaderConfiguration/useLegacyReplicaReader":{"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"useLegacyReplicaReader"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"type":"topic","kind":"symbol","url":"\/documentation\/psreaderui\/readerconfiguration\/uselegacyreplicareader","title":"useLegacyReplicaReader","abstract":[{"text":"When ","type":"text"},{"code":"true","type":"codeVoice"},{"text":", uses the legacy replica reader instead of the modern implementation.","type":"text"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration\/useLegacyReplicaReader"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Carousel-Setup":{"type":"topic","abstract":[{"text":"Configure the carousel’s sections, content sources, and layout.","type":"text"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup","role":"article","url":"\/documentation\/psreaderui\/carousel-setup","kind":"article","title":"Carousel Setup"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Paywall-Integration":{"role":"article","url":"\/documentation\/psreaderui\/paywall-integration","type":"topic","abstract":[{"type":"text","text":"Restrict access to premium content with custom paywall screens."}],"title":"Paywall Integration","kind":"article","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/LegacyReaderConfiguration":{"navigatorTitle":[{"text":"LegacyReaderConfiguration","kind":"identifier"}],"abstract":[{"text":"Configuration object for customizing the appearance, behavior, and sharing","type":"text"},{"text":" ","type":"text"},{"text":"strategies of the legacy replica reader.","type":"text"}],"title":"LegacyReaderConfiguration","url":"\/documentation\/psreaderui\/legacyreaderconfiguration","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyReaderConfiguration","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LegacyReaderConfiguration","kind":"identifier"}],"kind":"symbol","type":"topic","role":"symbol"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Text-to-Speech":{"role":"article","kind":"article","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","abstract":[{"text":"Add audio playback of article content using the SDK’s text-to-speech system.","type":"text"}],"type":"topic","title":"Text-to-Speech","url":"\/documentation\/psreaderui\/text-to-speech"}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"value":"occ","path":"\/identifier\/interfaceLanguage","op":"replace"},{"value":null,"path":"\/topicSections","op":"add"},{"value":null,"path":"\/seeAlsoSections","op":"add"}]}]}