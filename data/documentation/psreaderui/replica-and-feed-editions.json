{"kind":"article","primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"The PSReaderUI SDK supports two distinct backend systems for delivering digital"},{"type":"text","text":" "},{"type":"text","text":"publication content. Which system your publications use determines the content"},{"type":"text","text":" "},{"type":"text","text":"types you configure, the analytics events you receive, and which delegate"},{"type":"text","text":" "},{"type":"text","text":"methods the SDK calls."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Consult the PageSuite portal or your account manager to determine which system"},{"type":"text","text":" "},{"type":"text","text":"applies to your publications."}],"type":"paragraph"},{"level":2,"text":"Shortcodes","anchor":"Shortcodes","type":"heading"},{"inlineContent":[{"type":"text","text":"A "},{"type":"strong","inlineContent":[{"text":"shortcode","type":"text"}]},{"type":"text","text":" is a remote configuration set up in the PageSuite portal that"},{"type":"text","text":" "},{"type":"text","text":"maps to your publication setup. When you use a shortcode with "},{"type":"codeVoice","code":".dynamicArchive"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the SDK fetches this configuration and automatically populates the correct"},{"type":"text","text":" "},{"type":"text","text":"publications — routing to either the feed or replica system as appropriate."}],"type":"paragraph"},{"code":[".dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\")"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"This is the ","type":"text"},{"inlineContent":[{"type":"text","text":"recommended approach"}],"type":"strong"},{"text":" for loading content. You don’t need to","type":"text"},{"text":" ","type":"text"},{"text":"manage GUIDs yourself or know which backend system your publications use — the","type":"text"},{"text":" ","type":"text"},{"text":"shortcode handles it. See ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup","isActive":true,"type":"reference"},{"text":" for more detail on configuring","type":"text"},{"text":" ","type":"text"},{"text":"sections.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Feed Editions","anchor":"Feed-Editions","type":"heading"},{"inlineContent":[{"text":"Feed editions are the ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"modern"}]},{"text":" content system. They deliver a mix of HTML","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"article templates and PDF pages, enabling responsive layouts that adapt to"},{"type":"text","text":" "},{"type":"text","text":"different screen sizes and orientations. Key advantages over replica editions"},{"type":"text","text":" "},{"type":"text","text":"include:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Rich templates","type":"text"}],"type":"strong"},{"text":" — elaborate article layouts such as multi-column templates","type":"text"},{"text":" ","type":"text"},{"text":"that go beyond a static PDF reproduction.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"In-flow advertising"}],"type":"strong"},{"text":" — greater support for ads placed directly within","type":"text"},{"text":" ","type":"text"},{"text":"article content.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Faster backend"}],"type":"strong"},{"text":" — improved content delivery for quicker load times.","type":"text"}]}]}]},{"inlineContent":[{"text":"Feed edition publications are identified by an ","type":"text"},{"inlineContent":[{"text":"application GUID","type":"text"}],"type":"strong"},{"text":". When","type":"text"},{"text":" ","type":"text"},{"text":"configuring sections manually (without a shortcode), use the ","type":"text"},{"code":".feedArchive","type":"codeVoice"},{"text":" ","type":"text"},{"text":"content type:","type":"text"}],"type":"paragraph"},{"code":[".section(.init(name: \"Editions\", type: .feedArchive(guid: \"APP_GUID\")))"],"type":"codeListing","syntax":"swift"},{"level":2,"text":"Replica Editions","anchor":"Replica-Editions","type":"heading"},{"inlineContent":[{"type":"text","text":"Replica editions are the "},{"type":"strong","inlineContent":[{"text":"legacy","type":"text"}]},{"type":"text","text":" content system. They deliver PDF-only"},{"type":"text","text":" "},{"type":"text","text":"pages that reproduce the print layout of a publication. Users navigate through"},{"type":"text","text":" "},{"type":"text","text":"a faithful digital replica of the printed product."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Replica publications are identified by a "},{"type":"strong","inlineContent":[{"text":"publication GUID","type":"text"}]},{"type":"text","text":". When configuring"},{"type":"text","text":" "},{"type":"text","text":"sections manually (without a shortcode), use the "},{"type":"codeVoice","code":".replicaArchive"},{"type":"text","text":" content type:"}],"type":"paragraph"},{"code":[".section(.init(name: \"Editions\", type: .replicaArchive(guid: \"PUB_GUID\")))"],"type":"codeListing","syntax":"swift"},{"level":2,"text":"Transition","anchor":"Transition","type":"heading"},{"inlineContent":[{"type":"text","text":"PageSuite is transitioning publications from the replica system to feed"},{"type":"text","text":" "},{"type":"text","text":"editions. New publications are typically set up as feed editions, while"},{"type":"text","text":" "},{"type":"text","text":"existing replica publications may be migrated over time. Your account manager"},{"type":"text","text":" "},{"type":"text","text":"can advise on the timeline and steps for any migration."}],"type":"paragraph"},{"level":2,"text":"Impact on the SDK","anchor":"Impact-on-the-SDK","type":"heading"},{"inlineContent":[{"text":"The backend system affects several areas of the SDK:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Content types"}]},{"type":"text","text":" — Use "},{"type":"codeVoice","code":".feedArchive"},{"type":"text","text":" for feed editions and"},{"type":"text","text":" "},{"type":"codeVoice","code":".replicaArchive"},{"type":"text","text":" for replica editions when configuring sections manually."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"codeVoice","code":".dynamicArchive"},{"type":"text","text":" with a shortcode to let the SDK choose automatically."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Analytics events","type":"text"}]},{"type":"text","text":" — Feed editions emit "},{"type":"codeVoice","code":"feedEdition*"},{"type":"text","text":" events; replica"},{"type":"text","text":" "},{"type":"text","text":"editions emit "},{"type":"codeVoice","code":"replica*"},{"type":"text","text":" events. See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Paywall delegate methods","type":"text"}]},{"type":"text","text":" — Separate delegate methods exist for opening"},{"type":"text","text":" "},{"type":"text","text":"and downloading feed vs replica editions. See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Share delegate methods"}],"type":"strong"},{"text":" — Separate methods handle sharing for feed pages","type":"text"},{"text":" ","type":"text"},{"text":"and replica spreads. See ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Audio delegate methods","type":"text"}]},{"type":"text","text":" — Separate methods handle TTS for feed pages"},{"type":"text","text":" "},{"type":"text","text":"and replica spreads. See "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","isActive":true,"type":"reference"},{"type":"text","text":"."}]}]}]},{"level":2,"text":"Replica Reader Variants","anchor":"Replica-Reader-Variants","type":"heading"},{"inlineContent":[{"text":"Replica editions can be displayed using one of two reader implementations:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Legacy reader"}],"type":"strong"},{"text":" — the original PDF reader with its own navigation and","type":"text"},{"text":" ","type":"text"},{"text":"toolbar UI. Configured via ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyReaderConfiguration","isActive":true,"type":"reference"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Modern reader"}]},{"type":"text","text":" — a newer implementation whose look and feel matches the"},{"type":"text","text":" "},{"type":"text","text":"feed edition reader, providing a consistent experience across both systems."}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"The active reader is controlled by ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration\/useLegacyReplicaReader","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The default is currently ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" (legacy), but will change to ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" (modern)","type":"text"},{"text":" ","type":"text"},{"text":"in a future release. If you are starting a new integration, consider using the","type":"text"},{"text":" ","type":"text"},{"text":"modern reader from the outset.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"text":"Understand the two backend systems that power PSReaderUI content.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/replica-and-feed-editions"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/psreaderui\/replica-and-feed-editions"]}],"sections":[],"metadata":{"roleHeading":"Article","role":"article","title":"Replica and Feed Editions","modules":[{"name":"PSReaderUI"}]},"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions"},"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Text-to-Speech":{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","kind":"article","role":"article","url":"\/documentation\/psreaderui\/text-to-speech","type":"topic","abstract":[{"text":"Add audio playback of article content using the SDK’s text-to-speech system.","type":"text"}],"title":"Text-to-Speech"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/LegacyReaderConfiguration":{"type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyReaderConfiguration","title":"LegacyReaderConfiguration","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LegacyReaderConfiguration","kind":"identifier"}],"abstract":[{"text":"Configuration object for customizing the appearance, behavior, and sharing","type":"text"},{"text":" ","type":"text"},{"text":"strategies of the legacy replica reader.","type":"text"}],"role":"symbol","url":"\/documentation\/psreaderui\/legacyreaderconfiguration","navigatorTitle":[{"text":"LegacyReaderConfiguration","kind":"identifier"}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Carousel-Setup":{"type":"topic","abstract":[{"type":"text","text":"Configure the carousel’s sections, content sources, and layout."}],"url":"\/documentation\/psreaderui\/carousel-setup","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup","kind":"article","title":"Carousel Setup","role":"article"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Sharing":{"url":"\/documentation\/psreaderui\/sharing","kind":"article","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","role":"article","abstract":[{"type":"text","text":"Configure how users share edition content from the reader."}],"type":"topic","title":"Sharing"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Analytics":{"role":"article","title":"Analytics","type":"topic","abstract":[{"text":"Track user interactions and content engagement across the PSReaderUI SDK.","type":"text"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","kind":"article","url":"\/documentation\/psreaderui\/analytics"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI":{"kind":"symbol","url":"\/documentation\/psreaderui","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI","title":"PSReaderUI","abstract":[{"type":"text","text":"A UI framework for building digital newspaper and magazine reader experiences on iOS."}],"type":"topic","role":"collection"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/ReaderConfiguration/useLegacyReplicaReader":{"kind":"symbol","abstract":[{"type":"text","text":"When "},{"type":"codeVoice","code":"true"},{"type":"text","text":", uses the legacy replica reader instead of the modern implementation."}],"title":"useLegacyReplicaReader","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"useLegacyReplicaReader"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"url":"\/documentation\/psreaderui\/readerconfiguration\/uselegacyreplicareader","role":"symbol","type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration\/useLegacyReplicaReader"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Paywall-Integration":{"abstract":[{"text":"Restrict access to premium content with custom paywall screens.","type":"text"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","role":"article","kind":"article","url":"\/documentation\/psreaderui\/paywall-integration","type":"topic","title":"Paywall Integration"}},"variantOverrides":[{"patch":[{"path":"\/identifier\/interfaceLanguage","op":"replace","value":"occ"},{"path":"\/topicSections","op":"add","value":null},{"path":"\/seeAlsoSections","op":"add","value":null}],"traits":[{"interfaceLanguage":"occ"}]}]}