{"abstract":[{"type":"text","text":"Understand the two backend systems that power PSReaderUI content."}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The PSReaderUI SDK supports two distinct backend systems for delivering digital"},{"type":"text","text":" "},{"type":"text","text":"publication content. Which system your publications use determines the content"},{"type":"text","text":" "},{"type":"text","text":"types you configure, the analytics events you receive, and which delegate"},{"type":"text","text":" "},{"type":"text","text":"methods the SDK calls."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Consult the PageSuite portal or your account manager to determine which system"},{"type":"text","text":" "},{"type":"text","text":"applies to your publications."}],"type":"paragraph"},{"anchor":"Shortcodes","text":"Shortcodes","type":"heading","level":2},{"inlineContent":[{"text":"A ","type":"text"},{"inlineContent":[{"type":"text","text":"shortcode"}],"type":"strong"},{"text":" is a remote configuration set up in the PageSuite portal that","type":"text"},{"text":" ","type":"text"},{"text":"maps to your publication setup. When you use a shortcode with ","type":"text"},{"code":".dynamicArchive","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"the SDK fetches this configuration and automatically populates the correct","type":"text"},{"text":" ","type":"text"},{"text":"publications — routing to either the feed or replica system as appropriate.","type":"text"}],"type":"paragraph"},{"code":[".dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\")"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"This is the "},{"type":"strong","inlineContent":[{"type":"text","text":"recommended approach"}]},{"type":"text","text":" for loading content. You don’t need to"},{"type":"text","text":" "},{"type":"text","text":"manage GUIDs yourself or know which backend system your publications use — the"},{"type":"text","text":" "},{"type":"text","text":"shortcode handles it. See "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup","isActive":true},{"type":"text","text":" for more detail on configuring"},{"type":"text","text":" "},{"type":"text","text":"sections."}],"type":"paragraph"},{"anchor":"Feed-Editions","text":"Feed Editions","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Feed editions are the "},{"type":"strong","inlineContent":[{"type":"text","text":"modern"}]},{"type":"text","text":" content system. They deliver a mix of HTML"},{"type":"text","text":" "},{"type":"text","text":"article templates and PDF pages, enabling responsive layouts that adapt to"},{"type":"text","text":" "},{"type":"text","text":"different screen sizes and orientations. Key advantages over replica editions"},{"type":"text","text":" "},{"type":"text","text":"include:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Rich templates","type":"text"}]},{"type":"text","text":" — elaborate article layouts such as multi-column templates"},{"type":"text","text":" "},{"type":"text","text":"that go beyond a static PDF reproduction."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"In-flow advertising","type":"text"}],"type":"strong"},{"text":" — greater support for ads placed directly within","type":"text"},{"text":" ","type":"text"},{"text":"article content.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Faster backend"}],"type":"strong"},{"type":"text","text":" — improved content delivery for quicker load times."}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"Feed edition publications are identified by an ","type":"text"},{"inlineContent":[{"text":"application GUID","type":"text"}],"type":"strong"},{"text":". When","type":"text"},{"text":" ","type":"text"},{"text":"configuring sections manually (without a shortcode), use the ","type":"text"},{"type":"codeVoice","code":".feedArchive"},{"text":" ","type":"text"},{"text":"content type:","type":"text"}],"type":"paragraph"},{"code":[".section(.init(name: \"Editions\", type: .feedArchive(guid: \"APP_GUID\")))"],"syntax":"swift","type":"codeListing"},{"anchor":"Replica-Editions","text":"Replica Editions","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Replica editions are the "},{"type":"strong","inlineContent":[{"text":"legacy","type":"text"}]},{"type":"text","text":" content system. They deliver PDF-only"},{"type":"text","text":" "},{"type":"text","text":"pages that reproduce the print layout of a publication. Users navigate through"},{"type":"text","text":" "},{"type":"text","text":"a faithful digital replica of the printed product."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Replica publications are identified by a "},{"inlineContent":[{"type":"text","text":"publication GUID"}],"type":"strong"},{"type":"text","text":". When configuring"},{"type":"text","text":" "},{"type":"text","text":"sections manually (without a shortcode), use the "},{"type":"codeVoice","code":".replicaArchive"},{"type":"text","text":" content type:"}],"type":"paragraph"},{"code":[".section(.init(name: \"Editions\", type: .replicaArchive(guid: \"PUB_GUID\")))"],"syntax":"swift","type":"codeListing"},{"anchor":"Transition","text":"Transition","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"PageSuite is transitioning publications from the replica system to feed"},{"type":"text","text":" "},{"type":"text","text":"editions. New publications are typically set up as feed editions, while"},{"type":"text","text":" "},{"type":"text","text":"existing replica publications may be migrated over time. Your account manager"},{"type":"text","text":" "},{"type":"text","text":"can advise on the timeline and steps for any migration."}],"type":"paragraph"},{"anchor":"Impact-on-the-SDK","text":"Impact on the SDK","type":"heading","level":2},{"inlineContent":[{"text":"The backend system affects several areas of the SDK:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Content types"}]},{"type":"text","text":" — Use "},{"type":"codeVoice","code":".feedArchive"},{"type":"text","text":" for feed editions and"},{"type":"text","text":" "},{"type":"codeVoice","code":".replicaArchive"},{"type":"text","text":" for replica editions when configuring sections manually."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"codeVoice","code":".dynamicArchive"},{"type":"text","text":" with a shortcode to let the SDK choose automatically."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Analytics events","type":"text"}],"type":"strong"},{"text":" — Feed editions emit ","type":"text"},{"code":"feedEdition*","type":"codeVoice"},{"text":" events; replica","type":"text"},{"text":" ","type":"text"},{"text":"editions emit ","type":"text"},{"code":"replica*","type":"codeVoice"},{"text":" events. See ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","type":"reference"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Paywall delegate methods","type":"text"}]},{"type":"text","text":" — Separate delegate methods exist for opening"},{"type":"text","text":" "},{"type":"text","text":"and downloading feed vs replica editions. See "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Share delegate methods","type":"text"}],"type":"strong"},{"type":"text","text":" — Separate methods handle sharing for feed pages"},{"type":"text","text":" "},{"type":"text","text":"and replica spreads. See "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Audio delegate methods","type":"text"}]},{"text":" — Separate methods handle TTS for feed pages","type":"text"},{"text":" ","type":"text"},{"text":"and replica spreads. See ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech"},{"text":".","type":"text"}]}]}]},{"anchor":"Replica-Reader-Variants","text":"Replica Reader Variants","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Replica editions can be displayed using one of two reader implementations:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Legacy reader"}],"type":"strong"},{"text":" — the original PDF reader with its own navigation and","type":"text"},{"text":" ","type":"text"},{"text":"toolbar UI. Configured via ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyReaderConfiguration","type":"reference"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Modern reader"}],"type":"strong"},{"text":" — a newer implementation whose look and feel matches the","type":"text"},{"text":" ","type":"text"},{"text":"feed edition reader, providing a consistent experience across both systems.","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The active reader is controlled by "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration\/useLegacyReplicaReader","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The default is currently "},{"type":"codeVoice","code":"true"},{"type":"text","text":" (legacy), but will change to "},{"type":"codeVoice","code":"false"},{"type":"text","text":" (modern)"},{"type":"text","text":" "},{"type":"text","text":"in a future release. If you are starting a new integration, consider using the"},{"type":"text","text":" "},{"type":"text","text":"modern reader from the outset."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/replica-and-feed-editions"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/psreaderui\/replica-and-feed-editions"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"kind":"article","metadata":{"modules":[{"name":"PSReaderUI"}],"roleHeading":"Article","role":"article","title":"Replica and Feed Editions"},"sections":[],"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Sharing":{"role":"article","url":"\/documentation\/psreaderui\/sharing","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","kind":"article","type":"topic","title":"Sharing","abstract":[{"text":"Configure how users share edition content from the reader.","type":"text"}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Carousel-Setup":{"role":"article","type":"topic","abstract":[{"text":"Configure the carousel’s sections, content sources, and layout.","type":"text"}],"title":"Carousel Setup","kind":"article","url":"\/documentation\/psreaderui\/carousel-setup","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/ReaderConfiguration/useLegacyReplicaReader":{"kind":"symbol","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration\/useLegacyReplicaReader","type":"topic","title":"useLegacyReplicaReader","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"useLegacyReplicaReader","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"role":"symbol","abstract":[{"text":"When ","type":"text"},{"code":"true","type":"codeVoice"},{"text":", uses the legacy replica reader instead of the modern implementation.","type":"text"}],"url":"\/documentation\/psreaderui\/readerconfiguration\/uselegacyreplicareader"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Text-to-Speech":{"type":"topic","title":"Text-to-Speech","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","abstract":[{"text":"Add audio playback of article content using the SDK’s text-to-speech system.","type":"text"}],"url":"\/documentation\/psreaderui\/text-to-speech","kind":"article","role":"article"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Analytics":{"type":"topic","title":"Analytics","kind":"article","role":"article","abstract":[{"type":"text","text":"Track user interactions and content engagement across the PSReaderUI SDK."}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","url":"\/documentation\/psreaderui\/analytics"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI":{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI","kind":"symbol","title":"PSReaderUI","url":"\/documentation\/psreaderui","role":"collection","type":"topic","abstract":[{"text":"A UI framework for building digital newspaper and magazine reader experiences on iOS.","type":"text"}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/LegacyReaderConfiguration":{"url":"\/documentation\/psreaderui\/legacyreaderconfiguration","type":"topic","abstract":[{"text":"Configuration object for customizing the appearance, behavior, and sharing","type":"text"},{"text":" ","type":"text"},{"text":"strategies of the legacy replica reader.","type":"text"}],"kind":"symbol","title":"LegacyReaderConfiguration","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"LegacyReaderConfiguration"}],"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyReaderConfiguration","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"LegacyReaderConfiguration"}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Paywall-Integration":{"kind":"article","url":"\/documentation\/psreaderui\/paywall-integration","role":"article","type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","title":"Paywall Integration","abstract":[{"type":"text","text":"Restrict access to premium content with custom paywall screens."}]}},"variantOverrides":[{"patch":[{"op":"replace","path":"\/identifier\/interfaceLanguage","value":"occ"},{"path":"\/topicSections","value":null,"op":"add"},{"path":"\/seeAlsoSections","value":null,"op":"add"}],"traits":[{"interfaceLanguage":"occ"}]}]}