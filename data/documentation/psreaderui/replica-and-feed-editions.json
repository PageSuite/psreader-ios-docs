{"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/replica-and-feed-editions"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/psreaderui\/replica-and-feed-editions"]}],"metadata":{"modules":[{"name":"PSReaderUI"}],"roleHeading":"Article","title":"Replica and Feed Editions","role":"article"},"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions"},"abstract":[{"type":"text","text":"Understand the two backend systems that power PSReaderUI content."}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"The PSReaderUI SDK supports two distinct backend systems for delivering digital","type":"text"},{"text":" ","type":"text"},{"text":"publication content. Which system your publications use determines the content","type":"text"},{"text":" ","type":"text"},{"text":"types you configure, the analytics events you receive, and which delegate","type":"text"},{"text":" ","type":"text"},{"text":"methods the SDK calls.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Consult the PageSuite portal or your account manager to determine which system"},{"type":"text","text":" "},{"type":"text","text":"applies to your publications."}]},{"type":"heading","text":"Shortcodes","anchor":"Shortcodes","level":2},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"inlineContent":[{"type":"text","text":"shortcode"}],"type":"strong"},{"text":" is a remote configuration set up in the PageSuite portal that","type":"text"},{"text":" ","type":"text"},{"text":"maps to your publication setup. When you use a shortcode with ","type":"text"},{"code":".dynamicArchive","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"the SDK fetches this configuration and automatically populates the correct","type":"text"},{"text":" ","type":"text"},{"text":"publications — routing to either the feed or replica system as appropriate.","type":"text"}]},{"type":"codeListing","code":[".dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This is the ","type":"text"},{"inlineContent":[{"text":"recommended approach","type":"text"}],"type":"strong"},{"text":" for loading content. You don’t need to","type":"text"},{"text":" ","type":"text"},{"text":"manage GUIDs yourself or know which backend system your publications use — the","type":"text"},{"text":" ","type":"text"},{"text":"shortcode handles it. See ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup"},{"text":" for more detail on configuring","type":"text"},{"text":" ","type":"text"},{"text":"sections.","type":"text"}]},{"type":"heading","text":"Feed Editions","anchor":"Feed-Editions","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Feed editions are the "},{"type":"strong","inlineContent":[{"type":"text","text":"modern"}]},{"type":"text","text":" content system. They deliver a mix of HTML"},{"type":"text","text":" "},{"type":"text","text":"article templates and PDF pages, enabling responsive layouts that adapt to"},{"type":"text","text":" "},{"type":"text","text":"different screen sizes and orientations. Key advantages over replica editions"},{"type":"text","text":" "},{"type":"text","text":"include:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Rich templates"}]},{"type":"text","text":" — elaborate article layouts such as multi-column templates"},{"type":"text","text":" "},{"type":"text","text":"that go beyond a static PDF reproduction."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"In-flow advertising","type":"text"}]},{"type":"text","text":" — greater support for ads placed directly within"},{"type":"text","text":" "},{"type":"text","text":"article content."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Faster backend"}]},{"type":"text","text":" — improved content delivery for quicker load times."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Feed edition publications are identified by an ","type":"text"},{"inlineContent":[{"type":"text","text":"application GUID"}],"type":"strong"},{"text":". When","type":"text"},{"text":" ","type":"text"},{"text":"configuring sections manually (without a shortcode), use the ","type":"text"},{"code":".feedArchive","type":"codeVoice"},{"text":" ","type":"text"},{"text":"content type:","type":"text"}]},{"code":[".section(.init(name: \"Editions\", type: .feedArchive(guid: \"APP_GUID\")))"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Replica-Editions","text":"Replica Editions","type":"heading"},{"inlineContent":[{"type":"text","text":"Replica editions are the "},{"type":"strong","inlineContent":[{"type":"text","text":"legacy"}]},{"type":"text","text":" content system. They deliver PDF-only"},{"type":"text","text":" "},{"type":"text","text":"pages that reproduce the print layout of a publication. Users navigate through"},{"type":"text","text":" "},{"type":"text","text":"a faithful digital replica of the printed product."}],"type":"paragraph"},{"inlineContent":[{"text":"Replica publications are identified by a ","type":"text"},{"inlineContent":[{"text":"publication GUID","type":"text"}],"type":"strong"},{"text":". When configuring","type":"text"},{"text":" ","type":"text"},{"text":"sections manually (without a shortcode), use the ","type":"text"},{"type":"codeVoice","code":".replicaArchive"},{"text":" content type:","type":"text"}],"type":"paragraph"},{"code":[".section(.init(name: \"Editions\", type: .replicaArchive(guid: \"PUB_GUID\")))"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Transition","text":"Transition","type":"heading"},{"inlineContent":[{"text":"PageSuite is transitioning publications from the replica system to feed","type":"text"},{"text":" ","type":"text"},{"text":"editions. New publications are typically set up as feed editions, while","type":"text"},{"text":" ","type":"text"},{"text":"existing replica publications may be migrated over time. Your account manager","type":"text"},{"text":" ","type":"text"},{"text":"can advise on the timeline and steps for any migration.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Impact-on-the-SDK","text":"Impact on the SDK","type":"heading"},{"inlineContent":[{"type":"text","text":"The backend system affects several areas of the SDK:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Content types","type":"text"}]},{"type":"text","text":" — Use "},{"type":"codeVoice","code":".feedArchive"},{"type":"text","text":" for feed editions and"},{"type":"text","text":" "},{"type":"codeVoice","code":".replicaArchive"},{"type":"text","text":" for replica editions when configuring sections manually."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"codeVoice","code":".dynamicArchive"},{"type":"text","text":" with a shortcode to let the SDK choose automatically."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Analytics events"}]},{"text":" — Feed editions emit ","type":"text"},{"type":"codeVoice","code":"feedEdition*"},{"text":" events; replica","type":"text"},{"text":" ","type":"text"},{"text":"editions emit ","type":"text"},{"type":"codeVoice","code":"replica*"},{"text":" events. See ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","isActive":true},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Paywall delegate methods"}]},{"type":"text","text":" — Separate delegate methods exist for opening"},{"type":"text","text":" "},{"type":"text","text":"and downloading feed vs replica editions. See "},{"isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","type":"reference"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Share delegate methods"}]},{"type":"text","text":" — Separate methods handle sharing for feed pages"},{"type":"text","text":" "},{"type":"text","text":"and replica spreads. See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Audio delegate methods"}]},{"type":"text","text":" — Separate methods handle TTS for feed pages"},{"type":"text","text":" "},{"type":"text","text":"and replica spreads. See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech"},{"type":"text","text":"."}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Replica-Reader-Variants","text":"Replica Reader Variants","type":"heading"},{"inlineContent":[{"text":"Replica editions can be displayed using one of two reader implementations:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Legacy reader","type":"text"}]},{"type":"text","text":" — the original PDF reader with its own navigation and"},{"type":"text","text":" "},{"type":"text","text":"toolbar UI. Configured via "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyReaderConfiguration","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Modern reader","type":"text"}]},{"text":" — a newer implementation whose look and feel matches the","type":"text"},{"text":" ","type":"text"},{"text":"feed edition reader, providing a consistent experience across both systems.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"The active reader is controlled by "},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration\/useLegacyReplicaReader","type":"reference","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The default is currently "},{"code":"true","type":"codeVoice"},{"type":"text","text":" (legacy), but will change to "},{"code":"false","type":"codeVoice"},{"type":"text","text":" (modern)"},{"type":"text","text":" "},{"type":"text","text":"in a future release. If you are starting a new integration, consider using the"},{"type":"text","text":" "},{"type":"text","text":"modern reader from the outset."}],"type":"paragraph"}]}],"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Carousel-Setup":{"title":"Carousel Setup","type":"topic","role":"article","kind":"article","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup","abstract":[{"type":"text","text":"Configure the carousel’s sections, content sources, and layout."}],"url":"\/documentation\/psreaderui\/carousel-setup"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/ReaderConfiguration/useLegacyReplicaReader":{"title":"useLegacyReplicaReader","kind":"symbol","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration\/useLegacyReplicaReader","type":"topic","url":"\/documentation\/psreaderui\/readerconfiguration\/uselegacyreplicareader","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"useLegacyReplicaReader"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"abstract":[{"text":"When ","type":"text"},{"code":"true","type":"codeVoice"},{"text":", uses the legacy replica reader instead of the modern implementation.","type":"text"}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI":{"url":"\/documentation\/psreaderui","type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI","kind":"symbol","title":"PSReaderUI","abstract":[{"type":"text","text":"A UI framework for building digital newspaper and magazine reader experiences on iOS."}],"role":"collection"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Analytics":{"type":"topic","title":"Analytics","abstract":[{"text":"Track user interactions and content engagement across the PSReaderUI SDK.","type":"text"}],"url":"\/documentation\/psreaderui\/analytics","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Analytics","kind":"article","role":"article"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Text-to-Speech":{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Text-to-Speech","url":"\/documentation\/psreaderui\/text-to-speech","kind":"article","type":"topic","abstract":[{"type":"text","text":"Add audio playback of article content using the SDK’s text-to-speech system."}],"title":"Text-to-Speech","role":"article"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/LegacyReaderConfiguration":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"LegacyReaderConfiguration"}],"kind":"symbol","title":"LegacyReaderConfiguration","abstract":[{"text":"Configuration object for customizing the appearance, behavior, and sharing","type":"text"},{"type":"text","text":" "},{"type":"text","text":"strategies of the legacy replica reader."}],"role":"symbol","url":"\/documentation\/psreaderui\/legacyreaderconfiguration","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/LegacyReaderConfiguration","type":"topic","navigatorTitle":[{"kind":"identifier","text":"LegacyReaderConfiguration"}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Sharing":{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Sharing","abstract":[{"type":"text","text":"Configure how users share edition content from the reader."}],"type":"topic","kind":"article","url":"\/documentation\/psreaderui\/sharing","title":"Sharing","role":"article"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Paywall-Integration":{"title":"Paywall Integration","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Paywall-Integration","abstract":[{"text":"Restrict access to premium content with custom paywall screens.","type":"text"}],"url":"\/documentation\/psreaderui\/paywall-integration","type":"topic","kind":"article","role":"article"}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"op":"replace","value":"occ","path":"\/identifier\/interfaceLanguage"},{"op":"add","value":null,"path":"\/topicSections"},{"op":"add","value":null,"path":"\/seeAlsoSections"}]}]}