{"abstract":[{"text":"Guidance to help you smoothly transition your app to newer versions of the SDK.","type":"text"},{"text":" ","type":"text"},{"text":"This page highlights breaking changes, necessary updates, and recommended","type":"text"},{"text":" ","type":"text"},{"text":"practices when migrating between versions.","type":"text"}],"kind":"article","primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"v26.1.0","anchor":"v2610"},{"inlineContent":[{"inlineContent":[{"text":"Archive limit defaults","type":"text"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"archiveLimit"},{"type":"text","text":" now defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", with type-specific behavior:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Replica archives: 30 editions (unchanged from previous releases)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Feed archives: unbounded — shows the full backend archive (usually ~1 year)."}]}]}]},{"inlineContent":[{"type":"text","text":"This is a behavior change for feed edition clients who previously saw a default"},{"type":"text","text":" "},{"type":"text","text":"of 30 editions. To restore the old behavior, explicitly set "},{"type":"codeVoice","code":"archiveLimit"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","archiveConfig.archiveLimit = 30"]},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Modern replica reader","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A modern replacement for the legacy replica reader is now available. It shares"},{"type":"text","text":" "},{"type":"text","text":"delegates and navigation with the feed edition reader, giving end users the same"},{"type":"text","text":" "},{"type":"text","text":"experience regardless of backend. Replica-specific analytics events still fire."}],"type":"paragraph"},{"inlineContent":[{"text":"Opt in by setting ","type":"text"},{"type":"codeVoice","code":"useLegacyReplicaReader"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"false"},{"text":" (defaults to ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" for","type":"text"},{"text":" ","type":"text"},{"text":"now). The modern reader will become the default in a future release, and the","type":"text"},{"text":" ","type":"text"},{"text":"legacy reader will be removed further out.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","archiveConfig.readerConfig.useLegacyReplicaReader = false"]},{"type":"aside","style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"The legacy reader’s content browser next\/previous button events are","type":"text"},{"text":" ","type":"text"},{"text":"not reported in the modern reader:","type":"text"},{"text":" ","type":"text"},{"code":"replicaPageBrowserNextTapped","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"replicaPageBrowserPreviousTapped","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"replicaArticleBrowserNextTapped","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"replicaArticleBrowserPreviousTapped","type":"codeVoice"},{"text":".","type":"text"}]}],"name":"Important"},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"LegacyReaderConfiguration"},{"text":" properties (e.g. ","type":"text"},{"type":"codeVoice","code":"shareTemplater"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"prefersStatusBarHidden"},{"text":", ","type":"text"},{"type":"codeVoice","code":"navigationBarItems"},{"text":") do not apply to the modern","type":"text"},{"text":" ","type":"text"},{"text":"reader — it uses the standard ","type":"text"},{"type":"codeVoice","code":"ReaderConfiguration"},{"text":" delegates instead.","type":"text"}]}],"name":"Note"},{"type":"heading","level":2,"text":"v5.5.0","anchor":"v550"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Liquid Glass UI defaults"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"text":"On iOS 26 and later, the SDK defaults to a new Liquid Glass design. The SDK","type":"text"},{"text":" ","type":"text"},{"text":"respects the host app’s ","type":"text"},{"code":"UIDesignRequiresCompatibility","type":"codeVoice"},{"text":" flag and will fall back","type":"text"},{"text":" ","type":"text"},{"text":"automatically on older OS versions. The new design can also be controlled via","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"LiquidGlassPolicy","type":"codeVoice"},{"text":" option. You can apply this globally or more granularly","type":"text"},{"text":" ","type":"text"},{"text":"on specific configuration objects (for example, subsection ribbon, navigation","type":"text"},{"text":" ","type":"text"},{"text":"bar, page browser, etc.). To disable it globally:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["var globalConfig = PSReaderUI.GlobalConfiguration(apiKey: apiKey, accountGUID: accountGUID)","globalConfig.liquidGlassPolicy = .disabled \/\/ disable Liquid Glass across the SDK"]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Archive thumbnail layout"}]}],"type":"paragraph"},{"inlineContent":[{"text":"Archive thumbnails now offer a dynamic layout mode:","type":"text"},{"text":" ","type":"text"},{"code":"ImageContentMode.flexibleHeight","type":"codeVoice"},{"text":". It lets edition artwork (including the","type":"text"},{"text":" ","type":"text"},{"text":"latest\/hero card) grow or shrink to its true aspect ratio, keeping the full","type":"text"},{"text":" ","type":"text"},{"text":"image visible instead of cropping. Start with an estimated ratio for a steady","type":"text"},{"text":" ","type":"text"},{"text":"initial layout; the SDK tunes the size automatically once the real image","type":"text"},{"text":" ","type":"text"},{"text":"arrives. Example:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","archiveConfig.thumbnailContentMode = .flexibleHeight(estimatedAspectRatio: 0.9)"]},{"type":"heading","level":2,"text":"v5.2.0","anchor":"v520"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Reader UI\/UX Changes"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"text":"In PDF-driven editions, PDF pages and articles are now segmented. Users can no","type":"text"},{"text":" ","type":"text"},{"text":"longer swipe between them. Articles are accessed either via article hotspot","type":"text"},{"text":" ","type":"text"},{"text":"links or through the content browser. The content browser is also segmented in","type":"text"},{"text":" ","type":"text"},{"text":"the same way, with a toggle that allows switching between pages and articles.","type":"text"},{"text":" ","type":"text"},{"text":"This behavior now matches the web reader.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The navigation bar layout has also been updated:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"The right-side back arrow has been removed."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The left-side icon now adapts to the current context:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Dismiss Article – If the user opened an article from a hotspot link, this","type":"text"},{"text":" ","type":"text"},{"text":"action returns them to the PDF page containing that article.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dismiss Reader – In all other cases, this action dismisses the reader"},{"type":"text","text":" "},{"type":"text","text":"view controller."}]}]}]}]}]},{"inlineContent":[{"text":"You can customize the icons for these actions via your ","type":"text"},{"code":"AssetDelegate","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["ImageResourceName.dismiss        \/\/ Default: back arrow","ImageResourceName.dismissArticle \/\/ Default: xmark"]},{"type":"heading","level":2,"text":"v5.0.0","anchor":"v500"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Edition Download Behavior"}]}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"5.0.0"},{"type":"text","text":" introduces the ability to read editions without downloading them."},{"type":"text","text":" "},{"type":"text","text":"This is the new default behavior. It can be customized by users via the reader"},{"type":"text","text":" "},{"type":"text","text":"settings menu. To retain the original default:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","archiveConfig.readerConfig.settings.downloadWhileReadingDefault = false","","\/\/ To hide the user facing setting","archiveConfig.readerConfig.settings.isDownloadWhileReadingToggleEnabled = false","archiveConfig.readerConfig.settings.isDownloadWhileReadingPreferenceAlertEnabled = false"]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Edition Date Formatting"}]}],"type":"paragraph"},{"inlineContent":[{"text":"Breaking Change: ","type":"text"},{"type":"codeVoice","code":"DateFormatter"},{"text":" objects in configuration structs have been","type":"text"},{"text":" ","type":"text"},{"text":"replaced with the ","type":"text"},{"type":"codeVoice","code":"EditionDateFormatter"},{"text":" protocol. This enables more fine","type":"text"},{"text":" ","type":"text"},{"text":"grained customization and allows for alternative naming strategies such as","type":"text"},{"text":" ","type":"text"},{"text":"edition names, identifiers, or any other custom labeling approach.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The SDK provides a "},{"type":"codeVoice","code":"DefaultEditionDateFormatter"},{"type":"text","text":" that wraps a"},{"type":"text","text":" "},{"type":"codeVoice","code":"DateFormatter"},{"type":"text","text":". This allows"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let dateFormatter = DateFormatter()","dateFormatter.dateFormat = \"d MMMM yyyy\"","dateFormatter.timeZone = .current","archiveConfig.dateFormatter = DefaultEditionDateFormatter(dateFormatter: dateFormatter)","","\/\/ Alternative initializer","archiveConfig.dateFormatter = DefaultEditionDateFormatter(dateFormat: \"d MMMM yyyy\", timeZone: .current)"]},{"inlineContent":[{"inlineContent":[{"text":"Asset Customization","type":"text"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"text":"Breaking Change: The ","type":"text"},{"code":"imageResourceForName","type":"codeVoice"},{"text":" callbacks have been removed. They","type":"text"},{"text":" ","type":"text"},{"text":"have been replaced by ","type":"text"},{"code":"AssetDelegate","type":"codeVoice"},{"text":". To migrate to the new system implement","type":"text"},{"text":" ","type":"text"},{"text":"the delegate and set it as needed.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["\/\/ Customize assets as desired","struct MyAssetDelegate: PSReaderUI.AssetDelegate {","    func imageResource(for name: ImageResourceName) -> UIImage? {","        return name.defaultImage()","    }","}","","var globalConfig = PSReaderUI.GlobalConfiguration(apiKey: apiKey, accountGUID: accountGUID)","globalConfig.assetDelegate = MyAssetDelegate()"]}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"metadata":{"role":"article","modules":[{"name":"PSReaderUI"}],"title":"Migration Guides","roleHeading":"Article"},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Migration-Guides","interfaceLanguage":"swift"},"seeAlsoSections":[{"generated":true,"title":"Release Notes","anchor":"Release-Notes","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Change-Log"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/migration-guides"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/psreaderui\/migration-guides"]}],"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI":{"type":"topic","abstract":[{"text":"A UI framework for building digital newspaper and magazine reader experiences on iOS.","type":"text"}],"url":"\/documentation\/psreaderui","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI","title":"PSReaderUI","role":"collection","kind":"symbol"},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Change-Log":{"role":"article","abstract":[{"type":"text","text":"Track new features, improvements, bug fixes, and other updates in each"},{"type":"text","text":" "},{"type":"text","text":"PSReaderUI SDK release."}],"kind":"article","url":"\/documentation\/psreaderui\/change-log","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Change-Log","title":"Change Log","type":"topic"}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"value":"occ","path":"\/identifier\/interfaceLanguage","op":"replace"},{"value":null,"path":"\/topicSections","op":"add"},{"value":[{"generated":true,"anchor":"Release-Notes","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Change-Log"],"title":"Release Notes"}],"path":"\/seeAlsoSections","op":"replace"}]}]}