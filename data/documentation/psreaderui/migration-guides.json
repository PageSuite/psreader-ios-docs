{"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"kind":"article","schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"primaryContentSections":[{"content":[{"anchor":"v2610","text":"v26.1.0","level":2,"type":"heading"},{"inlineContent":[{"inlineContent":[{"text":"Archive limit defaults","type":"text"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"archiveLimit"},{"type":"text","text":" now defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", with type-specific behavior:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Replica archives: 30 editions (unchanged from previous releases)."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Feed archives: unbounded — shows the full backend archive (usually ~1 year)."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"This is a behavior change for feed edition clients who previously saw a default","type":"text"},{"text":" ","type":"text"},{"text":"of 30 editions. To restore the old behavior, explicitly set ","type":"text"},{"type":"codeVoice","code":"archiveLimit"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","archiveConfig.archiveLimit = 30"],"type":"codeListing"},{"inlineContent":[{"inlineContent":[{"text":"Modern replica reader","type":"text"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"text":"A modern replacement for the legacy replica reader is now available. It shares","type":"text"},{"text":" ","type":"text"},{"text":"delegates and navigation with the feed edition reader, giving end users the same","type":"text"},{"text":" ","type":"text"},{"text":"experience regardless of backend. Replica-specific analytics events still fire.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Opt in by setting "},{"type":"codeVoice","code":"useLegacyReplicaReader"},{"type":"text","text":" to "},{"type":"codeVoice","code":"false"},{"type":"text","text":" (defaults to "},{"type":"codeVoice","code":"true"},{"type":"text","text":" for"},{"type":"text","text":" "},{"type":"text","text":"now). The modern reader will become the default in a future release, and the"},{"type":"text","text":" "},{"type":"text","text":"legacy reader will be removed further out."}],"type":"paragraph"},{"syntax":"swift","code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","archiveConfig.readerConfig.useLegacyReplicaReader = false"],"type":"codeListing"},{"name":"Important","style":"important","content":[{"inlineContent":[{"type":"text","text":"The legacy reader’s content browser next\/previous button events are"},{"type":"text","text":" "},{"type":"text","text":"not reported in the modern reader:"},{"type":"text","text":" "},{"code":"replicaPageBrowserNextTapped","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"replicaPageBrowserPreviousTapped","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"replicaArticleBrowserNextTapped","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"replicaArticleBrowserPreviousTapped","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"type":"aside"},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"LegacyReaderConfiguration"},{"type":"text","text":" properties (e.g. "},{"type":"codeVoice","code":"shareTemplater"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"prefersStatusBarHidden"},{"type":"text","text":", "},{"type":"codeVoice","code":"navigationBarItems"},{"type":"text","text":") do not apply to the modern"},{"type":"text","text":" "},{"type":"text","text":"reader — it uses the standard "},{"type":"codeVoice","code":"ReaderConfiguration"},{"type":"text","text":" delegates instead."}]}]},{"level":2,"type":"heading","anchor":"v550","text":"v5.5.0"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Liquid Glass UI defaults","type":"text"}],"type":"strong"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On iOS 26 and later, the SDK defaults to a new Liquid Glass design. The SDK"},{"type":"text","text":" "},{"type":"text","text":"respects the host app’s "},{"code":"UIDesignRequiresCompatibility","type":"codeVoice"},{"type":"text","text":" flag and will fall back"},{"type":"text","text":" "},{"type":"text","text":"automatically on older OS versions. The new design can also be controlled via"},{"type":"text","text":" "},{"type":"text","text":"the "},{"code":"LiquidGlassPolicy","type":"codeVoice"},{"type":"text","text":" option. You can apply this globally or more granularly"},{"type":"text","text":" "},{"type":"text","text":"on specific configuration objects (for example, subsection ribbon, navigation"},{"type":"text","text":" "},{"type":"text","text":"bar, page browser, etc.). To disable it globally:"}]},{"syntax":"swift","code":["var globalConfig = PSReaderUI.GlobalConfiguration(apiKey: apiKey, accountGUID: accountGUID)","globalConfig.liquidGlassPolicy = .disabled \/\/ disable Liquid Glass across the SDK"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Archive thumbnail layout","type":"text"}],"type":"strong"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Archive thumbnails now offer a dynamic layout mode:"},{"type":"text","text":" "},{"type":"codeVoice","code":"ImageContentMode.flexibleHeight"},{"type":"text","text":". It lets edition artwork (including the"},{"type":"text","text":" "},{"type":"text","text":"latest\/hero card) grow or shrink to its true aspect ratio, keeping the full"},{"type":"text","text":" "},{"type":"text","text":"image visible instead of cropping. Start with an estimated ratio for a steady"},{"type":"text","text":" "},{"type":"text","text":"initial layout; the SDK tunes the size automatically once the real image"},{"type":"text","text":" "},{"type":"text","text":"arrives. Example:"}]},{"syntax":"swift","code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","archiveConfig.thumbnailContentMode = .flexibleHeight(estimatedAspectRatio: 0.9)"],"type":"codeListing"},{"level":2,"type":"heading","anchor":"v520","text":"v5.2.0"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Reader UI\/UX Changes","type":"text"}]}]},{"inlineContent":[{"type":"text","text":"In PDF-driven editions, PDF pages and articles are now segmented. Users can no"},{"type":"text","text":" "},{"type":"text","text":"longer swipe between them. Articles are accessed either via article hotspot"},{"type":"text","text":" "},{"type":"text","text":"links or through the content browser. The content browser is also segmented in"},{"type":"text","text":" "},{"type":"text","text":"the same way, with a toggle that allows switching between pages and articles."},{"type":"text","text":" "},{"type":"text","text":"This behavior now matches the web reader."}],"type":"paragraph"},{"inlineContent":[{"text":"The navigation bar layout has also been updated:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"The right-side back arrow has been removed.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The left-side icon now adapts to the current context:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Dismiss Article – If the user opened an article from a hotspot link, this"},{"type":"text","text":" "},{"type":"text","text":"action returns them to the PDF page containing that article."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dismiss Reader – In all other cases, this action dismisses the reader"},{"type":"text","text":" "},{"type":"text","text":"view controller."}]}]}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"You can customize the icons for these actions via your ","type":"text"},{"type":"codeVoice","code":"AssetDelegate"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["ImageResourceName.dismiss        \/\/ Default: back arrow","ImageResourceName.dismissArticle \/\/ Default: xmark"],"syntax":"swift","type":"codeListing"},{"text":"v5.0.0","level":2,"anchor":"v500","type":"heading"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Edition Download Behavior"}]}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"5.0.0"},{"type":"text","text":" introduces the ability to read editions without downloading them."},{"type":"text","text":" "},{"type":"text","text":"This is the new default behavior. It can be customized by users via the reader"},{"type":"text","text":" "},{"type":"text","text":"settings menu. To retain the original default:"}],"type":"paragraph"},{"code":["var archiveConfig = PSReaderUI.ArchiveConfiguration(globalConfig: globalConfig)","archiveConfig.readerConfig.settings.downloadWhileReadingDefault = false","","\/\/ To hide the user facing setting","archiveConfig.readerConfig.settings.isDownloadWhileReadingToggleEnabled = false","archiveConfig.readerConfig.settings.isDownloadWhileReadingPreferenceAlertEnabled = false"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Edition Date Formatting"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"text":"Breaking Change: ","type":"text"},{"type":"codeVoice","code":"DateFormatter"},{"text":" objects in configuration structs have been","type":"text"},{"text":" ","type":"text"},{"text":"replaced with the ","type":"text"},{"type":"codeVoice","code":"EditionDateFormatter"},{"text":" protocol. This enables more fine","type":"text"},{"text":" ","type":"text"},{"text":"grained customization and allows for alternative naming strategies such as","type":"text"},{"text":" ","type":"text"},{"text":"edition names, identifiers, or any other custom labeling approach.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The SDK provides a "},{"type":"codeVoice","code":"DefaultEditionDateFormatter"},{"type":"text","text":" that wraps a"},{"type":"text","text":" "},{"type":"codeVoice","code":"DateFormatter"},{"type":"text","text":". This allows"}],"type":"paragraph"},{"code":["let dateFormatter = DateFormatter()","dateFormatter.dateFormat = \"d MMMM yyyy\"","dateFormatter.timeZone = .current","archiveConfig.dateFormatter = DefaultEditionDateFormatter(dateFormatter: dateFormatter)","","\/\/ Alternative initializer","archiveConfig.dateFormatter = DefaultEditionDateFormatter(dateFormat: \"d MMMM yyyy\", timeZone: .current)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Asset Customization"}]}],"type":"paragraph"},{"inlineContent":[{"text":"Breaking Change: The ","type":"text"},{"code":"imageResourceForName","type":"codeVoice"},{"text":" callbacks have been removed. They","type":"text"},{"text":" ","type":"text"},{"text":"have been replaced by ","type":"text"},{"code":"AssetDelegate","type":"codeVoice"},{"text":". To migrate to the new system implement","type":"text"},{"text":" ","type":"text"},{"text":"the delegate and set it as needed.","type":"text"}],"type":"paragraph"},{"code":["\/\/ Customize assets as desired","struct MyAssetDelegate: PSReaderUI.AssetDelegate {","    func imageResource(for name: ImageResourceName) -> UIImage? {","        return name.defaultImage()","    }","}","","var globalConfig = PSReaderUI.GlobalConfiguration(apiKey: apiKey, accountGUID: accountGUID)","globalConfig.assetDelegate = MyAssetDelegate()"],"syntax":null,"type":"codeListing"}],"kind":"content"}],"abstract":[{"type":"text","text":"Guidance to help you smoothly transition your app to newer versions of the SDK."},{"type":"text","text":" "},{"type":"text","text":"This page highlights breaking changes, necessary updates, and recommended"},{"type":"text","text":" "},{"type":"text","text":"practices when migrating between versions."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/migration-guides"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/psreaderui\/migration-guides"]}],"seeAlsoSections":[{"title":"Release Notes","generated":true,"anchor":"Release-Notes","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Change-Log"]}],"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Migration-Guides","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Article","modules":[{"name":"PSReaderUI"}],"role":"article","title":"Migration Guides"},"references":{"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI/Change-Log":{"title":"Change Log","role":"article","kind":"article","type":"topic","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Change-Log","url":"\/documentation\/psreaderui\/change-log","abstract":[{"text":"Track new features, improvements, bug fixes, and other updates in each","type":"text"},{"text":" ","type":"text"},{"text":"PSReaderUI SDK release.","type":"text"}]},"doc://com.pagesuite.PSReaderUI/documentation/PSReaderUI":{"role":"collection","type":"topic","kind":"symbol","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI","url":"\/documentation\/psreaderui","abstract":[{"type":"text","text":"A UI framework for building digital newspaper and magazine reader experiences on iOS."}],"title":"PSReaderUI"}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"path":"\/identifier\/interfaceLanguage","value":"occ","op":"replace"},{"path":"\/topicSections","value":null,"op":"add"},{"path":"\/seeAlsoSections","value":[{"anchor":"Release-Notes","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Change-Log"],"title":"Release Notes","generated":true}],"op":"replace"}]}]}