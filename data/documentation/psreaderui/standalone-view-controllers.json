{"metadata":{"title":"Standalone View Controllers","modules":[{"name":"PSReaderUI"}],"roleHeading":"Article","role":"article"},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Standalone-View-Controllers","interfaceLanguage":"swift"},"abstract":[{"text":"Use archive, bookmarks, and downloads views outside of the carousel.","type":"text"}],"seeAlsoSections":[{"identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Theming-and-Customization","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Localization"],"generated":true,"title":"Customization","anchor":"Customization"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/standalone-view-controllers"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/psreaderui\/standalone-view-controllers"]}],"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","isActive":true},{"type":"text","text":" is the primary way to present SDK content, but"},{"type":"text","text":" "},{"type":"text","text":"the SDK also exposes three standalone view controllers for use outside the"},{"type":"text","text":" "},{"type":"text","text":"carousel. These are useful when you want to embed a specific view in your own"},{"type":"text","text":" "},{"type":"text","text":"navigation hierarchy or present it independently."}],"type":"paragraph"},{"text":"When to Use Standalone View Controllers","type":"heading","level":2,"anchor":"When-to-Use-Standalone-View-Controllers"},{"inlineContent":[{"type":"text","text":"Use standalone view controllers when you need to embed a single content view"},{"type":"text","text":" "},{"type":"text","text":"in your own navigation hierarchy — for example, a bookmarks tab in a custom"},{"type":"text","text":" "},{"type":"text","text":"tab bar controller. Prefer "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","isActive":true},{"type":"text","text":" when you want the full"},{"type":"text","text":" "},{"type":"text","text":"tabbed experience with section ribbons, since it manages navigation and layout"},{"type":"text","text":" "},{"type":"text","text":"internally."}],"type":"paragraph"},{"text":"ArchiveViewController","type":"heading","level":2,"anchor":"ArchiveViewController"},{"inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveViewController","isActive":true,"type":"reference"},{"text":" displays a publication’s edition archive in a grid","type":"text"},{"text":" ","type":"text"},{"text":"layout. Initialize it with an ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveViewController\/ArchiveType","isActive":true,"type":"reference"},{"text":" to specify","type":"text"},{"text":" ","type":"text"},{"text":"the content source:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Feed edition archive","let feedArchive = PSReaderUI.ArchiveViewController(","    globalConfig: globalConfig,","    archiveType: .feedArchive(guid: \"APP_GUID\", publicationName: \"My Publication\")",")","","\/\/ Replica edition archive","let replicaArchive = PSReaderUI.ArchiveViewController(","    globalConfig: globalConfig,","    archiveType: .replicaArchive(guid: \"PUB_GUID\")",")","","\/\/ Kiosk grids","let replicaKiosk = PSReaderUI.ArchiveViewController(","    globalConfig: globalConfig,","    archiveType: .replicaPublicationKiosk(publications: replicaPublications)",")","","let feedKiosk = PSReaderUI.ArchiveViewController(","    globalConfig: globalConfig,","    archiveType: .feedPublicationKiosk(publications: feedPublications)",")"],"type":"codeListing"},{"inlineContent":[{"text":"Pass an optional ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration","isActive":true,"type":"reference"},{"text":" to customize the appearance.","type":"text"}],"type":"paragraph"},{"text":"Kiosk Grid Setup","type":"heading","level":3,"anchor":"Kiosk-Grid-Setup"},{"inlineContent":[{"type":"text","text":"For kiosk grids, build an array of "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/KioskReplicaPublication","isActive":true},{"type":"text","text":" entries. Each"},{"type":"text","text":" "},{"type":"text","text":"entry specifies a publication GUID and an optional per-publication"},{"type":"text","text":" "},{"type":"text","text":"configuration override:"}],"type":"paragraph"},{"syntax":"swift","code":["let publications = [","    PSReaderUI.KioskReplicaPublication(guid: \"PUB_GUID_1\"),","    PSReaderUI.KioskReplicaPublication(guid: \"PUB_GUID_2\"),","    PSReaderUI.KioskReplicaPublication(","        guid: \"PUB_GUID_3\",","        archiveConfig: specialArchiveConfig  \/\/ Optional override","    )","]","","let kioskVC = PSReaderUI.ArchiveViewController(","    globalConfig: globalConfig,","    archiveType: .replicaPublicationKiosk(publications: publications)",")"],"type":"codeListing"},{"text":"BookmarksViewController","type":"heading","anchor":"BookmarksViewController","level":2},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/BookmarksViewController","isActive":true},{"text":" displays the user’s bookmarked pages and articles.","type":"text"},{"text":" ","type":"text"},{"text":"Filter the displayed content using ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documen