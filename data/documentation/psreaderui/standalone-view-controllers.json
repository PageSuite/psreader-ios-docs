(publications: replicaPublications)",")","","let feedKiosk = PSReaderUI.ArchiveViewController(","    globalConfig: globalConfig,","    archiveType: .feedPublicationKiosk(publications: feedPublications)",")"]},{"inlineContent":[{"type":"text","text":"Pass an optional "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ArchiveConfiguration"},{"type":"text","text":" to customize the appearance."}],"type":"paragraph"},{"level":3,"type":"heading","anchor":"Kiosk-Grid-Setup","text":"Kiosk Grid Setup"},{"inlineContent":[{"type":"text","text":"For kiosk grids, build an array of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/KioskReplicaPublication"},{"type":"text","text":" entries. Each"},{"type":"text","text":" "},{"type":"text","text":"entry specifies a publication GUID and an optional per-publication"},{"type":"text","text":" "},{"type":"text","text":"configuration override:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let publications = [","    PSReaderUI.KioskReplicaPublication(guid: \"PUB_GUID_1\"),","    PSReaderUI.KioskReplicaPublication(guid: \"PUB_GUID_2\"),","    PSReaderUI.KioskReplicaPublication(","        guid: \"PUB_GUID_3\",","        archiveConfig: specialArchiveConfig  \/\/ Optional override","    )","]","","let kioskVC = PSReaderUI.ArchiveViewController(","    globalConfig: globalConfig,","    archiveType: .replicaPublicationKiosk(publications: publications)",")"]},{"level":2,"type":"heading","anchor":"BookmarksViewController","text":"BookmarksViewController"},{"inlineContent":[{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/BookmarksViewController","type":"reference","isActive":true},{"type":"text","text":" displays the user’s bookmarked pages and articles."},{"type":"text","text":" "},{"type":"text","text":"Filter the displayed content using "},{"identifier":"doc:\/\/com.pa