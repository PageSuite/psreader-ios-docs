{"abstract":[{"type":"text","text":"Use archive, bookmarks, and downloads views outside of the carousel."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/psreaderui\/standalone-view-controllers"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/psreaderui\/standalone-view-controllers"]}],"metadata":{"modules":[{"name":"PSReaderUI"}],"role":"article","title":"Standalone View Controllers","roleHeading":"Article"},"identifier":{"url":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Standalone-View-Controllers","interfaceLanguage":"swift"},"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"seeAlsoSections":[{"anchor":"Customization","identifiers":["doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Theming-and-Customization","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Carousel-Setup","doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Localization"],"title":"Customization","generated":true}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/CarouselViewController","isActive":true},{"type":"text","text":" is the primary way to present SDK content, but"},{"type":"text","text":" "},{"type":"text","text":"the SDK also exposes three standalone view controllers for use outside the"},{"type":"text","text":" "},{"type":"text","text":"carousel. These are useful when you want to embed a specific view in your own"},{"type":"text","text":" "},{"type":"text","text":"navigation hierarchy or present it independently."}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"When-to-Use-Standalone-View-Controllers","text":"When to Use Standalone View Controllers"},{"inli