{"abstract":[{"text":"Open a specific feed edition directly, bypassing the archive screen.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"inlineContent":[{"type":"text","text":"When your app receives a push notification, handles a URL scheme, or responds"},{"type":"text","text":" "},{"type":"text","text":"to a universal link, you often want to jump straight to a specific edition"},{"type":"text","text":" "},{"type":"text","text":"rather than showing the archive grid first. "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/FeedReaderViewController","isActive":true},{"type":"text","text":" "},{"type":"text","text":"provides a standalone reader that loads a single edition and presents its own"},{"type":"text","text":" "},{"type":"text","text":"dismiss button, making it ideal for these entry points."}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":""},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/FeedReaderViewController","isActive":true},{"type":"text","text":" supports feed editions only. Replica"},{"type":"text","text":" "},{"type":"text","text":"editions are not supported. See "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Replica-and-Feed-Editions","isActive":true},{"type":"text","text":" to determine"},{"type":"text","text":" "},{"type":"text","text":"which system your publication uses."}],"type":"paragraph"}],"type":"aside"},{"inlineContent":[{"type":"text","text":"For general SDK setup and credentials, see "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Getting-Started","isActive":true},{"type":"text","text":". For other"},{"type":"text","text":" "},{"type":"text","text":"standalone view controllers like "},{"type":"refer