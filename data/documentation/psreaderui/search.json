service"}]},{"text":" — use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchService"},{"text":" directly to build a fully custom search UI.","type":"text"}]}]}],"type":"unorderedList"},{"text":"Adding Search to the Carousel","anchor":"Adding-Search-to-the-Carousel","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Add a search tab to the carousel using the "},{"code":".search(config:)","type":"codeVoice"},{"type":"text","text":" content type."},{"type":"text","text":" "},{"type":"text","text":"When using a dynamic archive, the carousel provides a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchDelegate"},{"type":"text","text":" "},{"type":"text","text":"automatically — no additional setup is needed:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    sections: [","        .dynamicArchive(\"Editions\", shortcode: \"SHORTCODE\"),","        .subsections(\"More\", [","            .init(name: \"Bookmarks\", type: .bookmarks(type: .all)),","            .init(name: \"Search\", type: .search(config: searchConfig))","        ])","    ]",")"]},{"inlineContent":[{"type":"text","text":"When using manual sections, you must set a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchDelegate"},{"type":"text","text":" on the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchConfiguration"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["var searchConfig = PSReaderUI.SearchConfiguration(globalConfig: globalConfig)","searchConfig.searchDelegate = PSReaderUI.ApplicationSearchDelegate(","    shortcode: \"SHORTCODE\",","    readerConfig: readerConfig",")","","let carouselVC = PSReaderUI.CarouselViewController(","    globalConfig: globalConfig,","    sections: [","        .section(.init(name: \"Daily\", type: .feedArchive(guid: \"APP_GUID\"))),","        .section(.init(name: \"Search\", type: .search(config: searchConfig)))","    ]",")"]},{"text":"Standalone Search View Controller","anchor":"Standalone-Search-View-Controller","type":"heading","level":2},{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchViewController","isActive":true},{"text":" presents search outside of the carousel. It requires","type":"text"},{"text":" ","type":"text"},{"text":"a ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchDelegate","isActive":true},{"text":" to provide the list of searchable publications and their","type":"text"},{"text":" ","type":"text"},{"text":"reader configurations. Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ApplicationSearchDelegate","isActive":true},{"text":" for a ready-made","type":"text"},{"text":" ","type":"text"},{"text":"implementation:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ From a shortcode (fetches application config lazily on first search)","let delegate = PSReaderUI.ApplicationSearchDelegate(","    shortcode: \"SHORTCODE\",","    readerConfig: readerConfig",")","","let searchVC = PSReaderUI.SearchViewController(","    globalConfig: globalConfig,","    delegate: delegate",")","","navigationController?.pushViewController(searchVC, animated: true)"]},{"inlineContent":[{"text":"For modal presentation, set ","type":"text"},{"code":"dismissible","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" to show a close button:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let searchVC = PSReaderUI.SearchViewController(","    globalConfig: globalConfig,","    delegate: delegate,","    dismissible: true",")","","present(searchVC, animated: true)"]},{"inlineContent":[{"type":"text","text":"If you already have a "},{"type":"codeVoice","code":"PSEApplication"},{"type":"text","text":" object, you can create the delegate"},{"type":"text","text":" "},{"type":"text","text":"from it directly:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let delegate = PSReaderUI.ApplicationSearchDelegate(","    application: myApplication,","    readerConfig: readerConfig",")"]},{"inlineContent":[{"text":"See ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Standalone-View-Controllers","isActive":true,"type":"reference"},{"text":" for common patterns like interface style","type":"text"},{"text":" ","type":"text"},{"text":"overrides.","type":"text"}],"type":"paragraph"},{"text":"In-Reader Search","anchor":"In-Reader-Search","type":"heading","level":2},{"inlineContent":[{"text":"When ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ReaderConfiguration\/search"},{"text":" is set with a non-nil","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchConfiguration\/searchDelegate"},{"text":", a search option appears in the reader’s","type":"text"},{"text":" ","type":"text"},{"text":"settings menu.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In carousel-based setups this is configured automatically — the carousel","type":"text"},{"text":" ","type":"text"},{"text":"provides a default ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchDelegate","isActive":true,"type":"reference"},{"text":" if one is not set