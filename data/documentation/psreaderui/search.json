/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchPublicationType","isActive":true,"type":"reference"},{"text":" — either","type":"text"},{"text":" ","type":"text"},{"code":".app","type":"codeVoice"},{"text":" or ","type":"text"},{"code":".publication","type":"codeVoice"},{"text":". Despite the confusing names, there is no functional","type":"text"},{"text":" ","type":"text"},{"text":"difference between the two; they simply reflect how the publication is indexed","type":"text"},{"text":" ","type":"text"},{"text":"on the backend. Passing the wrong type will cause search to return no results.","type":"text"},{"text":" ","type":"text"},{"text":"You can find the correct type in your application configuration — the carousel","type":"text"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/ApplicationSearchDelegate","isActive":true,"type":"reference"},{"text":" resolve this automatically.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let service = PSReaderUI.SearchService()","","service.search(","    accountGuid: \"ACCOUNT_GUID\",","    query: \"election results\",","    type: .all,","    publications: [","        (.app, \"APP_GUID_1\"),","        (.publication, \"PUB_GUID_2\")","    ],","    offset: 0,","    limit: 20,","    timeZone: .current",") { result in","    switch result {","    case .success(let response):","        let totalCount = response.meta?.totalCount ?? 0","        let results = response.data ?? []","","        for item in results {","            print(item.headline ?? \"Untitled\")","            print(item.snippet ?? \"\")","        }","","    case .failure(let error):","        print(error)","    }","}"]},{"inlineContent":[{"type":"text","text":"Each "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchResult"},{"type":"text","text":" includes:"}],"type":"paragraph"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Property"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"type"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"EDITION_ARTICLE\""},{"type":"text","text":" or "},{"type":"codeVoice","code":"\"EDITION_PAGE\""},{"type":"text","text":"."}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"editionId"}]}],[{"type":"paragraph","inlineContent":[{"text":"The GUID of the edition containing the result.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"pageId"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"The GUID of the specific page."}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"applicationId"}]}],[{"type":"paragraph","inlineContent":[{"text":"The application GUID (publication identifier).","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"headline"}]}],[{"type":"paragraph","inlineContent":[{"text":"Article headline (articles only).","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"section"}]}],[{"type":"paragraph","inlineContent":[{"text":"Section name (articles only).","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"pageNumber","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Page number (pages only).","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"snippet"}]}],[{"type":"paragraph","inlineContent":[{"text":"Text excerpt with ","type":"text"},{"type":"codeVoice","code":"<b>"},{"text":" tags around matching terms.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"images","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Array of associated images with URLs and captions.","type":"text"}]}]]],"type":"table"},{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchResult\/formattedSnippet(font:)"},{"type":"text","text":" to convert the snippet into an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSAttributedString"},{"type":"text","text":" with bold highlights:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let attributedSnippet = result.formattedSnippet(font: .systemFont(ofSize: 14))"]},{"text":"Opening Search Results","anchor":"Opening-Search-Results","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/FeedReaderViewController","isActive":true},{"type":"text","text":" to open an edition from a "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/SearchResult","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Map the result’s identifiers to the reader’s initializer parameters:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["guard let editionGUID = result.editionId,","      let publicationGUID = result.applicationId else {","    return","}","","let reader = PSReaderUI.FeedReaderViewController(","    globalConfig: globalConfig,","    publicationGUID: publicationGUID,","    editionGUID: editionGUID,","    openingPage: result.pageId.map { .page(guid: $0) }",")","","present(reader, animated: true)"]},{"inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/com.pagesuite.PSReaderUI\/documentation\/PSReaderUI\/Deep-Linking","isActive":true},{"type":"text","text":" for more on presenting the reader directly."}],"type":"paragraph"},{"text":"Paywall Integration","anchor":"Paywall-Integration","type":"heading","level":2},{"inlineContent":[{"